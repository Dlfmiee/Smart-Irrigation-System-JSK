void logToGoogleSheets() {
  if (WiFi.status() != WL_CONNECTED) return;
  Serial.println("📊 [LOG] Sending master log to Google Sheets...");
  WiFiClientSecure client; client.setInsecure();
  HTTPClient http;
  String url = String(googleScriptUrl)
             + "?pump="     + String(pumpRunning ? "1" : "0")
             + "&flowE="    + String(flowE, 3)
             + "&moisture=" + String(moisturePct)
             + "&rainfall=" + String(rainfallMm, 2)
             + "&rain="     + String(rainLockout ? "1" : "0")
             + "&tank="     + String(tankFull)
             + "&ec="       + String(ecValue, 2)
             + "&valveA="   + String(v5_open ? "1" : "0")
             + "&valveB="   + String(v6_open ? "1" : "0")
             + "&valveC="   + String(v3_open ? "1" : "0")
             + "&valveD="   + String(v4_open ? "1" : "0");
  http.begin(client, url);
  int code = http.GET();
  http.end();
  Serial.printf("✅ [LOG] Google Sheets response: %d\n", code);
}

// ================= MASTER FETCH (Gather Data) =================

void fetchRemoteStatus() {
  if (WiFi.status() != WL_CONNECTED) return;
  Serial.println("🔄 [SYNC] Fetching remote status from all nodes...");
  WiFiClientSecure client; client.setInsecure();
  HTTPClient http;

  // Sync Valves
  auto fetchAPI = [&](const char* token, const char* vPin, int& outVar, int bVpin) {
    http.begin(client, "https://blynk.cloud/external/api/get?token=" + String(token) + "&" + vPin);
    if (http.GET() == 200) { outVar = http.getString().toInt(); Blynk.virtualWrite(bVpin, outVar); }
    http.end();
  };
  
  fetchAPI(ALTF4_TOKEN, "V5", (int&)v5_open, V5);
  fetchAPI(ALTF4_TOKEN, "V6", (int&)v6_open, V6);
  fetchAPI(CYBERSPARK_TOKEN, "V3", (int&)v3_open, V3);
  fetchAPI(CYBERSPARK_TOKEN, "V4", (int&)v4_open, V4);
  Serial.printf("[SYNC] Valves -> A:%d B:%d C:%d D:%d\n", v5_open, v6_open, v3_open, v4_open);
  
  // Sync Sensors
  http.begin(client, "https://blynk.cloud/external/api/get?token=" + String(SENSOR_TOKEN) + "&V12");
  if (http.GET() == 200) { rainLockout = http.getString().toInt(); Blynk.virtualWrite(V12, rainLockout); }
  http.end();
  http.begin(client, "https://blynk.cloud/external/api/get?token=" + String(SENSOR_TOKEN) + "&V8");
  if (http.GET() == 200) { rainfallMm = http.getString().toFloat(); Blynk.virtualWrite(V8, rainfallMm); }
  http.end();
  http.begin(client, "https://blynk.cloud/external/api/get?token=" + String(SENSOR_TOKEN) + "&V7");
  if (http.GET() == 200) { moisturePct = http.getString().toInt(); Blynk.virtualWrite(V7, moisturePct); }
  http.end();
  http.begin(client, "https://blynk.cloud/external/api/get?token=" + String(SENSOR_TOKEN) + "&V1");
  if (http.GET() == 200) { tankFull = http.getString().toInt(); Blynk.virtualWrite(V1, tankFull); }
  http.end();
  http.begin(client, "https://blynk.cloud/external/api/get?token=" + String(SENSOR_TOKEN) + "&V2");
  if (http.GET() == 200) { ecValue = http.getString().toFloat(); Blynk.virtualWrite(V2, ecValue); }
  http.end();
  Serial.printf("[SYNC] Sensors -> Rain:%d Rainfall:%.2fmm Moisture:%d%% Tank:%d EC:%.2f\n", rainLockout, rainfallMm, moisturePct, tankFull, ecValue);
  Serial.println("✅ [SYNC] Remote fetch complete. Evaluating pump...");

  evaluatePumpState(); 
}

