// ================= WIFI =================

void checkWiFi() {
  if (WiFi.status() != WL_CONNECTED) {
    digitalWrite(wifiLedPin, LOW);
    WiFi.begin(ssid, pass);
  } else {
    digitalWrite(wifiLedPin, HIGH);
  }
}

// ================= SETUP =================

void setup() {
  Serial.begin(115200);

  pinMode(relayPin, OUTPUT);
  pinMode(ledPin, OUTPUT);
  pinMode(wifiLedPin, OUTPUT);

  stopPump();

  // Limited blocking WiFi connect so WDT/Loop isn't fully blocked forever if routing issues occur
  WiFi.begin(ssid, pass);
  int attempt = 0;
  while (WiFi.status() != WL_CONNECTED && attempt < 20) { 
    delay(500); 
    attempt++;
  }

  Blynk.config(BLYNK_AUTH_TOKEN);
  Blynk.connect();

  esp_task_wdt_config_t config = {300000, 0, true};
  esp_task_wdt_reconfigure(&config);

  timer.setInterval(10000L, checkWiFi);
  timer.setInterval(60000L, fetchRemoteValveStatus);
  timer.setInterval(300000L, logToGoogleSheets);
}

// ================= LOOP =================

void loop() {
  if (Blynk.connected()) {
    Blynk.run();
  } else if (WiFi.status() == WL_CONNECTED) {
    // Attempt reconnect occasionally without blocking the whole loop
    if (millis() % 15000 < 100) Blynk.connect();
  }
  
  timer.run();
  if (wdtActive) esp_task_wdt_reset();
}