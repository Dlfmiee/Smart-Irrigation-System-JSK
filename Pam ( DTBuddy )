/* --- Pins --- */
const int relayPin = 26;   // ACTIVE-LOW
const int ledPin   = 27;   // Custom Hardware LED
const int wifiLedPin = 2;  // Built-in Wi-Fi Status LED

/* --- State Variables --- */
bool pumpState = false;
bool pumpError = false;      
unsigned long pumpStartTime = 0;

// Valve & Cloud States
bool v3_open = false, v4_open = false; // Valve C & D
bool v5_open = false, v6_open = false; // Valve A & B
bool rainLockout = false;              // Global Rain (V12)
float flowE = 0;

/* 
  Pump Mode (V13):
  0 = AUTO (Default)
  1 = MANUAL ON (Force)
  2 = MANUAL OFF (Force Stop)
*/
int pumpMode = 0; 

BlynkTimer timer;

// ================== HELPER FUNCTIONS ==================

void updateLED() {
  // Sync LED with active relay state
  digitalWrite(ledPin, !digitalRead(relayPin)); 
}

void startupBlink(int count, int speed) {
  for(int i=0; i<count; i++) {
    digitalWrite(ledPin, LOW); delay(speed);
    digitalWrite(ledPin, HIGH); delay(speed);
  }
}

// ================== CORE FUNCTIONS ==================

void turnPumpON() {
  if (pumpState) return;
  digitalWrite(relayPin, LOW); 
  pumpState = true;
  pumpStartTime = millis();
  Blynk.virtualWrite(V11, 1);
  updateLED();
  Serial.println("[SYSTEM] PUMP ON");
}

void turnPumpOFF() {
  if (!pumpState) return;
  digitalWrite(relayPin, HIGH); 
  pumpState = false;
  Blynk.virtualWrite(V11, 0);
  updateLED();
  Serial.println("[SYSTEM] PUMP OFF");
}

void masterResetAll() {
  turnPumpOFF();
  Blynk.virtualWrite(V3, 0); v3_open = false;
  Blynk.virtualWrite(V4, 0); v4_open = false;
  Blynk.virtualWrite(V5, 0); v5_open = false;
  Blynk.virtualWrite(V6, 0); v6_open = false;
  Serial.println("MASTER: 30-Minute Cycle Finished. System Reset.");
}

void evaluatePumpState() {
  bool anyOutletOpen = (v4_open || v6_open);
  
  // ⛔ PRIORITY 1: Safety Shuts & Force Stop
  if (rainLockout || pumpError || pumpMode == 2) {
    turnPumpOFF();
    if (pumpMode == 2) Serial.println("[MODE] Pump Force Disabled");
  } 
  // 🚀 PRIORITY 2: Manual Start
  else if (pumpMode == 1) {
    turnPumpON();
    Serial.println("[MODE] Pump Force Started");
  }
  // ⚙️ PRIORITY 3: Auto Mode
  else {
    if (anyOutletOpen) {
      turnPumpON();
    } else {
      turnPumpOFF();
    }
  }

  // --- Post-Activation Monitoring (Safety) ---
  if (pumpState && !pumpError) {
    unsigned long runTime = millis() - pumpStartTime;

    // Dry-Run Protection (15s Window)
    if (runTime > 15000 && runTime < 20000) {
      if (flowE < 0.1) {
        Serial.println("DRY RUN DETECTED! Shutting down.");
        pumpError = true;
        masterResetAll();
        Blynk.logEvent("pump_error", "Dry Run Detected! Hardware protected.");
        return; 
      }
    }

    // 30-Minute Master Cap
    if (runTime >= 1800000) {
      masterResetAll();
    }
  }
}

void syncCloudData() {
  Blynk.syncVirtual(V3, V4, V5, V6, V12); 
  Blynk.syncVirtual(V0); 
}

void checkWiFi() {
  if (WiFi.status() == WL_CONNECTED) {
    digitalWrite(wifiLedPin, HIGH);   // 🔆 LED ON - WiFi OK
    Serial.println("✅ WiFi OK");
  } else {
    digitalWrite(wifiLedPin, LOW);  // ⚫ LED OFF - WiFi Lost
    Serial.println("📶 WiFi reconnect...");
    WiFi.begin(ssid, pass);
  }
}

void logToGoogleSheets() {
  if (WiFi.status() == WL_CONNECTED) {
    WiFiClientSecure client;
    client.setInsecure();
    HTTPClient http;

    String url = String(googleScriptUrl) + "?pump=" + String(pumpState);
    http.begin(client, url);
    http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);
    http.GET();
    http.end();
  }
}

// ================== BLYNK HANDLERS ==================

BLYNK_WRITE(V3) { v3_open = param.asInt(); }
BLYNK_WRITE(V4) { v4_open = param.asInt(); }
BLYNK_WRITE(V5) { v5_open = param.asInt(); }
BLYNK_WRITE(V6) { v6_open = param.asInt(); }
BLYNK_WRITE(V12){ rainLockout = param.asInt(); }
BLYNK_WRITE(V0) { flowE = param.asFloat(); }

BLYNK_WRITE(V13) {
  pumpMode = param.asInt();
  Serial.print("[MODE] New Master Switch State: ");
  Serial.println(pumpMode);
}

// ================== SETUP ==================

void setup() {
  Serial.begin(115200);
  pinMode(relayPin, OUTPUT);
  pinMode(ledPin, OUTPUT);
  pinMode(wifiLedPin, OUTPUT);
  digitalWrite(wifiLedPin, LOW); // Default OFF
  
  digitalWrite(relayPin, HIGH); // Default OFF
  updateLED();                  // Sync custom LED with initial relay state

  // Visual feedback
  startupBlink(5, 200);

  Blynk.begin(auth, ssid, pass);

  esp_task_wdt_config_t twdt_config = {
      .timeout_ms = 30000,
      .idle_core_mask = 0,
      .trigger_panic = true,
  };
  esp_task_wdt_init(&twdt_config);
  esp_task_wdt_add(NULL);

  timer.setInterval(1000L, evaluatePumpState); // High responsiveness
  timer.setInterval(5000L, syncCloudData);
  timer.setInterval(10000L, checkWiFi);         // WiFi indicator update
  timer.setInterval(300000L, logToGoogleSheets);
  
  Serial.println("[SYSTEM] Pump Node Ready");
}

void loop() {
  Blynk.run();
  timer.run();
  esp_task_wdt_reset();
}