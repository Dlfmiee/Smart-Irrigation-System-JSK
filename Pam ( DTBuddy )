// ================= RECONNECT LOGIC =================

void reconnectBlynk() {
  if (!Blynk.connected() && WiFi.status() == WL_CONNECTED) {
    Serial.println("🌐 [BLYNK] Reconnecting...");
    Blynk.connect();
  }
}

void checkWiFi() {
  wl_status_t status = WiFi.status();

  if (status != WL_CONNECTED) {
    digitalWrite(wifiLedPin, LOW);
    if (status == WL_IDLE_STATUS) {
      Serial.println("📶 [WIFI] Connecting...");
    } else {
      Serial.printf("📶 [WIFI] Lost (status=%d). Retrying...\n", status);
      WiFi.begin(ssid, pass);
    }
  } else {
    digitalWrite(wifiLedPin, HIGH);
  }
}

// ================= SAFE EVALUATE =================
unsigned long lastEvalTime = 0;

void safeEvaluate() {
  if (millis() - lastEvalTime > 2000) {
    evaluatePumpState();
    lastEvalTime = millis();
  }
}

// ================= PUMP HARDWARE =================

void startPump() {
  if (pumpRunning || pumpError) return;
  
  // Hardware Debounce: Prevent rapid ON/OFF clicking (5 sec)
  // FIX: If we must wait, we schedule a re-check! If we just 'return' here
  // (like ChatGPT suggested), the pump would NEVER start.
  if (millis() - lastPumpAction < 5000) {
    unsigned long waitTime = 5000 - (millis() - lastPumpAction);
    Serial.println("⏳ [PUMP] Delay active. Will start automatically in a few seconds...");
    timer.setTimeout(waitTime + 100, evaluatePumpState);
    return;
  }

  digitalWrite(relayPin, HIGH);
  digitalWrite(ledPin, HIGH);
  pumpRunning = true;
  pumpStartTime = millis();
  lastPumpAction = millis();

  // State Latching: Update Blynk Dashboard
  Blynk.virtualWrite(V1, 1);
  Blynk.virtualWrite(V11, 1);

  Serial.println("💦 [STATUS] PUMP STARTED");
}

void stopPump() {
  if (!pumpRunning) {
    digitalWrite(ledPin, LOW);
    return;
  }
  
  // FIX: We do NOT debounce 'stop' events. If a sensor detects dry-run or rain,
  // we MUST stop the pump instantly for safety. ChatGPT's suggestion here was dangerous!

  digitalWrite(relayPin, LOW);
  digitalWrite(ledPin, LOW);
  pumpRunning = false;
  lastPumpAction = millis();

  Blynk.virtualWrite(V1, 0);
  Blynk.virtualWrite(V11, 0);

  Serial.println("❌ [STATUS] PUMP STOPPED");
}

void masterResetAll() {
  stopPump();
  v4_open = false;
  v6_open = false;
  pumpError = false;
  Blynk.virtualWrite(V2, 0);
  safeEvaluate();
}

// ================= LOGIC =================

void evaluatePumpState() {
  bool demand = (v4_open || v6_open);

  if (rainLockout || pumpError || pumpMode == 2) {
    if (pumpRunning) stopPump();
    return;
  }

  if (pumpMode == 1) { // FORCE RUN
    if (!pumpRunning) startPump();
    return;
  }

  if (demand) {
    if (!pumpRunning) startPump();
  } else {
    if (pumpRunning) stopPump();
  }

  // Watchdog Management (Dynamic)
  if (pumpRunning && !wdtActive) {
    esp_task_wdt_add(NULL);
    wdtActive = true;
    Serial.println("🛡️ [WATCHDOG] Armed.");
  } else if (!pumpRunning && wdtActive) {
    esp_task_wdt_delete(NULL);
    wdtActive = false;
    Serial.println("🔓 [WATCHDOG] Disarmed.");
  }
}

// ================= LOGGING =================

void logToGoogleSheets() {
  if (WiFi.status() != WL_CONNECTED) return;

  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;

  String url = String(googleScriptUrl)
             + "?pump=" + String(pumpRunning)
             + "&valveB=" + (v6_open ? "1" : "0")
             + "&valveD=" + (v4_open ? "1" : "0")
             + "&flowE=" + String(flowE, 3);

  http.begin(client, url);
  int httpCode = http.GET();
  if (httpCode <= 0) {
    Serial.printf("⚠️ [SHEETS] Failed. Code: %d\n", httpCode);
  }
  http.end();
}

