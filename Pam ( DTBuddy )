// ================= RECONNECT & NTP LOGIC =================

void syncNTP() {
  configTime(28800, 0, "pool.ntp.org", "time.google.com");
  struct tm t;
  if (getLocalTime(&t, 1000)) { ntpSynced = true; }
}

void reconnectBlynk() { if (!Blynk.connected() && WiFi.status() == WL_CONNECTED) Blynk.connect(); }

void checkWiFi() {
  wl_status_t s = WiFi.status();
  if (s == WL_CONNECTED) {
    digitalWrite(wifiLedPin, HIGH);
    if (!ntpSynced) syncNTP();
  } else if (s == WL_DISCONNECTED || s == WL_NO_SSID_AVAIL || s == WL_CONNECT_FAILED) {
    digitalWrite(wifiLedPin, LOW);
    ntpSynced = false;
    WiFi.begin(ssid, pass); // Only begin if not already connecting
  }
}

// ================= PUMP LOGIC =================
void evaluatePumpState() {
  bool demand = (v4_open || v6_open); 
  if (rainLockout || pumpError || pumpMode == 2) { if (pumpRunning) stopPump(); return; }
  if (pumpMode == 1) { if (!pumpRunning) startPump(); return; }
  if (demand) { if (!pumpRunning) startPump(); } else { if (pumpRunning) stopPump(); }

  if (pumpRunning && !wdtActive) { esp_task_wdt_add(NULL); wdtActive = true; }
  else if (!pumpRunning && wdtActive) { esp_task_wdt_delete(NULL); wdtActive = false; }
}

void startPump() {
  if (pumpRunning || pumpError) return;
  if (millis() - lastPumpAction < 5000) { timer.setTimeout(5100L, evaluatePumpState); return; }
  digitalWrite(relayPin, LOW); digitalWrite(ledPin, HIGH); // LOW = Relay ON for Active-LOW modules
  pumpRunning = true; lastPumpAction = millis();
  Blynk.virtualWrite(V11, 1);
}

void stopPump() {
  digitalWrite(relayPin, HIGH); digitalWrite(ledPin, LOW); // HIGH = Relay OFF for Active-LOW modules
  pumpRunning = false; lastPumpAction = millis();
  Blynk.virtualWrite(V11, 0);
}

