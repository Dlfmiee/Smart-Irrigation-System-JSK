/* --- Pins --- */
const int relayPin = 26;   // ACTIVE-LOW
const int ledPin   = 27;   

/* --- State Variables --- */
bool pumpState = false;
bool manualOverride = false;
bool pumpError = false;      
unsigned long pumpStartTime = 0;

// Valve States
bool v3_open = false, v4_open = false; // Valve C & D
bool v7_open = false, v8_open = false; // Valve A & B
bool rainLockout = false;              // Global Rain (V17)

// Flow Rates 
float flowC = 0, flowD = 0;
float flowA = 0, flowB = 0;
float flowE = 0;

BlynkTimer timer;

void turnPumpON() {
  if (pumpState) return;
  digitalWrite(relayPin, LOW); 
  pumpState = true;
  pumpStartTime = millis();
  Blynk.virtualWrite(V15, 1);
  Serial.println("PUMP ON: Starting Master Cycle Phase.");
}

void turnPumpOFF() {
  if (!pumpState) return;
  digitalWrite(relayPin, HIGH); 
  pumpState = false;
  Blynk.virtualWrite(V15, 0);
  Serial.println("PUMP OFF");
}

void masterResetAll() {
  // Master Controller enforces Default Mode (All Closed)
  turnPumpOFF();
  Blynk.virtualWrite(V3, 0); v3_open = false;
  Blynk.virtualWrite(V4, 0); v4_open = false;
  Blynk.virtualWrite(V7, 0); v7_open = false;
  Blynk.virtualWrite(V8, 0); v8_open = false;
  Serial.println("MASTER: 120s Cycle Finished. System returned to Default State.");
}

/* --- Core Smart Pump Logic --- */
void evaluatePumpState() {

  // We only care if an OUTLET valve is open (B or D) to run the pump 
  // (Inlet valves A and C don't strictly require the pump to open)
  bool anyOutletOpen = (v4_open || v8_open);
  
  // 1. Turn ON condition
  if (anyOutletOpen && !rainLockout && !pumpError) {
    turnPumpON();
  }
  
  // 2. Turn OFF conditions
  if (!anyOutletOpen || rainLockout || pumpError) {
    turnPumpOFF();
  }

  if (pumpState && !pumpError) {
    unsigned long runTime = millis() - pumpStartTime;

    // 3. Dry-Run Protection (Flow Verification - 15 Seconds)
    if (runTime > 15000 && runTime < 20000) { // Only check once strictly in this window
      float totalFlow = flowA + flowB + flowC + flowD + flowE;
      if (totalFlow < 0.1) {
        Serial.println("DRY RUN DETECTED! No flow after 15s.");
        pumpError = true;
        masterResetAll(); // Shut down entire system to protect hardware
        Blynk.logEvent("pump_error", "Dry Run Detected! Pump and Valves shut down.");
        return; 
      }
    }

    // 4. The 2-Minute Unified Cycle Cap (120,000ms)
    if (runTime >= 120000) {
      masterResetAll();
    }
  }
}

/* --- Fetch Cloud Data --- */
void syncCloudData() {
  Blynk.syncVirtual(V3, V4, V7, V8, V17); 
  Blynk.syncVirtual(V0, V5, V6, V9, V10); 
}

