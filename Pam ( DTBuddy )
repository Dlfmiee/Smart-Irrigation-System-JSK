/* --- Pins --- */
const int relayPin = 26;   // ACTIVE-LOW
const int ledPin   = 27;   

/* --- State Variables --- */
bool pumpState = false;
bool manualOverride = false;
bool pumpError = false;      
unsigned long pumpStartTime = 0;

// Valve States
bool v3_open = false, v4_open = false; // Valve C & D (V3, V4)
bool v5_open = false, v6_open = false; // Valve A & B (V5, V6)
bool rainLockout = false;              // Global Rain (V12)

// Flow Rates 
float flowE = 0;

BlynkTimer timer;

void turnPumpON() {
  if (pumpState) return;
  digitalWrite(relayPin, LOW); 
  pumpState = true;
  pumpStartTime = millis();
  Blynk.virtualWrite(V11, 1);
  Serial.println("PUMP ON: Starting Master Cycle Phase.");
}

void turnPumpOFF() {
  if (!pumpState) return;
  digitalWrite(relayPin, HIGH); 
  pumpState = false;
  Blynk.virtualWrite(V11, 0);
  Serial.println("PUMP OFF");
}

void masterResetAll() {
  // Master Controller enforces Default Mode (All Closed)
  turnPumpOFF();
  Blynk.virtualWrite(V3, 0); v3_open = false;
  Blynk.virtualWrite(V4, 0); v4_open = false;
  Blynk.virtualWrite(V5, 0); v5_open = false;
  Blynk.virtualWrite(V6, 0); v6_open = false;
  Serial.println("MASTER: 120s Cycle Finished. System returned to Default State.");
}

/* --- Core Smart Pump Logic --- */
void evaluatePumpState() {

  // We only care if an OUTLET valve is open (B or D) to run the pump 
  // (Inlet valves A and C don't strictly require the pump to open)
  bool anyOutletOpen = (v4_open || v6_open);
  
  // 1. Turn ON condition
  if (anyOutletOpen && !rainLockout && !pumpError) {
    turnPumpON();
  }
  
  // 2. Turn OFF conditions
  if (!anyOutletOpen || rainLockout || pumpError) {
    turnPumpOFF();
  }

  if (pumpState && !pumpError) {
    unsigned long runTime = millis() - pumpStartTime;

    // 3. Dry-Run Protection (Flow Verification - 15 Seconds)
    if (runTime > 15000 && runTime < 20000) { // Only check once strictly in this window
      float totalFlow = flowE;
      if (totalFlow < 0.1) {
        Serial.println("DRY RUN DETECTED! No flow after 15s.");
        pumpError = true;
        masterResetAll(); // Shut down entire system to protect hardware
        Blynk.logEvent("pump_error", "Dry Run Detected! Pump and Valves shut down.");
        return; 
      }
    }

    // 4. The 2-Minute Unified Cycle Cap (120,000ms)
    if (runTime >= 120000) {
      masterResetAll();
    }
  }
}

/* --- Fetch Cloud Data --- */
void syncCloudData() {
  Blynk.syncVirtual(V3, V4, V5, V6, V12); 
  Blynk.syncVirtual(V0); 
}

void logToGoogleSheets() {
  if (WiFi.status() == WL_CONNECTED) {
    WiFiClientSecure client;
    client.setInsecure();
    HTTPClient http;

    String statusStr = pumpState ? "PUMP_ON" : "PUMP_OFF";
    if (pumpError) statusStr = "PUMP_ERROR_DRY_RUN";

    String url = String(googleScriptUrl) + "?pump=" + String(pumpState);

    Serial.print("Logging to Google Sheets: ");
    http.begin(client, url);
    http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);
    int httpCode = http.GET();
    
    if (httpCode > 0) {
      Serial.println("OK (" + String(httpCode) + ")");
    } else {
      Serial.println("FAILED (" + http.errorToString(httpCode) + ")");
    }
    http.end();
  }
}

