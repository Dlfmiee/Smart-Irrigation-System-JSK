// ================== WIFI CHECK ==================

void checkWiFi() {
  if (WiFi.status() == WL_CONNECTED) {
    digitalWrite(ledPin, HIGH); // Use ledPin as status
  } else {
    digitalWrite(ledPin, LOW);
    Serial.println("[WIFI] Attempting to reconnect...");
    WiFi.begin(ssid, pass);
  }
}

// ================== SETUP ==================

void setup() {
  Serial.begin(115200);
  delay(500);
  Serial.println("\n\n[STARTUP] Initializing Pump Node (B/D Only)...");
  
  pinMode(relayPin, OUTPUT);
  pinMode(ledPin, OUTPUT);
  
  stopPump();

  Serial.println("[SETUP] Connecting to WiFi: " + String(ssid));
  WiFi.begin(ssid, pass);
  
  int wifiAttempts = 0;
  while (WiFi.status() != WL_CONNECTED && wifiAttempts < 20) {
    delay(500);
    Serial.print(".");
    wifiAttempts++;
  }
  
  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\n✅ WiFi Connected! IP: " + WiFi.localIP().toString());
  } else {
    Serial.println("\n❌ WiFi Connection FAILED!");
  }

  Serial.println("[SETUP] Configuring Blynk...");
  Blynk.config(BLYNK_AUTH_TOKEN);
  
  if (!Blynk.connected()) {
    Serial.println("[SETUP] Connecting to Blynk server...");
    Blynk.connect();
  }

  // Watchdog 5m
  esp_task_wdt_config_t twdt_config = {
    .timeout_ms = 300000, .idle_core_mask = 0, .trigger_panic = true
  };
  esp_task_wdt_reconfigure(&twdt_config);
  // esp_task_wdt_add(NULL); -> Moved to dynamic event in evaluatePumpState()

  timer.setInterval(5000L, evaluatePumpState);      // Balanced evaluation (5s)
  timer.setInterval(10000L, checkWiFi);             // WiFi stabilizer
  timer.setInterval(30000L, fetchRemoteValveStatus); // Independent Pulse Sync (30s)
  timer.setInterval(300000L, logToGoogleSheets);   // Google Sheets Log (5m)

  Serial.println("[SYSTEM] Pump Node Ready (B/D Focused Sync)");
}

void loop() {
  if (Blynk.connected()) {
    Blynk.run();
  } else {
    Blynk.connect();
  }
  timer.run();
  if (wdtActive) esp_task_wdt_reset();
}