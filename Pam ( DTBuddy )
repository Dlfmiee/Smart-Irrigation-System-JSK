void setup() {
  Serial.begin(115200);
  pinMode(relayPin, OUTPUT);
  pinMode(ledPin, OUTPUT);
  digitalWrite(ledPin, HIGH);   
  digitalWrite(relayPin, HIGH); 
  
  Blynk.begin(auth, ssid, pass);

  timer.setInterval(2000L, evaluatePumpState);
  timer.setInterval(10000L, syncCloudData); 
  timer.setInterval(300000L, logToGoogleSheets); // Log every 5 minutes
}

void loop() {
  Blynk.run();
  timer.run();
}