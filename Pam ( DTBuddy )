  Serial.println("📊 [LOG] Sending master log to Google Sheets...");
  WiFiClientSecure client; client.setInsecure();
  HTTPClient http;
  String url = String(googleScriptUrl)
             + "?pump="     + String(pumpRunning ? "1" : "0")
             + "&flowE="    + String(flowE, 3)
             + "&moisture=" + String(moisturePct)
             + "&rainfall=" + String(rainfallMm, 2)
             + "&rain="     + String(rainLockout ? "1" : "0")
             + "&tank="     + String(tankFull)
             + "&ec="       + String(ecValue, 2)
             + "&valveA="   + String(v5_open ? "1" : "0")
             + "&valveB="   + String(v6_open ? "1" : "0")
             + "&valveC="   + String(v3_open ? "1" : "0")
             + "&valveD="   + String(v4_open ? "1" : "0");
  http.begin(client, url);
  int code = http.GET();
  http.end();
  Serial.printf("✅ [LOG] Google Sheets response: %d\n", code);
}

// ================= MASTER FETCH (Gather Data) =================

void fetchRemoteStatus() {
  if (WiFi.status() != WL_CONNECTED) return;
  WiFiClientSecure client; client.setInsecure();
  HTTPClient http;

  // Sync Valves (Only write to Blynk if state changed)
  auto fetchAPI = [&](const char* token, const char* vPin, int& outVar, int bVpin) {
    http.begin(client, "https://blynk.cloud/external/api/get?token=" + String(token) + "&" + vPin);
    if (http.GET() == 200) { 
      int newVal = http.getString().toInt();
      if (newVal != outVar) { 
        outVar = newVal; 
        Blynk.virtualWrite(bVpin, outVar); 
      }
    }
    http.end();
  };
  
  fetchAPI(ALTF4_TOKEN, "V5", v5_open, V5);
  fetchAPI(ALTF4_TOKEN, "V6", v6_open, V6);
  fetchAPI(CYBERSPARK_TOKEN, "V3", v3_open, V3);
  fetchAPI(CYBERSPARK_TOKEN, "V4", v4_open, V4);
  Serial.printf("[SYNC] Valves -> A:%d B:%d C:%d D:%d\n", v5_open, v6_open, v3_open, v4_open);
  
  // Sync Sensors (Only write to Blynk if state changed significant amount)
  auto getFloat = [&](int bVpin, float& outVar, float delta) {
    http.begin(client, "https://blynk.cloud/external/api/get?token=" + String(SENSOR_TOKEN) + "&V" + String(bVpin==V12?12:bVpin==V8?8:bVpin==V7?7:bVpin==V1?1:2));
    if (http.GET() == 200) {
      float newVal = http.getString().toFloat();
      if (abs(newVal - outVar) > delta) {
        outVar = newVal;
        Blynk.virtualWrite(bVpin, outVar);
      }
    }
    http.end();
  };

  auto getInt = [&](int bVpin, int& outVar) {
    http.begin(client, "https://blynk.cloud/external/api/get?token=" + String(SENSOR_TOKEN) + "&V" + String(bVpin==V12?12:bVpin==V7?7:bVpin==V1?1:2));
    if (http.GET() == 200) {
      int newVal = http.getString().toInt();
      if (newVal != outVar) {
        outVar = newVal;
        Blynk.virtualWrite(bVpin, outVar);
      }
    }
    http.end();
  };

  getInt(V12, rainLockout);
  getFloat(V8, rainfallMm, 0.1);
  getInt(V7, moisturePct);
  getInt(V1, tankFull);
  getFloat(V2, ecValue, 0.05);

  static unsigned long lastLogTime = 0;
  if (millis() - lastLogTime > 600000 || demand) { // Log every 10 mins OR when demand is active
    Serial.printf("📊 [SYNC] Valves:%d%d%d%d | Rain:%d | Moist:%d%% | Tank:%d | EC:%.2f\n", 
                  v5_open, v6_open, v3_open, v4_open, rainLockout, moisturePct, tankFull, ecValue);
    lastLogTime = millis();
  }

  evaluatePumpState(); 
}

