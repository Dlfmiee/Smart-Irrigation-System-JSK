// ================= SETUP =================

void setup() {
  Serial.begin(115200);

  pinMode(relayPin, OUTPUT);
  pinMode(ledPin, OUTPUT);
  pinMode(wifiLedPin, OUTPUT);

  stopPump();

  WiFi.begin(ssid, pass);
  int attempt = 0;
  while (WiFi.status() != WL_CONNECTED && attempt < 20) { 
    delay(500); 
    attempt++;
  }

  Blynk.config(BLYNK_AUTH_TOKEN);
  Blynk.connect();

  // Safer Watchdog (30 seconds vs 5 minutes)
  esp_task_wdt_config_t config = {30000, 0, true};
  esp_task_wdt_reconfigure(&config);

  timer.setInterval(10000L, checkWiFi);
  timer.setInterval(15000L, reconnectBlynk); // Timer-based reconnection (safer)
  timer.setInterval(60000L, fetchRemoteValveStatus);
  timer.setInterval(300000L, logToGoogleSheets);
}

void loop() {
  if (Blynk.connected()) Blynk.run();
  timer.run();
  if (wdtActive) esp_task_wdt_reset();
}