/*
  Pump Controller (Pam / DTBuddy) - FINAL STABLE
  Logic: HIGH = RUN, LOW = STOP
  Monitors: Valve A (V5) and Valve D (V4)
  WiFi: Fmz / iiiiiiii
*/

#define BLYNK_TEMPLATE_ID "TMPL67aY-VULb"
#define BLYNK_TEMPLATE_NAME "ESP32 WIFI"
#define BLYNK_PRINT Serial

#include <WiFi.h>
#include <BlynkSimpleEsp32.h>
#include <HTTPClient.h>
#include <WiFiClientSecure.h>
#include <esp_task_wdt.h>

// WiFi Configuration
const char* ssid = "Fmz";
const char* pass = "iiiiiiii";
char auth[] = "MbA2y5hlAv4SpJ7-a-y9CDhSH9d2zfyd";

// --- PIN DEFINITIONS ---
const int relayPin = 26;   // Pump Relay
const int ledPin   = 27;   // Status LED
const int wifiLedPin = 2;  // Built-in WiFi LED

// --- VARIABLES ---
bool pumpRunning = false;
bool pumpError = false;
unsigned long pumpStartTime = 0;
bool v4_open = false; // Valve D
bool v5_open = false; // Valve A
bool rainLockout = false;
float flowE = 0;
int pumpMode = 0; // 0=AUTO, 1=FORCE RUN, 2=FORCE STOP

BlynkTimer timer;

// ================== HELPER ==================

void updateLED() {
  digitalWrite(ledPin, pumpRunning ? HIGH : LOW);
}

// ================== RELAY CONTROL ==================

void allowPump() {
  digitalWrite(relayPin, HIGH); // User preferred HIGH to run
  pumpRunning = true;
  if (pumpStartTime == 0) pumpStartTime = millis();
  Blynk.virtualWrite(V11, 1);
  updateLED();
  Serial.println("[SYSTEM] Pump RUNNING");
}

void stopPump() {
  digitalWrite(relayPin, LOW); // User preferred LOW to stop
  pumpRunning = false;
  pumpStartTime = 0;
  Blynk.virtualWrite(V11, 0);
  updateLED();
  Serial.println("[SYSTEM] Pump STOPPED");
}

// ================== CORE LOGIC ==================

void masterResetAll() {
  stopPump();
  Blynk.virtualWrite(V4, 0); v4_open = false;
  Blynk.virtualWrite(V5, 0); v5_open = false;
  pumpError = false;
  Serial.println("[MASTER] System Reset");
}

void evaluatePumpState() {
  // Only Valve A and Valve D are actually flowing water now
  bool demand = (v5_open || v4_open);

  // 🚨 PRIORITY 1: SAFETY
  if (rainLockout || pumpError || pumpMode == 2) {
    stopPump();
    return;
  }

  // 🚀 PRIORITY 2: FORCE RUN
  if (pumpMode == 1) {
    allowPump();
  }
  // ⚙️ PRIORITY 3: AUTO
  else {
    if (demand) {
      allowPump();
    } else {
      stopPump();
    }
  }

  // ================= SAFETY MONITOR =================
  if (pumpRunning && !pumpError) {
    unsigned long runTime = millis() - pumpStartTime;

    // Dry-run protection (15s window)
    if (runTime > 15000 && runTime < 20000) {
      if (flowE < 0.1) {
        Serial.println("[ERROR] Dry Run! No water flow detected.");
        pumpError = true;
        stopPump();
        Blynk.logEvent("pump_error", "Dry Run Detected!");
      }
    }

    // 30-minute safety cutoff
    if (runTime >= 1800000) {
      Serial.println("[SAFETY] 30 min timeout");
      masterResetAll();
    }
  }
}

// ================== CLOUD ==================

void checkWiFi() {
  if (WiFi.status() == WL_CONNECTED) {
    digitalWrite(wifiLedPin, HIGH);
  } else {
    digitalWrite(wifiLedPin, LOW);
    WiFi.begin(ssid, pass);
    Serial.println("[WIFI] Reconnecting...");
  }
}

void logToGoogleSheets() {
  if (WiFi.status() != WL_CONNECTED) return;
  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;
  String url = String("https://script.google.com/macros/s/AKfycbw6NvqTFViBKepVJR1U8h83tk3qDTgYXf08oPubvSgFoqx4YWgLtQ71HhUk0xqkdrty/exec") + "?pump=" + String(pumpRunning);
  http.begin(client, url);
  http.GET();
  http.end();
}

// ================== BLYNK ==================

BLYNK_WRITE(V4)  { v4_open = param.asInt(); evaluatePumpState(); }
BLYNK_WRITE(V5)  { v5_open = param.asInt(); evaluatePumpState(); }
BLYNK_WRITE(V12) { rainLockout = param.asInt(); evaluatePumpState(); }
BLYNK_WRITE(V0)  { flowE = param.asFloat(); }
BLYNK_WRITE(V13) { pumpMode = param.asInt(); evaluatePumpState(); }

BLYNK_CONNECTED() {
  Blynk.syncVirtual(V4, V5, V12, V13);
  Serial.println("✅ Pam Connected");
}

// ================== SETUP ==================

void setup() {
  Serial.begin(115200);
  pinMode(relayPin, OUTPUT);
  pinMode(ledPin, OUTPUT);
  pinMode(wifiLedPin, OUTPUT);
  
  stopPump(); // Start with pump OFF
  
  WiFi.begin(ssid, pass);
  Blynk.config(auth);
  
  esp_task_wdt_config_t twdt_config = {
    .timeout_ms = 30000, .idle_core_mask = 0, .trigger_panic = true
  };
  esp_task_wdt_init(&twdt_config);
  esp_task_wdt_add(NULL);

  timer.setInterval(1000L, evaluatePumpState);
  timer.setInterval(10000L, checkWiFi);
  timer.setInterval(300000L, logToGoogleSheets);

  Serial.println("[SYSTEM] Pump Node Ready (3-Wire Sync Mode)");
}

void loop() {
  Blynk.run();
  timer.run();
  esp_task_wdt_reset();
}