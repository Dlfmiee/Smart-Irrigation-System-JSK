const int wifiLedPin = 21; // Assuming GPIO 21 for LED from user snippets previously, but we'll stick to GPIO 2 if available. 
                          // Actually, user's snippet used wifiLedPin which wasn't defined. I'll define it as 2.

// State Variables
bool pumpRunning = false;
bool pumpError = false;
unsigned long pumpStartTime = 0;
bool lastPumpRunning = false; // Prevents Blynk message spam

bool v3_open = false; // Valve C (Cyberspark) - Monitored but not triggering pump
bool v4_open = false; // Valve D (Cyberspark) - TRIGGER
bool v5_open = false; // Valve A (ALTF4) - Monitored but not triggering pump
bool v6_open = false; // Valve B (ALTF4) - TRIGGER
bool rainLockout = false;
float flowE = 0;
int pumpMode = 0; // 0=AUTO, 1=FORCE RUN, 2=FORCE STOP

BlynkTimer timer;

// ================== PUMP CONTROL ==================

void startPump() {
  if (pumpRunning || pumpError) return;
  digitalWrite(relayPin, HIGH); // Active HIGH
  pumpRunning = true;
  pumpStartTime = millis();
  Blynk.virtualWrite(V1, 1);
  Blynk.virtualWrite(V11, 1); // Status Indicator
  Serial.println("💦 PUMP STARTED");
}

void stopPump() {
  if (!pumpRunning) return;
  digitalWrite(relayPin, LOW);
  pumpRunning = false;
  Blynk.virtualWrite(V1, 0);
  Blynk.virtualWrite(V11, 0); // Status Indicator
  Serial.println("❌ PUMP STOPPED");
}

void masterResetAll() {
  stopPump();
  Blynk.virtualWrite(V3, 0); v3_open = false;
  Blynk.virtualWrite(V4, 0); v4_open = false;
  Blynk.virtualWrite(V5, 0); v5_open = false;
  Blynk.virtualWrite(V6, 0); v6_open = false;
  pumpError = false;
  Blynk.virtualWrite(V2, 0);
  Serial.println("[MASTER] System Reset");
}

bool wdtActive = false;

void evaluatePumpState() {
  // Update indicator only on change to save Blynk messages
  if (pumpRunning != lastPumpRunning) {
    Blynk.virtualWrite(V11, pumpRunning ? 1 : 0);
    lastPumpRunning = pumpRunning;
  }

  // Check ONLY B and D are open (as requested)
  bool demand = (v4_open || v6_open);

  // 🚨 PRIORITY 1: SAFETY
  if (rainLockout || pumpError || pumpMode == 2) {
    if (pumpRunning) stopPump();
    return;
  }

  // 💡 PRIORITY 2: FORCE RUN
  if (pumpMode == 1) {
    if (!pumpRunning) startPump();
    return;
  }

  // 📅 PRIORITY 3: AUTO
  if (demand) {
    if (!pumpRunning) startPump();
  } else {
    if (pumpRunning) stopPump();
  }

  // --- DYNAMIC WATCHDOG LOGIC ---
  if (pumpRunning && !wdtActive) {
    esp_task_wdt_add(NULL);
    wdtActive = true;
    Serial.println("🛡️ [WATCHDOG] Armed during Pump Operation.");
  } else if (!pumpRunning && wdtActive) {
    esp_task_wdt_delete(NULL);
    wdtActive = false;
    Serial.println("🔓 [WATCHDOG] Disarmed (Idle Mode).");
  }
}

// ================== LOGGING & SYNC ==================

void logToGoogleSheets() {
  if (WiFi.status() != WL_CONNECTED) return;
  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;
  String url = String(googleScriptUrl) + "?pump=" + String(pumpRunning);
  
  Serial.print("[LOG] Sheets Syncing Status... ");
  http.begin(client, url);
  int httpCode = http.GET();
  Serial.println(httpCode > 0 ? "SUCCESS" : "FAILED");
  http.end();
}

// CONTINUOUS STATUS SYNC (PULSE) 
void fetchRemoteValveStatus() {
  if (WiFi.status() != WL_CONNECTED) return;
  
  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;

  // 1. Check ALTF4 (Valve A & B)
  String urlA = "https://blynk.cloud/external/api/get?token=" + String(ALTF4_TOKEN) + "&V5";
  http.begin(client, urlA);
  if (http.GET() > 0) v5_open = (http.getString().toInt() == 1);
  http.end();

String urlB = "https://blynk.cloud/external/api/get?token=" + String(ALTF4_TOKEN) + "&V6";
  http.begin(client, urlB);
  if (http.GET() > 0) v6_open = (http.getString().toInt() == 1);
  http.end();

  // 2. Check Cyberspark (Valve C & D)
  String urlC = "https://blynk.cloud/external/api/get?token=" + String(CYBERSPARK_TOKEN) + "&V3";
  http.begin(client, urlC);
  if (http.GET() > 0) v3_open = (http.getString().toInt() == 1);
  http.end();

  String urlD = "https://blynk.cloud/external/api/get?token=" + String(CYBERSPARK_TOKEN) + "&V4";
  http.begin(client, urlD);
  if (http.GET() > 0) v4_open = (http.getString().toInt() == 1);
  http.end();

  Serial.print("[SYNC] A:"); Serial.print(v5_open);
  Serial.print(" B:"); Serial.print(v6_open);
  Serial.print(" C:"); Serial.print(v3_open);
  Serial.print(" D:"); Serial.println(v4_open);
}

