void setup() {
  Serial.begin(115200);
  pinMode(relayPin, OUTPUT); pinMode(ledPin, OUTPUT); pinMode(wifiLedPin, OUTPUT);
  digitalWrite(relayPin, HIGH); // Ensure relay is OFF (Active-LOW) on boot
  stopPump();

  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, pass);
  Blynk.config(BLYNK_AUTH_TOKEN);
  Blynk.connect();

  esp_task_wdt_config_t config = {30000, 0, true};
  esp_task_wdt_reconfigure(&config);

  timer.setInterval(10000L, checkWiFi);
  timer.setInterval(15000L, reconnectBlynk);
  timer.setInterval(300000L, fetchRemoteStatus); 
  timer.setInterval(300000L, logToGoogleSheets); 
}

void loop() {
  if (Blynk.connected()) Blynk.run();
  timer.run();
  if (wdtActive) esp_task_wdt_reset();
}
