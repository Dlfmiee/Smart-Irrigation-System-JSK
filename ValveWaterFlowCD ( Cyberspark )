#define VPIN_VALVE_D V4

// --- VARIABLES ---
BlynkTimer timer;
int lastOpenHour  = -1;
int lastCloseHour = -1;

// Staging Variables (Pre-Check via HTTP Fetch)
int envMoisture = 0;      
bool envRain = false;     
float envFlow = 0;        
bool envConditionOK = false;
bool leakDetected = false;
int lastCheckHour = -1;
int lastLeakCheckHour = -1;

// ================== BRIDGE ==================

void shoutToMasterPump(int vPin, int value) {
  if (WiFi.status() != WL_CONNECTED) return;
  
  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;
  
  String url = "https://blynk.cloud/external/api/update?token=" + 
               String(MASTER_PUMP_TOKEN) + "&v" + String(vPin) + "=" + String(value);
  
  Serial.print("[BRIDGE] Syncing V" + String(vPin) + " to Pump -> ");
  Serial.println(value);
  
  http.begin(client, url);
  int httpCode = http.GET();
  if (httpCode > 0) Serial.println("[BRIDGE] Success");
  else Serial.println("[BRIDGE] Failed: " + http.errorToString(httpCode));
  http.end();
}

// Fetch Environmental Data from Master Token
void fetchGlobalData() {
  if (WiFi.status() != WL_CONNECTED) return;
  
  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;
  
  String urlV7 = "https://blynk.cloud/external/api/get?token=" + String(MASTER_PUMP_TOKEN) + "&V7";
  http.begin(client, urlV7);
  if (http.GET() > 0) envMoisture = http.getString().toInt();
  http.end();
  
  String urlV12 = "https://blynk.cloud/external/api/get?token=" + String(MASTER_PUMP_TOKEN) + "&V12";
  http.begin(client, urlV12);
  if (http.GET() > 0) envRain = (http.getString().toInt() == 1);
  http.end();
  
  String urlV0 = "https://blynk.cloud/external/api/get?token=" + String(MASTER_PUMP_TOKEN) + "&V0";
  http.begin(client, urlV0);
  if (http.GET() > 0) envFlow = http.getString().toFloat();
  http.end();
  
  Serial.print("[FETCH] M: "); Serial.print(envMoisture);
  Serial.print(" | R: "); Serial.print(envRain);
  Serial.print(" | F: "); Serial.println(envFlow);
}

// ================== VALVE CONTROL ==================

void openValveC() {
  digitalWrite(RELAY_C_PIN, HIGH);
  Blynk.virtualWrite(VPIN_VALVE_C, 1);
  shoutToMasterPump(3, 1);
  Serial.println("[C] Valve C OPEN");
}

void closeValveC() {
  digitalWrite(RELAY_C_PIN, LOW);
  Blynk.virtualWrite(VPIN_VALVE_C, 0);
  shoutToMasterPump(3, 0);
  Serial.println("[C] Valve C CLOSED");
}

void openValveD() {
  digitalWrite(RELAY_D_PIN, HIGH);
  Blynk.virtualWrite(VPIN_VALVE_D, 1);
  shoutToMasterPump(4, 1);
  Serial.println("[D] Valve D OPEN");
}

void closeValveD() {
  digitalWrite(RELAY_D_PIN, LOW);
  Blynk.virtualWrite(VPIN_VALVE_D, 0);
  shoutToMasterPump(4, 0);
  Serial.println("[D] Valve D CLOSED");
}

// ================== BLYNK HANDLERS ==================

BLYNK_WRITE(VPIN_VALVE_C) {
  int val = param.asInt();
  Serial.print("[BLYNK] V3 received: "); Serial.println(val);
  if (val == 1) openValveC();
  else          closeValveC();
}

BLYNK_WRITE(VPIN_VALVE_D) {
  int val = param.asInt();
  Serial.print("[BLYNK] V4 received: "); Serial.println(val);
  if (val == 1) openValveD();
  else          closeValveD();
}

BLYNK_CONNECTED() {
  Serial.println("[BLYNK] Connected! Syncing virtual pins...");
  Blynk.syncVirtual(VPIN_VALVE_C, VPIN_VALVE_D);
  Serial.println("✅ Cyberspark Connected & Synced (Optimized)");
}

// ================== SCHEDULE ==================

bool wdtActive = false;

void checkSchedule() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return;

  int hour = timeinfo.tm_hour;
  int minute = timeinfo.tm_min;

  // --- WINDOWED WATCHDOG LOGIC ---
  // Window: 15:57 (3m before) to 16:33 (3m after)
  bool inWindow = ( (hour == 15 && minute >= 57) || 
                    (hour == 16 && minute <= 33) );
  
  if (inWindow && !wdtActive) {
    esp_task_wdt_add(NULL);
    wdtActive = true;
    Serial.println("🛡️ [WATCHDOG] Armed for Irrigation Window.");
  } else if (!inWindow && wdtActive) {
    esp_task_wdt_delete(NULL);
    wdtActive = false;
    Serial.println("🔓 [WATCHDOG] Disarmed (Idle Mode).");
  }

  // 1. T-27 Mins (15:33): Fetch Environment Data
  if (hour == 15 && minute == 33 && lastCheckHour != hour) {
    Serial.println("📢 T-30 [Cyberspark]: Fetching Sensor Data...");
    fetchGlobalData();
    lastCheckHour = hour;
    if (envRain) {
      envConditionOK = false;
      Serial.println("⚠️ Pre-check FAIL: Rain Lockout active.");
    } else if (envMoisture >= 80) {
      envConditionOK = false;
      Serial.println("⚠️ Pre-check FAIL: Soil is too wet.");
    } else {
      envConditionOK = true;
      Serial.println("✅ Pre-check PASS: Conditions OK.");
    }
  }

  // 2. T-30 Secs (15:59): Fetch Flow for Leak Check
  if (hour == 15 && minute == 59 && lastLeakCheckHour != hour) {
    Serial.println("📢 T-30s [Cyberspark]: Fetching Flow for Leak Check...");
    fetchGlobalData(); // refresh
    lastLeakCheckHour = hour;
    if (envFlow > 0.05) {
      leakDetected = true;
      Serial.println("🚨 Leak Check FAIL: Flow detected before opening!");
    } else {
      leakDetected = false;
      Serial.println("✅ Leak Check PASS: No flow detected.");
    }
  }

  // 3. 04:00 PM (16:00) - Process Execution
  if (hour == 16 && minute == 0 && lastOpenHour != hour) {
    lastOpenHour = hour;
    if (envConditionOK && !leakDetected) {
      Serial.println("⏰ Schedule: 16:00 - STARTING (Staggered)");
      openValveC();
      timer.setTimeout(7000L, openValveD);
    } else {
      String reason = leakDetected ? "LEAK" : (envRain ? "RAIN" : "WET SOIL");
      Serial.print("🚫 Schedule: 16:00 - SKIPPED. Reason: ");
      Serial.println(reason);
    }
  }

  // 4. 04:30 PM (16:30) - Close staggered
  if (hour == 16 && minute == 30 && lastCloseHour != hour) {
    Serial.println("⏰ Schedule: 16:30 - Closing Valve C (D follows in 7s)");
    closeValveC();
    timer.setTimeout(7000L, closeValveD);
    lastCloseHour = hour;
  }
}

// ================== WIFI CHECK ==================

void checkWiFi() {
  if (WiFi.status() == WL_CONNECTED) {
    digitalWrite(WIFI_LED_PIN, HIGH);
  } else {
    digitalWrite(WIFI_LED_PIN, LOW);
    Serial.println("[WIFI] Attempting to reconnect...");
    WiFi.begin(ssid, pass);
  }
}

// ================== SETUP ==================

void setup() {
  Serial.begin(115200);
  delay(500);
  Serial.println("\n\n[STARTUP] Initializing Cyberspark (Valve CD)...");

  pinMode(RELAY_C_PIN, OUTPUT);
  pinMode(RELAY_D_PIN, OUTPUT);
  pinMode(WIFI_LED_PIN, OUTPUT);

  // Safe default
  digitalWrite(RELAY_C_PIN, LOW);
  digitalWrite(RELAY_D_PIN, LOW);
  digitalWrite(WIFI_LED_PIN, LOW);

  Serial.println("[SETUP] Connecting to WiFi: " + String(ssid));
  WiFi.begin(ssid, pass);
  
  // Robust WiFi Wait
  int wifiAttempts = 0;
  while (WiFi.status() != WL_CONNECTED && wifiAttempts < 20) {
    delay(500);
    Serial.print(".");
    wifiAttempts++;
  }
  
  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\n✅ WiFi Connected! IP: " + WiFi.localIP().toString());
  } else {
    Serial.println("\n❌ WiFi Connection FAILED!");
  }

  Serial.println("[SETUP] Configuring Blynk...");
  Blynk.config(BLYNK_AUTH_TOKEN);
  
  if (!Blynk.connected()) {
    Serial.println("[SETUP] Connecting to Blynk server...");
    Blynk.connect();
  }

  configTime(28800, 0, "pool.ntp.org", "time.nist.gov");

  // Watchdog 5m
  esp_task_wdt_config_t twdt_config = {
    .timeout_ms = 300000, .idle_core_mask = 0, .trigger_panic = true
  };
  esp_task_wdt_reconfigure(&twdt_config);
  // esp_task_wdt_add(NULL); -> Moved to dynamic window in checkSchedule()

  timer.setInterval(10000L, checkWiFi);
  timer.setInterval(60000L, checkSchedule);

  Serial.println("[SYSTEM] Cyberspark Ready (Independent Sync Mode)");
}

void loop() {
  if (Blynk.connected()) {
    Blynk.run();
  } else {
    static unsigned long lastReconnect = 0;
    if (millis() - lastReconnect > 30000) {
      Serial.println("🔄 [BLYNK] Attempting stabilized reconnect...");
      Blynk.connect();
      lastReconnect = millis();
    }
  }
  timer.run();
  if (wdtActive) esp_task_wdt_reset();
}