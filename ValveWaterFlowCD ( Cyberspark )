/*
 Valve CD Controller (Cyberspark) - UPDATED
 Logic: 3-Wire Motorized Valve (Valve D ONLY)
 Pins: 26 (Open), 27 (Close)
 Schedule: 04:00 PM - 04:30 PM
 Token: Shared (MbA2y5hl...)
*/

#define BLYNK_TEMPLATE_ID   "TMPL67aY-VULb"
#define BLYNK_TEMPLATE_NAME "ESP32 WIFI"
#define BLYNK_AUTH_TOKEN    "MbA2y5hlAv4SpJ7-a-y9CDhSH9d2zfyd"
#define BLYNK_PRINT Serial

#include <WiFi.h>
#include <BlynkSimpleEsp32.h>
#include <time.h>
#include <esp_task_wdt.h>

// WiFi Configuration
const char* ssid = "Fmz";
const char* pass = "iiiiiiii";
const char* POSIX_TZ = "MYT-8"; 

// --- PIN DEFINITIONS ---
const int RELAY_OPEN_PIN = 26;   // Relay for Open
const int RELAY_CLOSE_PIN = 27;  // Relay for Close
const int WIFI_LED_PIN = 2;      // Status LED

// --- VIRTUAL PINS ---
#define VPIN_VALVE_D V4           // Main Valve Switch for D
#define VPIN_SYSTEM_STATUS V7     // Status Text

// --- VARIABLES ---
BlynkTimer timer;
bool valveD_Open = false;
int lastOpenHour = -1;
int lastCloseHour = -1;

// ================== VALVE ACTIONS ==================

void stopValve() {
  digitalWrite(RELAY_OPEN_PIN, HIGH); // Relays OFF (Active Low)
  digitalWrite(RELAY_CLOSE_PIN, HIGH);
  Serial.println("Motor: STOP");
}

void openValveD() {
  digitalWrite(RELAY_CLOSE_PIN, HIGH); // Ensure Close is OFF
  delay(100);
  digitalWrite(RELAY_OPEN_PIN, LOW); // Trigger OPEN
  valveD_Open = true;
  Blynk.virtualWrite(VPIN_VALVE_D, 1);
  Serial.println("Action: OPEN Valve D (3-Wire)");
}

void closeValveD() {
  digitalWrite(RELAY_OPEN_PIN, HIGH); // Ensure Open is OFF
  delay(100);
  digitalWrite(RELAY_CLOSE_PIN, LOW); // Trigger CLOSE
  valveD_Open = false;
  Blynk.virtualWrite(VPIN_VALVE_D, 0);
  Serial.println("Action: CLOSE Valve D (3-Wire)");
}

// ================== HANDLERS ==================

BLYNK_WRITE(VPIN_VALVE_D) {
  if (param.asInt()) openValveD();
  else closeValveD();
}

BLYNK_CONNECTED() {
  Blynk.syncVirtual(VPIN_VALVE_D);
  Serial.println("✅ Cyberspark Connected to Blynk");
}

// ================== LOGIC ==================

void checkWiFi() {
  if (WiFi.status() == WL_CONNECTED) {
    digitalWrite(WIFI_LED_PIN, HIGH);
  } else {
    digitalWrite(WIFI_LED_PIN, LOW);
    WiFi.begin(ssid, pass);
  }
}

void checkSchedule() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return;

  int hour = timeinfo.tm_hour;
  int minute = timeinfo.tm_min;
  int day = timeinfo.tm_mday;

  // 04:00 PM (16:00) - START
  if (hour == 16 && minute == 0 && lastOpenHour != hour) {
    openValveD();
    lastOpenHour = hour;
  }

  // 04:30 PM (16:30) - STOP
  if (hour == 16 && minute == 30 && lastCloseHour != hour) {
    closeValveD();
    lastCloseHour = hour;
  }
}

void setup() {
  Serial.begin(115200);
  
  pinMode(RELAY_OPEN_PIN, OUTPUT);
  pinMode(RELAY_CLOSE_PIN, OUTPUT);
  pinMode(WIFI_LED_PIN, OUTPUT);
  
  // Default: OFF
  digitalWrite(RELAY_OPEN_PIN, HIGH);
  digitalWrite(RELAY_CLOSE_PIN, HIGH);
  digitalWrite(WIFI_LED_PIN, LOW);

  // Connection
  WiFi.begin(ssid, pass);
  Blynk.config(BLYNK_AUTH_TOKEN);
  configTime(28800, 0, "pool.ntp.org", "time.nist.gov");

  // Watchdog
  esp_task_wdt_config_t twdt_config = {
    .timeout_ms = 30000, .idle_core_mask = 0, .trigger_panic = true
  };
  esp_task_wdt_init(&twdt_config);
  esp_task_wdt_add(NULL);

  timer.setInterval(10000L, checkWiFi);
  timer.setInterval(60000L, checkSchedule);
  
  Serial.println("🚀 Cyberspark READY (3-Wire Valve D)");
}

void loop() {
  Blynk.run();
  timer.run();
  esp_task_wdt_reset();
}