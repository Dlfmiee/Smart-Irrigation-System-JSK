#define RELAY_C_PIN 26    // Valve C (Inlet - Water)
#define RELAY_D_PIN 27    // Valve D (Outlet - Water)
#define FLOW_SENSOR_C_PIN 13  
#define FLOW_SENSOR_D_PIN 14  

volatile int pulseCountC = 0;
volatile int pulseCountD = 0;
float flowRateC = 0.0;
float flowRateD = 0.0;
unsigned long oldTimeC = 0;
unsigned long oldTimeD = 0;

const float calibrationFactor = 450.0; 
BlynkTimer timer;

bool rainLockout = false;
int lastTriggerHour = -1;

// Motorized Valve Timing
unsigned long valveCTimer = 0;
bool valveCHalfOpening = false;

void IRAM_ATTR pulseCounterC() { pulseCountC++; }
void IRAM_ATTR pulseCounterD() { pulseCountD++; }

void calculateFlow() {
  unsigned long currentTime = millis();
  if ((currentTime - oldTimeC) >= 1000) {
    flowRateC = ((1000.0 / (millis() - oldTimeC)) * pulseCountC) / (calibrationFactor / 60.0);
    oldTimeC = millis(); pulseCountC = 0;
    Blynk.virtualWrite(V5, flowRateC);
  }
  if ((currentTime - oldTimeD) >= 1000) {
    flowRateD = ((1000.0 / (millis() - oldTimeD)) * pulseCountD) / (calibrationFactor / 60.0);
    oldTimeD = millis(); pulseCountD = 0;
    Blynk.virtualWrite(V6, flowRateD);
  }
}

void forceCloseAB() {
  Blynk.virtualWrite(V7, 0);
  Blynk.virtualWrite(V8, 0);
}

// VALVE C - INLET (Half-Open Logic)
void openValveC_Half() { 
  digitalWrite(RELAY_C_PIN, LOW); 
  Blynk.virtualWrite(V3, 1); 
  valveCHalfOpening = true;
  valveCTimer = millis();
  Serial.println("Valve C (Inlet) Opening for 5s..."); 
  forceCloseAB();
}
void closeValveC() { 
  digitalWrite(RELAY_C_PIN, HIGH); 
  valveCHalfOpening = false;
  Blynk.virtualWrite(V3, 0); 
  Serial.println("Valve C (Inlet) Command Closed"); 
}

// VALVE D - OUTLET (Full-Open Logic)
void openValveD() { 
  digitalWrite(RELAY_D_PIN, LOW); 
  Blynk.virtualWrite(V4, 1); 
  Serial.println("Valve D (Outlet) Opened Fully"); 
  forceCloseAB();
}
void closeValveD() { 
  digitalWrite(RELAY_D_PIN, HIGH); 
  Blynk.virtualWrite(V4, 0); 
  Serial.println("Valve D (Outlet) Command Closed"); 
}

void processMotorTiming() {
  // Pause Valve C after 5 seconds to achieve "Half-Open"
  if (valveCHalfOpening && (millis() - valveCTimer >= 5000)) {
    digitalWrite(RELAY_C_PIN, HIGH); // Cut power to stop motor half-way
    valveCHalfOpening = false;
    Serial.println("Valve C (Inlet) Paused at Half-Open to reduce pressure.");
  }
}

void checkSchedule() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return;

  int hour = timeinfo.tm_hour;
  bool isWateringHour = (hour == 10 || hour == 12 || hour == 14 || hour == 16);

  if (isWateringHour && timeinfo.tm_min == 0) {
    if (lastTriggerHour != hour) {
      if (!rainLockout) {
        Serial.println("SCHEDULE: Water Sequence (" + String(hour) + ":00)");
        openValveC_Half(); // Inlet Half
        openValveD();      // Outlet Full
      }
      lastTriggerHour = hour;
    }
  }
}

BLYNK_WRITE(V17) { rainLockout = param.asInt() == 1; }
BLYNK_WRITE(V3) { if (param.asInt()) openValveC_Half(); else closeValveC(); }
BLYNK_WRITE(V4) { if (param.asInt()) openValveD(); else closeValveD(); }
BLYNK_CONNECTED() { Blynk.syncVirtual(V17); }

void setup() {
  Serial.begin(115200);
  pinMode(RELAY_C_PIN, OUTPUT);
  pinMode(RELAY_D_PIN, OUTPUT);
  digitalWrite(RELAY_C_PIN, HIGH); 
  digitalWrite(RELAY_D_PIN, HIGH); 
  
  pinMode(FLOW_SENSOR_C_PIN, INPUT_PULLUP);
  pinMode(FLOW_SENSOR_D_PIN, INPUT_PULLUP);
  attachInterrupt(FLOW_SENSOR_C_PIN, pulseCounterC, FALLING);
  attachInterrupt(FLOW_SENSOR_D_PIN, pulseCounterD, FALLING);

  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);
  configTime(28800, 0, "pool.ntp.org", "time.nist.gov");
  
  timer.setInterval(100L, processMotorTiming);
  timer.setInterval(1000L, calculateFlow);
  timer.setInterval(15000L, checkSchedule);
}

void loop() {
  Blynk.run();
  timer.run();
}