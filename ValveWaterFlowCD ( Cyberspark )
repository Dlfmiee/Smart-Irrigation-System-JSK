#define RELAY_D_PIN 27
#define WIFI_LED_PIN 2

// --- VIRTUAL PINS ---
#define VPIN_VALVE_C V3
#define VPIN_VALVE_D V4

// --- CONSTANTS ---
const unsigned long MAX_VALVE_ON_TIME = 2100000; // 35 minutes Fail-Safe

// --- VARIABLES ---
BlynkTimer timer;
int lastOpenHour  = -1;
int lastCloseHour = -1;
unsigned long valveC_StartTime = 0;
unsigned long valveD_StartTime = 0;
bool ntpSynced = false;
bool wdtActive = false;

// Staging Variables
int envMoisture = 0;      
bool envRain = false;     
float envFlow = 0;        

// ================== SYSTEM UTILS ==================

void syncNTP() {
  configTime(28800, 0, "pool.ntp.org", "time.google.com");
  struct tm t;
  if (getLocalTime(&t, 1000)) { ntpSynced = true; }
}

void checkWiFi() {
  wl_status_t s = WiFi.status();
  if (s == WL_CONNECTED) {
    digitalWrite(WIFI_LED_PIN, HIGH);
    if (!ntpSynced) syncNTP();
  } else if (s == WL_DISCONNECTED || s == WL_NO_SSID_AVAIL || s == WL_CONNECT_FAILED) {
    digitalWrite(WIFI_LED_PIN, LOW);
    ntpSynced = false;
    WiFi.begin(ssid, pass); 
  }
}

// ================== BRIDGE ==================

void shoutToMasterPump(int vPin, int value) {
  if (WiFi.status() != WL_CONNECTED) return;
  WiFiClientSecure client; client.setInsecure();
  HTTPClient http;
  String url = "https://blynk.cloud/external/api/update?token=" + String(MASTER_PUMP_TOKEN) + "&v" + String(vPin) + "=" + String(value);
  http.begin(client, url);
  if (http.GET() > 0) Serial.printf("📡 [BRIDGE] Hubungi Master: V%d = %d\n", vPin, value);
  http.end();
}

void fetchGlobalData() {
  if (WiFi.status() != WL_CONNECTED) return;
  WiFiClientSecure client; client.setInsecure();
  HTTPClient http;
  
  auto getAPI = [&](const char* vPin) -> String {
    http.begin(client, "https://blynk.cloud/external/api/get?token=" + String(SENSOR_TOKEN) + "&" + vPin);
    String res = (http.GET() > 0) ? http.getString() : "";
    http.end();
    return res;
  };
  
  envMoisture = getAPI("V7").toInt();
  envRain = (getAPI("V12").toInt() == 1);
  envFlow = getAPI("V0").toFloat();
}

// ================== VALVE CONTROL ==================

void openValveC() {
  digitalWrite(RELAY_C_PIN, HIGH); 
  Blynk.virtualWrite(VPIN_VALVE_C, 1);
  shoutToMasterPump(3, 1);
  valveC_StartTime = millis(); 
  Serial.println("[C] Valve C OPEN (Fail-Safe Armed)");
}

void closeValveC() {
  digitalWrite(RELAY_C_PIN, LOW); 
  Blynk.virtualWrite(VPIN_VALVE_C, 0);
  shoutToMasterPump(3, 0);
  valveC_StartTime = 0;
}

void openValveD() {
  digitalWrite(RELAY_D_PIN, HIGH); 
  Blynk.virtualWrite(VPIN_VALVE_D, 1);
  shoutToMasterPump(4, 1);
  valveD_StartTime = millis();
}

void closeValveD() {
  digitalWrite(RELAY_D_PIN, LOW); 
  Blynk.virtualWrite(VPIN_VALVE_D, 0);
  shoutToMasterPump(4, 0);
  valveD_StartTime = 0;
}

void checkFailSafe() {
  unsigned long now = millis();
  if (valveC_StartTime > 0 && (now - valveC_StartTime > MAX_VALVE_ON_TIME)) {
    Serial.println("🚨 [FAIL-SAFE] Valve C force closed (35m limit)"); closeValveC();
  }
  if (valveD_StartTime > 0 && (now - valveD_StartTime > MAX_VALVE_ON_TIME)) {
    Serial.println("🚨 [FAIL-SAFE] Valve D force closed (35m limit)"); closeValveD();
  }
}

// ================== HANDLERS ==================

BLYNK_WRITE(VPIN_VALVE_C) { if (param.asInt()==1) openValveC(); else closeValveC(); }
BLYNK_WRITE(VPIN_VALVE_D) { if (param.asInt()==1) openValveD(); else closeValveD(); }

BLYNK_CONNECTED() { Blynk.syncVirtual(VPIN_VALVE_C, VPIN_VALVE_D); }

void checkSchedule() {
  struct tm ti; if (!getLocalTime(&ti)) return;
  int h = ti.tm_hour; int m = ti.tm_min;

  bool inWindow = ( (h == 15 && m >= 57) || (h == 16 && m <= 33) );
  if (inWindow && !wdtActive) { esp_task_wdt_add(NULL); wdtActive = true; }
  else if (!inWindow && wdtActive) { esp_task_wdt_delete(NULL); wdtActive = false; }

  // 04:00 PM Open (16:00)
  if (h == 16 && (m >= 0 && m <= 5) && lastOpenHour != h) {
    lastOpenHour = h; fetchGlobalData();
    if (envRain || envMoisture >= 80 || envFlow > 0.05) {
      Serial.println("🚫 Schedule: Skipped");
    } else {
      openValveC(); timer.setTimeout(7000L, openValveD);
    }
  }

  // 04:30 PM Close (16:30)
  if (h == 16 && m == 30 && lastCloseHour != h) {
    closeValveC(); timer.setTimeout(7000L, closeValveD); lastCloseHour = h;
  }
}

void setup() {
  Serial.begin(115200);
  pinMode(RELAY_C_PIN, OUTPUT); pinMode(RELAY_D_PIN, OUTPUT); pinMode(WIFI_LED_PIN, OUTPUT);
  digitalWrite(RELAY_C_PIN, LOW); digitalWrite(RELAY_D_PIN, LOW);

  WiFi.mode(WIFI_STA); WiFi.begin(ssid, pass);
  Blynk.config(BLYNK_AUTH_TOKEN); Blynk.connect();

  esp_task_wdt_config_t twdt_config = { .timeout_ms = 300000, .idle_core_mask = 0, .trigger_panic = true };
  esp_task_wdt_reconfigure(&twdt_config);

  timer.setInterval(10000L, checkWiFi);
  timer.setInterval(60000L, checkSchedule);
  timer.setInterval(30000L, checkFailSafe);
}

void loop() {
  if (Blynk.connected()) Blynk.run();
  timer.run();
  if (wdtActive) esp_task_wdt_reset();
}