void logToGoogleSheets() {
  if (WiFi.status() == WL_CONNECTED) {
    WiFiClientSecure client;
    client.setInsecure();
    HTTPClient http;

    // Read relay state. LOW means motor is powered (or was powered). 
    // This is an approximation as motorized valves keep state.
    int valveC_on = !digitalRead(RELAY_C_PIN) || valveCHalfOpening;
    int valveD_on = !digitalRead(RELAY_D_PIN);

    String statusStr = "VALVE_C:" + String(valveC_on) + "_D:" + String(valveD_on);

    String url = String(googleScriptUrl) + "?valveC=" + String(valveC_on) + "&valveD=" + String(valveD_on);

    Serial.print("Logging to Google Sheets: ");
    http.begin(client, url);
    http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);
    int httpCode = http.GET();
    
    if (httpCode > 0) {
      Serial.println("OK (" + String(httpCode) + ")");
    } else {
      Serial.println("FAILED (" + http.errorToString(httpCode).c_str() + ")");
    }
    http.end();
  }
}

void setup() {
  Serial.begin(115200);
  pinMode(RELAY_C_PIN, OUTPUT);
  pinMode(RELAY_D_PIN, OUTPUT);
  digitalWrite(RELAY_C_PIN, HIGH); 
  digitalWrite(RELAY_D_PIN, HIGH); 
  


  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);
  configTime(28800, 0, "pool.ntp.org", "time.nist.gov");
  
  timer.setInterval(100L, processMotorTiming);
  timer.setInterval(15000L, checkSchedule);
  timer.setInterval(300000L, logToGoogleSheets); // Log every 5 minutes
}

void loop() {
  Blynk.run();
  timer.run();
}