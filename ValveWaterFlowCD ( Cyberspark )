/*
 Valve CD Controller (Cyberspark)
 V3 = Valve C (Pin 26) - Independent
 V4 = Valve D (Pin 27) - Independent
 Schedule: 04:00 PM Open, 04:30 PM Close
*/

#define BLYNK_TEMPLATE_ID   "TMPL67aY-VULb"
#define BLYNK_TEMPLATE_NAME "ESP32 WIFI"
#define BLYNK_AUTH_TOKEN    "MbA2y5hlAv4SpJ7-a-y9CDhSH9d2zfyd"
#define BLYNK_PRINT Serial

#include <WiFi.h>
#include <BlynkSimpleEsp32.h>
#include <time.h>
#include <esp_task_wdt.h>

// WiFi
const char* ssid = "Fmz";
const char* pass = "iiiiiiii";

// --- PIN DEFINITIONS ---
#define RELAY_C_PIN 26   // Valve C
#define RELAY_D_PIN 27   // Valve D
#define WIFI_LED_PIN 2   // Built-in Status LED

// --- VIRTUAL PINS ---
#define VPIN_VALVE_C V3
#define VPIN_VALVE_D V4

// --- VARIABLES ---
BlynkTimer timer;
int lastOpenHour  = -1;
int lastCloseHour = -1;

// ================== FORCE CLOSE ==================
void forceCloseAB() {
  Blynk.virtualWrite(V5, 0);
  Blynk.virtualWrite(V6, 0);
}

// ================== VALVE C ==================

void openValveC() {
  digitalWrite(RELAY_C_PIN, LOW);
  Blynk.virtualWrite(VPIN_VALVE_C, 1);
  Serial.println("[C] Valve C OPEN");
  forceCloseAB();
}

void closeValveC() {
  digitalWrite(RELAY_C_PIN, HIGH);
  Blynk.virtualWrite(VPIN_VALVE_C, 0);
  Serial.println("[C] Valve C CLOSED");
}

// ================== VALVE D ==================

void openValveD() {
  digitalWrite(RELAY_D_PIN, LOW);
  Blynk.virtualWrite(VPIN_VALVE_D, 1);
  Serial.println("[D] Valve D OPEN");
  forceCloseAB();
}

void closeValveD() {
  digitalWrite(RELAY_D_PIN, HIGH);
  Blynk.virtualWrite(VPIN_VALVE_D, 0);
  Serial.println("[D] Valve D CLOSED");
}

// ================== BLYNK HANDLERS ==================

BLYNK_WRITE(VPIN_VALVE_C) {
  if (param.asInt() == 1) openValveC();
  else                    closeValveC();
}

BLYNK_WRITE(VPIN_VALVE_D) {
  if (param.asInt() == 1) openValveD();
  else                    closeValveD();
}

BLYNK_CONNECTED() {
  Blynk.syncVirtual(VPIN_VALVE_C, VPIN_VALVE_D);
  Serial.println("✅ Cyberspark Connected");
}

// ================== SCHEDULE ==================

void checkSchedule() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return;

  int hour   = timeinfo.tm_hour;
  int minute = timeinfo.tm_min;

  // 04:00 PM - Open both valves
  if (hour == 16 && minute == 0 && lastOpenHour != hour) {
    Serial.println("⏰ Schedule: 16:00 - Opening C & D");
    openValveC();
    openValveD();
    lastOpenHour = hour;
  }

  // 04:30 PM - Close both valves
  if (hour == 16 && minute == 30 && lastCloseHour != hour) {
    Serial.println("⏰ Schedule: 16:30 - Closing C & D");
    closeValveC();
    closeValveD();
    lastCloseHour = hour;
  }
}

// ================== WIFI CHECK ==================

void checkWiFi() {
  if (WiFi.status() == WL_CONNECTED) {
    digitalWrite(WIFI_LED_PIN, HIGH);
  } else {
    digitalWrite(WIFI_LED_PIN, LOW);
    WiFi.begin(ssid, pass);
    Serial.println("[WiFi] Reconnecting...");
  }
}

// ================== SETUP ==================

void setup() {
  Serial.begin(115200);

  pinMode(RELAY_C_PIN, OUTPUT);
  pinMode(RELAY_D_PIN, OUTPUT);
  pinMode(WIFI_LED_PIN, OUTPUT);

  // Safe default: both valves CLOSED
  digitalWrite(RELAY_C_PIN, HIGH);
  digitalWrite(RELAY_D_PIN, HIGH);
  digitalWrite(WIFI_LED_PIN, LOW);

  WiFi.begin(ssid, pass);
  Blynk.config(BLYNK_AUTH_TOKEN);
  configTime(28800, 0, "pool.ntp.org", "time.nist.gov");

  // Watchdog 30s
  esp_task_wdt_config_t twdt_config = {
    .timeout_ms = 30000, .idle_core_mask = 0, .trigger_panic = true
  };
  esp_task_wdt_init(&twdt_config);
  esp_task_wdt_add(NULL);

  timer.setInterval(10000L, checkWiFi);
  timer.setInterval(60000L, checkSchedule);

  Serial.println("🚀 Cyberspark Ready - Valve C (V3/Pin26) | Valve D (V4/Pin27)");
}

void loop() {
  Blynk.run();
  timer.run();
  esp_task_wdt_reset();
}