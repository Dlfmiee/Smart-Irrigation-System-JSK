#define BLYNK_TEMPLATE_NAME "ESP32 WIFI"
#define BLYNK_AUTH_TOKEN    "MbA2y5hlAv4SpJ7-a-y9CDhSH9d2zfyd"

#include <WiFi.h>
#include <BlynkSimpleEsp32.h>
#include <time.h>

// WiFi credentials
char ssid[] = "SurauAl-Irfan";
char pass[] = "datangsurau";

// Soil sensor pins
#define SENSOR1 34
#define SENSOR2 35
#define SENSOR3 32

// Calibration values
int dryValue = 4095;   // completely dry
int wetValue = 1500;   // completely wet

// Time settings (Malaysia UTC+8)
const char* ntpServer = "pool.ntp.org";
const long gmtOffset_sec = 8 * 3600;
const int daylightOffset_sec = 0;

// To prevent multiple sending
bool sentMorning = false;
bool sentEvening = false;

int readSoilPercent(int pin) {
  int value = analogRead(pin);
  int percent = map(value, dryValue, wetValue, 0, 100);
  percent = constrain(percent, 0, 100);
  return percent;
}

void sendSoilData() {
  int s1 = readSoilPercent(SENSOR1);
  int s2 = readSoilPercent(SENSOR2);
  int s3 = readSoilPercent(SENSOR3);

  int average = (s1 + s2 + s3) / 3;

  Serial.print("Soil Moisture Avg: ");
  Serial.print(average);
  Serial.println("%");

  // Send ONLY average to V0 as requested
  Blynk.virtualWrite(V0, average);
}

void checkTimeAndSend() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) {
    Serial.println("Failed to obtain time");
    return;
  }

  int hour = timeinfo.tm_hour;
  int minute = timeinfo.tm_min;

  // Reset flags at midnight
  if (hour == 0 && minute == 0) {
    sentMorning = false;
    sentEvening = false;
  }

  // 7:30 AM trigger
  if (hour == 7 && minute == 30 && !sentMorning) {
    sendSoilData();
    sentMorning = true;
  }

  // 3:30 PM trigger
  if (hour == 15 && minute == 30 && !sentEvening) {
    sendSoilData();
    sentEvening = true;
  }
}

void setup() {
  Serial.begin(115200);

  pinMode(SENSOR1, INPUT);
  pinMode(SENSOR2, INPUT);
  pinMode(SENSOR3, INPUT);

  WiFi.begin(ssid, pass);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\n✅ WiFi Connected");
  configTime(gmtOffset_sec, daylightOffset_sec, ntpServer);
  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);
}

void loop() {
  Blynk.run();
  checkTimeAndSend();
  delay(1000); // Check every second
}
