#define SOIL1 34
#define SOIL2 35
#define SOIL3 32

int convertToPercentage(int value) {
  int percent = map(value, 0, 4095, 0, 100);
  if (percent > 100) percent = 100;
  if (percent < 0) percent = 0;
  return percent;
}

BlynkTimer timer;
bool ntpSynced = false;
bool wdtActive = false;

void updateBlynkSilent(String vPin, String value) {
  if (WiFi.status() != WL_CONNECTED) return;
  WiFiClientSecure client; client.setInsecure();
  HTTPClient http;
  String url = "https://blynk.cloud/external/api/update?token=" + String(BLYNK_AUTH_TOKEN) + "&" + vPin + "=" + value;
  http.begin(client, url);
  http.GET();
  http.end();
}

void syncNTP() {
  configTime(28800, 0, "pool.ntp.org", "time.google.com");
  struct tm t;
  if (getLocalTime(&t, 1000)) ntpSynced = true;
}

void sendMoistureToBlynk() {
  int avgPercent = (convertToPercentage(analogRead(SOIL1)) + convertToPercentage(analogRead(SOIL2)) + convertToPercentage(analogRead(SOIL3))) / 3;
  updateBlynkSilent("V7", String(avgPercent));
  Serial.println("[SILENT] Moisture sent to V7.");
}

void logToGoogleSheets() {
  if (WiFi.status() != WL_CONNECTED) return;
  int avgPercent = (convertToPercentage(analogRead(SOIL1)) + convertToPercentage(analogRead(SOIL2)) + convertToPercentage(analogRead(SOIL3))) / 3;
  WiFiClientSecure client; client.setInsecure();
  HTTPClient http;
  String url = String(googleScriptUrl) + "?moisture=" + String(avgPercent);
  http.begin(client, url);
  http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);
  http.GET();
  http.end();
}

void checkWiFi() {
  wl_status_t s = WiFi.status();
  if (s == WL_CONNECTED) {
    if (!ntpSynced) syncNTP();
  } else if (s == WL_DISCONNECTED || s == WL_NO_SSID_AVAIL || s == WL_CONNECT_FAILED) {
    ntpSynced = false;
    WiFi.begin(ssid, pass);
  }
}

void scheduledBlynkPublish() {
  time_t now = time(nullptr);
  struct tm* ti = localtime(&now);
  int h = ti->tm_hour; int m = ti->tm_min;

  bool inWindow = ( (h == 7 && m >= 24 && m <= 35) || (h == 15 && m >= 24 && m <= 35) );
  if (inWindow && !wdtActive) { esp_task_wdt_add(NULL); wdtActive = true; }
  else if (!inWindow && wdtActive) { esp_task_wdt_delete(NULL); wdtActive = false; }

  if ( (h == 7 && m == 31) || (h == 15 && m == 31) ) {
    static int lastH = -1;
    if (h != lastH) { lastH = h; sendMoistureToBlynk(); }
  }
}

void setup() {
  Serial.begin(115200);
  WiFi.mode(WIFI_STA); WiFi.begin(ssid, pass);
  Blynk.config(BLYNK_AUTH_TOKEN);

  esp_task_wdt_config_t twdt_config = { .timeout_ms = 300000, .idle_core_mask = 0, .trigger_panic = true };
  esp_task_wdt_reconfigure(&twdt_config);

  timer.setInterval(30000L, checkWiFi);         
  timer.setInterval(60000L, scheduledBlynkPublish);  
  timer.setInterval(900000L, logToGoogleSheets); 
}

void loop() {
  timer.run();
  if (wdtActive) esp_task_wdt_reset();
}