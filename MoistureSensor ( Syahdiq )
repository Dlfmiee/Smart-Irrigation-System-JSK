/************ CONVERT TO % ************/
int convertToPercentage(int value) {
  // Calculate percentage based on 4095 (max ADC value for ESP32)
  int percent = (value * 100) / 4095;

  if (percent > 100) percent = 100;
  if (percent < 0) percent = 0;

  return percent;
}

/************ CHECK IF SHOULD PUBLISH TO BLYNK ************/
bool shouldPublishToBlynk() {
  time_t now = time(nullptr);
  struct tm* timeinfo = localtime(&now);
  
  int hour = timeinfo->tm_hour;
  int minute = timeinfo->tm_min;
  int day = timeinfo->tm_yday;
  
  // Check if it's 7:31 AM or 3:31 PM (15:31)
  bool is7_31 = (hour == 7 && minute >= 31 && minute < 35);
  bool is15_31 = (hour == 15 && minute >= 31 && minute < 35);
  
  // Make sure we only publish once per day at each time
  if ((is7_31 || is15_31) && day != lastPublishDay) {
    lastPublishDay = day;
    return true;
  }
  
  return false;
}

/************ CHECK WIFI AND BLYNK CONNECTION ************/
void checkConnections() {
  // Check WiFi connection
  if (WiFi.status() == WL_CONNECTED) {
    Serial.print("[WiFi] Connected - IP: ");
    Serial.println(WiFi.localIP());
  } else {
    Serial.println("[WiFi] DISCONNECTED");
  }
  
  // Check Blynk connection
  if (Blynk.connected()) {
    Serial.println("[Blynk] Connected ✓");
  } else {
    Serial.println("[Blynk] DISCONNECTED ✗");
  }
}

/************ MONITOR SENSORS ************/
void monitorSensors() {
  int v1 = analogRead(SOIL1);
  int v2 = analogRead(SOIL2);
  int v3 = analogRead(SOIL3);

  int p1 = convertToPercentage(v1);
  int p2 = convertToPercentage(v2);
  int p3 = convertToPercentage(v3);

  Serial.print("[RAW] S1: "); Serial.print(v1);
  Serial.print(" | S2: "); Serial.print(v2);
  Serial.print(" | S3: "); Serial.print(v3);
  Serial.print(" | [%] S1: "); Serial.print(p1);
  Serial.print("% | S2: "); Serial.print(p2);
  Serial.print("% | S3: "); Serial.print(p3);
  Serial.println("%");
}

/************ SCHEDULED BLYNK PUBLISH ************/
void scheduledBlynkPublish() {
  if (shouldPublishToBlynk()) {
    Serial.println("[SCHEDULED] Publishing to Blynk at scheduled time...");
    sendMoistureToBlynk();
  }
}

/************ SEND TO BLYNK ************/
void sendMoistureToBlynk() {
  int v1 = analogRead(SOIL1);
  int v2 = analogRead(SOIL2);
  int v3 = analogRead(SOIL3);

  int p1 = convertToPercentage(v1);
  int p2 = convertToPercentage(v2);
  int p3 = convertToPercentage(v3);

  int avgPercent = (p1 + p2 + p3) / 3;
  int avgRaw = (v1 + v2 + v3) / 3;

  soil1Dry = (v1 > dryThreshold);
  soil2Dry = (v2 > dryThreshold);
  soil3Dry = (v3 > dryThreshold);

  Serial.print("Soil Avg (%): ");
  Serial.print(avgPercent);
  Serial.print(" | S1: "); Serial.print(p1);
  Serial.print("% | S2: "); Serial.print(p2);
  Serial.print("% | S3: "); Serial.print(p3);
  Serial.println("%");

  if (abs(avgPercent - lastSoilAvg) > 2) {
    Blynk.virtualWrite(V7, avgPercent);
    lastSoilAvg = avgPercent;
    Serial.println("[BLYNK] Sent moisture %.");
  } else {
    Serial.println("[DELTA] No change, skipping Blynk.");
  }

  // Rain lockout
  if (avgRaw < wetThreshold) {
    Blynk.virtualWrite(V12, 1);
    Serial.println("Soil extremely wet! Rain Lockout ON.");
  }
}

/************ GOOGLE SHEETS

************/
void logToGoogleSheets() {
  int v1 = analogRead(SOIL1);
  int v2 = analogRead(SOIL2);
  int v3 = analogRead(SOIL3);

  int avgRaw = (v1 + v2 + v3) / 3;
  int avgPercent = convertToPercentage(avgRaw);

  if (WiFi.status() == WL_CONNECTED) {
    WiFiClientSecure client;
    client.setInsecure();
    HTTPClient http;

    String url = String(googleScriptUrl) + "?moisture=" + String(avgPercent);

    Serial.print("Logging to Google Sheets: ");
    http.begin(client, url);
    http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);

    int httpCode = http.GET();

    if (httpCode > 0) {
      Serial.println("OK (" + String(httpCode) + ")");
    } else {
      Serial.println("FAILED (" + http.errorToString(httpCode) + ")");
    }

    http.end();
  }
}

/************ SETUP ************/
void setup() {
  Serial.begin(115200);

  pinMode(SOIL1, INPUT);
  pinMode(SOIL2, INPUT);
  pinMode(SOIL3, INPUT);

  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);
  
  // Synchronize time with NTP server (+8 Offset for Malaysia)
  configTime(28800, 0, "pool.ntp.org", "time.nist.gov");
  Serial.println("Waiting for NTP time sync: ");
  time_t now = time(nullptr);
  int retries = 0;
  while (now < 24 * 3600 && retries < 20) {
    delay(500);
    Serial.print(".");
    now = time(nullptr);
    retries++;
  }
  Serial.println();
  struct tm* timeinfo = localtime(&now);
  Serial.print("Current time: ");
  Serial.println(asctime(timeinfo));

  esp_task_wdt_config_t twdt_config = {
    .timeout_ms = 30000,
    .idle_core_mask = 0,
    .trigger_panic = true,
  };

  esp_task_wdt_init(&twdt_config);
  esp_task_wdt_add(NULL);

  timer.setInterval(5000L, monitorSensors);  // Read and display sensor data every 5 seconds (serial monitor only)
  timer.setInterval(10000L, checkConnections);  // Check WiFi and Blynk connection every 10 seconds
  timer.setInterval(60000L, scheduledBlynkPublish);  // Check every minute if it's time to publish to Blynk
  timer.setInterval(300000L, logToGoogleSheets);
}

/************ LOOP ************/
void loop() {
  Blynk.run();
  timer.run();
  esp_task_wdt_reset();
}