// Soil sensor pins
#define SOIL1 34
#define SOIL2 35
#define SOIL3 32
#define WIFI_LED_PIN 2 // Built-in Wi-Fi Status LED

// Calibration values
int dryThreshold = 2500;   // 0%
int wetThreshold = 1800;   // 100%

bool soil1Dry;
bool soil2Dry;
bool soil3Dry;

BlynkTimer timer;
int lastSoilAvg = -1;

/************ CONVERT TO % ************/
int convertToPercentage(int value) {
  int percent = map(value, dryThreshold, wetThreshold, 0, 100);

  if (percent > 100) percent = 100;
  if (percent < 0) percent = 0;

  return percent;
}

/************ BRIDGE TO PUMP ************/
void shoutToMasterPump(int lockoutValue) {
  if (WiFi.status() != WL_CONNECTED) return;
  
  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;
  
  String url = "https://blynk.cloud/external/api/update?token=" + String(MASTER_PUMP_TOKEN) + "&v12=" + String(lockoutValue);
  
  Serial.print("[BRIDGE] Syncing Pump V12 -> ");
  Serial.println(lockoutValue);
  
  http.begin(client, url);
  int httpCode = http.GET();
  if (httpCode > 0) {
    Serial.println("[BRIDGE] Success: " + String(httpCode));
  } else {
    Serial.println("[BRIDGE] Failed: " + http.errorToString(httpCode));
  }
  http.end();
}

/************ SEND TO BLYNK ************/
void sendMoistureToBlynk() {
  int v1 = analogRead(SOIL1);
  int v2 = analogRead(SOIL2);
  int v3 = analogRead(SOIL3);

  int p1 = convertToPercentage(v1);
  int p2 = convertToPercentage(v2);
  int p3 = convertToPercentage(v3);

  int avgPercent = (p1 + p2 + p3) / 3;
  int avgRaw = (v1 + v2 + v3) / 3;

  soil1Dry = (v1 > dryThreshold);
  soil2Dry = (v2 > dryThreshold);
  soil3Dry = (v3 > dryThreshold);

  Serial.print("Soil Avg (%): ");
  Serial.print(avgPercent);
  Serial.print(" | S1: "); Serial.print(p1);
  Serial.print("% | S2: "); Serial.print(p2);
  Serial.print("% | S3: "); Serial.print(p3);
  Serial.println("%");

  if (abs(avgPercent - lastSoilAvg) > 2) {
    Blynk.virtualWrite(V7, avgPercent);
    lastSoilAvg = avgPercent;
    Serial.println("[BLYNK] Sent moisture %.");
  } else {
    Serial.println("[DELTA] No change, skipping Blynk.");
  }

  // Rain lockout trigger (if soil extremely wet)
  if (avgRaw < wetThreshold) {
    Blynk.virtualWrite(V12, 1);
    Serial.println("Soil extremely wet! Rain Lockout ON.");
    shoutToMasterPump(1);
  }
}

/************ GOOGLE SHEETS ************/
void logToGoogleSheets() {
  int v1 = analogRead(SOIL1);
  int v2 = analogRead(SOIL2);
  int v3 = analogRead(SOIL3);

  int avgRaw = (v1 + v2 + v3) / 3;
  int avgPercent = convertToPercentage(avgRaw);

  if (WiFi.status() == WL_CONNECTED) {
    WiFiClientSecure client;
    client.setInsecure();
    HTTPClient http;

    String url = String(googleScriptUrl) + "?moisture=" + String(avgPercent);

    Serial.print("Logging to Google Sheets: ");
    http.begin(client, url);
    http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);

    int httpCode = http.GET();

    if (httpCode > 0) {
      Serial.println("OK (" + String(httpCode) + ")");
    } else {
      Serial.println("FAILED (" + http.errorToString(httpCode) + ")");
    }

    http.end();
  }
}

void checkWiFi() {
  if (WiFi.status() == WL_CONNECTED) {
    digitalWrite(WIFI_LED_PIN, HIGH);   // 🔆 LED ON - WiFi OK
    Serial.println("✅ WiFi OK");
  } else {
    digitalWrite(WIFI_LED_PIN, LOW);  // ⚫ LED OFF - WiFi Lost
    Serial.println("📶 WiFi reconnect...");
    WiFi.begin(ssid, pass);
  }
}

/************ SETUP ************/
void setup() {
  Serial.begin(115200);

  pinMode(SOIL1, INPUT);
  pinMode(SOIL2, INPUT);
  pinMode(SOIL3, INPUT);
  pinMode(WIFI_LED_PIN, OUTPUT);
  digitalWrite(WIFI_LED_PIN, LOW);

  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);

  esp_task_wdt_config_t twdt_config = {
    .timeout_ms = 30000,
    .idle_core_mask = 0,
    .trigger_panic = true,
  };

  esp_task_wdt_init(&twdt_config);
  esp_task_wdt_add(NULL);

  timer.setInterval(60000L, sendMoistureToBlynk);
  timer.setInterval(10000L, checkWiFi);
  timer.setInterval(300000L, logToGoogleSheets);
}

/************ LOOP ************/
void loop() {
  Blynk.run();
  timer.run();
  esp_task_wdt_reset();
}