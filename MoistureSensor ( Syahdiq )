// Soil sensor pins (ADC pins on ESP32)
#define SOIL1 34
#define SOIL2 35
#define SOIL3 32

// Adjust this value after calibration
// Higher value = drier soil
int dryThreshold = 2500;
int wetThreshold = 1800; // Too wet, prevent watering

bool soil1Dry;
bool soil2Dry;
bool soil3Dry;

BlynkTimer timer;
int lastSoilAvg = -1; // For delta logging

void sendMoistureToBlynk() {
  int soilValue1 = analogRead(SOIL1);
  int soilValue2 = analogRead(SOIL2);
  int soilValue3 = analogRead(SOIL3);

  // Calculate average
  int soilAverage = (soilValue1 + soilValue2 + soilValue3) / 3;

  // Condition: TRUE if DRY, FALSE if WET
  soil1Dry = (soilValue1 > dryThreshold);
  soil2Dry = (soilValue2 > dryThreshold);
  soil3Dry = (soilValue3 > dryThreshold);

  // Print results
  Serial.print("Soil Avg: ");
  Serial.print(soilAverage);
  Serial.print(" | S1: "); Serial.print(soilValue1);
  Serial.print(" | S2: "); Serial.print(soilValue2);
  Serial.print(" | S3: "); Serial.print(soilValue3);
  Serial.println();

  // Send to Blynk (only if changed by more than 50 ADC units)
  if (abs(soilAverage - lastSoilAvg) > 50) {
    Blynk.virtualWrite(V7, soilAverage);
    lastSoilAvg = soilAverage;
    Serial.println("[BLYNK] Sent moisture.");
  } else {
    Serial.println("[DELTA] No change, skipping Blynk.");
  }

  // Composite Rain Lockout: If soil is extremely wet, lock out system
  if (soilAverage < wetThreshold) {
      Blynk.virtualWrite(V12, 1);
      Serial.println("Soil extremely wet! Triggering Rain Lockout (V12).");
  }
}

void logToGoogleSheets() {
  int v1 = analogRead(SOIL1);
  int v2 = analogRead(SOIL2);
  int v3 = analogRead(SOIL3);
  int avg = (v1 + v2 + v3) / 3;

  if (WiFi.status() == WL_CONNECTED) {
    WiFiClientSecure client;
    client.setInsecure(); // Google certificates rotate often; skip validation for simplicity
    HTTPClient http;

    String url = String(googleScriptUrl) + "?moisture=" + String(avg);

    Serial.print("Logging to Google Sheets: ");
    http.begin(client, url);
    http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);
    int httpCode = http.GET();
    
    if (httpCode > 0) {
      Serial.println("OK (" + String(httpCode) + ")");
    } else {
      Serial.println("FAILED (" + http.errorToString(httpCode) + ")");
    }
    http.end();
  }
}

void setup() {
  Serial.begin(115200);

  pinMode(SOIL1, INPUT);
  pinMode(SOIL2, INPUT);
  pinMode(SOIL3, INPUT);

  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);

  // Hardware Watchdog: reboot if loop freezes for 30 seconds
  esp_task_wdt_config_t twdt_config = {
      .timeout_ms = 30000,
      .idle_core_mask = 0,
      .trigger_panic = true,
  };
  esp_task_wdt_init(&twdt_config);
  esp_task_wdt_add(NULL);

  timer.setInterval(60000L, sendMoistureToBlynk);
  timer.setInterval(300000L, logToGoogleSheets); // Log every 5 minutes
}

void loop() {
  Blynk.run();
  timer.run();
  esp_task_wdt_reset(); // Feed watchdog to prevent reboot
}