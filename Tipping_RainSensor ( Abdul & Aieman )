/* 
  Tipping Rain Sensor (Abdul & Aieman)
  - Uses SHARED AUTH TOKEN with Pump (MbA2... )
  - Reports Rainfall (V8) and Lockout (V12)
  - Schedule: Only communicates at 07:30 AM and 03:30 PM
*/

char ssid[] = "WiFi JSK";
char pass[] = "vhwau35565";

// --- EXTERNAL LINKS ---
const char* googleScriptUrl = "https://script.google.com/macros/s/AKfycbw6NvqTFViBKepVJR1U8h83tk3qDTgYXf08oPubvSgFoqx4YWgLtQ71HhUk0xqkdrty/exec";

// --- PIN DEFINITIONS ---
#define REED_PIN 32         // Tipping Bucket Reed Switch
#define RAIN_SENSOR_PIN 34  // Analog Rain Probe
#define WIFI_LED_PIN 2      // Built-in LED

// --- CONSTANTS ---
const float RAIN_PER_TIP = 0.2;     // 0.2mm per tip
const int RAIN_THRESHOLD = 2000;   // Analog threshold (Lower = Wetter)
const float LOCKOUT_THRESHOLD = 5.0; // Daily rain limit (mm)
const unsigned long rainTimeout = 10000; // 10s sensor window

// --- GLOBAL VARIABLES ---
volatile unsigned long tipCount = 0;
volatile unsigned long lastDebounceTime = 0;
const unsigned long debounceDelay = 50;

unsigned long lastTipTime = 0;
int lastResetDay = -1;
int lastPublishHour = -1;

BlynkTimer timer;

// ================== INTERRUPT ==================
void IRAM_ATTR handleTip() {
  unsigned long now = millis();
  if (now - lastDebounceTime > debounceDelay) {
    tipCount++;
    lastDebounceTime = now;
    lastTipTime = now;
  }
}

// ================== LOGGING ==================
void logToGoogleSheets() {
  if (WiFi.status() != WL_CONNECTED) return;
  float rainfall = tipCount * RAIN_PER_TIP;
  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;
  String url = String(googleScriptUrl) + "?rainfall=" + String(rainfall, 2);
  http.begin(client, url);
  http.GET();
  http.end();
  Serial.println("[LOG] Google Sheets updated.");
}

// ================== SCHEDULED TRANSMISSION ==================
void checkScheduledPublish() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return;

  int hour = timeinfo.tm_hour;
  int minute = timeinfo.tm_min;

  // Sync at 07:30 AM or 15:30 PM (3:30 PM)
  if (((hour == 7 && minute == 30) || (hour == 15 && minute == 30)) && hour != lastPublishHour) {
    lastPublishHour = hour;
    
    Serial.println("📤 [SCHEDULED] Updating shared virtual pins...");

    float rainfall = tipCount * RAIN_PER_TIP;
    bool isRaining = (millis() - lastTipTime < rainTimeout || analogRead(RAIN_SENSOR_PIN) < RAIN_THRESHOLD);
    int lockout = (isRaining || rainfall >= LOCKOUT_THRESHOLD) ? 1 : 0;

    // Direct Virtual Writes (Shared Account)
    Blynk.virtualWrite(V8, rainfall);
    Blynk.virtualWrite(V12, lockout);

    // Backup to Google Sheets
    logToGoogleSheets();
    
    Serial.println("✅ Sync Complete.");
  }
}

// ================== MONITOR (SERIAL) ==================
void monitorStatus() {
  float rainfall = tipCount * RAIN_PER_TIP;
  int sensorVal = analogRead(RAIN_SENSOR_PIN);
  
  Serial.print("Rain: "); Serial.print(rainfall); 
  Serial.print("mm | Probe: "); Serial.println(sensorVal);
}

// ================== MIDNIGHT RESET ==================
void checkMidnightReset() {
  struct tm timeinfo;
  if (getLocalTime(&timeinfo) && timeinfo.tm_hour == 0 && timeinfo.tm_min == 0) {
    if (lastResetDay != timeinfo.tm_mday) {
      tipCount = 0;
      lastResetDay = timeinfo.tm_mday;
      lastPublishHour = -1;
      
      Blynk.virtualWrite(V8, 0);
      Blynk.virtualWrite(V12, 0);
      Serial.println("🔄 Daily Rainfall reset to 0.");
    }
  }
}

// ================== SYSTEM TASKS ==================
void checkSystem() {
  if (WiFi.status() == WL_CONNECTED) {
    digitalWrite(WIFI_LED_PIN, HIGH);
    if (!Blynk.connected()) Blynk.connect();
  } else {
    digitalWrite(WIFI_LED_PIN, LOW);
    WiFi.begin(ssid, pass);
  }
}

// ================== SETUP ==================
void setup() {
  Serial.begin(115200);

  pinMode(REED_PIN, INPUT_PULLUP);
  pinMode(RAIN_SENSOR_PIN, INPUT);
  pinMode(WIFI_LED_PIN, OUTPUT);

  WiFi.begin(ssid, pass);
  Blynk.config(BLYNK_AUTH_TOKEN);
  configTime(28800, 0, "pool.ntp.org");

  esp_task_wdt_config_t wdt_config = {
    .timeout_ms = 30000, .idle_core_mask = 0, .trigger_panic = true
  };
  esp_task_wdt_init(&wdt_config);
  esp_task_wdt_add(NULL);

  attachInterrupt(digitalPinToInterrupt(REED_PIN), handleTip, FALLING);

  timer.setInterval(10000L, monitorStatus);
  timer.setInterval(10000L, checkSystem);
  timer.setInterval(30000L, checkScheduledPublish);
  timer.setInterval(30000L, checkMidnightReset);
}

void loop() {
  if (Blynk.connected()) Blynk.run();
  timer.run();
  esp_task_wdt_reset();
}