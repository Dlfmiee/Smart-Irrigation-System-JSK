#define REED_PIN 32         
#define RAIN_SENSOR_PIN 34  
#define WIFI_LED_PIN 2      

const float RAIN_PER_TIP = 0.2;     
const float LOCKOUT_THRESHOLD = 5.0; 
const unsigned long rainTimeout = 10000; 

volatile uint32_t tipCount = 0;
volatile uint32_t lastDebounce = 0;
uint32_t lastTipTime = 0;
int lastResetDay = -1;
int lastPublishH = -1;
bool ntpSynced = false;
bool wdtActive = false;
BlynkTimer timer;

void IRAM_ATTR handleTip() {
  uint32_t now = millis();
  if (now - lastDebounce > 50) { tipCount++; lastDebounce = now; lastTipTime = now; }
}

void updateBlynkSilent(String params) {
  if (WiFi.status() != WL_CONNECTED) return;
  WiFiClientSecure client; client.setInsecure();
  HTTPClient http;
  String url = "https://blynk.cloud/external/api/update?token=" + String(BLYNK_AUTH_TOKEN) + "&" + params;
  http.begin(client, url); http.GET(); http.end();
}

void syncNTP() {
  configTime(28800, 0, "pool.ntp.org", "time.google.com");
  struct tm t; if (getLocalTime(&t, 1000)) ntpSynced = true;
}

void checkWiFi() {
  wl_status_t s = WiFi.status();
  if (s == WL_CONNECTED) {
    digitalWrite(WIFI_LED_PIN, HIGH);
    if (!ntpSynced) syncNTP();
  } else if (s == WL_DISCONNECTED || s == WL_NO_SSID_AVAIL || s == WL_CONNECT_FAILED) {
    digitalWrite(WIFI_LED_PIN, LOW); ntpSynced = false;
    WiFi.begin(ssid, pass);
  }
}

void scheduledPublish() {
  struct tm ti; if (!getLocalTime(&ti)) return;
  int h = ti.tm_hour; int m = ti.tm_min;

  bool inWindow = ( (h == 7 && m >= 15 && m <= 30) || (h == 15 && m >= 15 && m <= 30) );
  if (inWindow && !wdtActive) { esp_task_wdt_add(NULL); wdtActive = true; }
  else if (!inWindow && wdtActive) { esp_task_wdt_delete(NULL); wdtActive = false; }

  if ((h == 7 && m == 25) || (h == 15 && m == 25)) {
    if (h != lastPublishH) {
      lastPublishH = h;
      float rainfall = tipCount * RAIN_PER_TIP;
      int intuitive = 4095 - analogRead(RAIN_SENSOR_PIN);
      bool isRaining = (millis() - lastTipTime < rainTimeout || intuitive > 2095);
      int lockout = (isRaining || rainfall >= LOCKOUT_THRESHOLD) ? 1 : 0;
      updateBlynkSilent("V8=" + String(rainfall, 2) + "&V9=" + String(intuitive) + "&V12=" + String(lockout));
    }
  }
}

void checkMidnightReset() {
  struct tm ti; if (getLocalTime(&ti) && ti.tm_hour == 0 && ti.tm_min == 0) {
    if (lastResetDay != ti.tm_mday) {
      lastResetDay = ti.tm_mday; tipCount = 0; lastPublishH = -1;
      updateBlynkSilent("V8=0&V12=0");
    }
  }
}

void setup() {
  Serial.begin(115200);
  pinMode(REED_PIN, INPUT_PULLUP); attachInterrupt(digitalPinToInterrupt(REED_PIN), handleTip, FALLING);
  pinMode(RAIN_SENSOR_PIN, INPUT); pinMode(WIFI_LED_PIN, OUTPUT);

  WiFi.mode(WIFI_STA); WiFi.begin(ssid, pass);
  Blynk.config(BLYNK_AUTH_TOKEN);

  esp_task_wdt_config_t twdt_config = { .timeout_ms = 300000, .idle_core_mask = 0, .trigger_panic = true };
  esp_task_wdt_reconfigure(&twdt_config);

  timer.setInterval(30000L, checkWiFi);
  timer.setInterval(60000L, scheduledPublish);
  timer.setInterval(60000L, checkMidnightReset);
}

void loop() {
  timer.run();
  if (wdtActive) esp_task_wdt_reset();
}