// --- PIN DEFINITIONS ---
#define RELAY_A_PIN 14
#define RELAY_B_PIN 27
#define WIFI_LED_PIN 2

// --- VIRTUAL PINS ---
#define VPIN_VALVE_A V5
#define VPIN_VALVE_B V6

// --- CONSTANTS ---
const unsigned long MAX_VALVE_ON_TIME = 2100000; // 35 minutes Fail-Safe

// --- VARIABLES ---
BlynkTimer timer;
int lastOpenHour  = -1;
int lastCloseHour = -1;
unsigned long valveA_StartTime = 0;
unsigned long valveB_StartTime = 0;
bool ntpSynced = false;
bool wdtActive = false;

// Staging Variables
int envMoisture = 0;      
bool envRain = false;     
float envFlow = 0;        

// ================== SYSTEM UTILS ==================

void syncNTP() {
  configTime(28800, 0, "pool.ntp.org", "time.google.com");
  struct tm t;
  if (getLocalTime(&t, 1000)) { ntpSynced = true; }
}

void checkWiFi() {
  wl_status_t s = WiFi.status();
  if (s == WL_CONNECTED) {
    digitalWrite(WIFI_LED_PIN, HIGH);
    if (!ntpSynced) syncNTP();
  } else if (s == WL_DISCONNECTED || s == WL_NO_SSID_AVAIL || s == WL_CONNECT_FAILED) {
    digitalWrite(WIFI_LED_PIN, LOW);
    ntpSynced = false;
    WiFi.begin(ssid, pass); 
  }
}

// ================== BRIDGE ==================

void shoutToMasterPump(int vPin, int value) {
  if (WiFi.status() != WL_CONNECTED) return;
  WiFiClientSecure client; client.setInsecure();
  HTTPClient http;
  String url = "https://blynk.cloud/external/api/update?token=" + String(MASTER_PUMP_TOKEN) + "&v" + String(vPin) + "=" + String(value);
  http.begin(client, url);
  if (http.GET() > 0) Serial.printf("📡 [BRIDGE] Hubungi Master: V%d = %d\n", vPin, value);
  http.end();
}

void fetchGlobalData() {
  if (WiFi.status() != WL_CONNECTED) return;
  WiFiClientSecure client; client.setInsecure();
  HTTPClient http;
  
  auto getAPI = [&](const char* vPin) -> String {
    http.begin(client, "https://blynk.cloud/external/api/get?token=" + String(SENSOR_TOKEN) + "&" + vPin);
    String res = (http.GET() > 0) ? http.getString() : "";
    http.end();
    return res;
  };
  
  envMoisture = getAPI("V7").toInt();
  envRain = (getAPI("V12").toInt() == 1);
  envFlow = getAPI("V0").toFloat();
}

// ================== VALVE CONTROL ==================

void openValveA() {
  digitalWrite(RELAY_A_PIN, HIGH); 
  Blynk.virtualWrite(VPIN_VALVE_A, 1);
  shoutToMasterPump(5, 1);
  valveA_StartTime = millis(); 
  Serial.println("[A] Valve A OPEN (Fail-Safe Armed)");
}

void closeValveA() {
  digitalWrite(RELAY_A_PIN, LOW); 
  Blynk.virtualWrite(VPIN_VALVE_A, 0);
  shoutToMasterPump(5, 0);
  valveA_StartTime = 0;
  Serial.println("[A] Valve A CLOSED");
}

void openValveB() {
  digitalWrite(RELAY_B_PIN, HIGH); 
  Blynk.virtualWrite(VPIN_VALVE_B, 1);
  shoutToMasterPump(6, 1);
  valveB_StartTime = millis();
}

void closeValveB() {
  digitalWrite(RELAY_B_PIN, LOW); 
  Blynk.virtualWrite(VPIN_VALVE_B, 0);
  shoutToMasterPump(6, 0);
  valveB_StartTime = 0;
}

void checkFailSafe() {
  unsigned long now = millis();
  if (valveA_StartTime > 0 && (now - valveA_StartTime > MAX_VALVE_ON_TIME)) {
    Serial.println("🚨 [FAIL-SAFE] Valve A force closed (35m limit)"); closeValveA();
  }
  if (valveB_StartTime > 0 && (now - valveB_StartTime > MAX_VALVE_ON_TIME)) {
    Serial.println("🚨 [FAIL-SAFE] Valve B force closed (35m limit)"); closeValveB();
  }
}

// ================== HANDLERS ==================

BLYNK_WRITE(VPIN_VALVE_A) { if (param.asInt()==1) openValveA(); else closeValveA(); }
BLYNK_WRITE(VPIN_VALVE_B) { if (param.asInt()==1) openValveB(); else closeValveB(); }

BLYNK_CONNECTED() { Blynk.syncVirtual(VPIN_VALVE_A, VPIN_VALVE_B); }

void checkSchedule() {
  struct tm ti; if (!getLocalTime(&ti)) return;
  int h = ti.tm_hour; int m = ti.tm_min;

  bool inWindow = ( (h == 7 && m >= 57) || (h == 8 && m <= 33) );
  if (inWindow && !wdtActive) { esp_task_wdt_add(NULL); wdtActive = true; }
  else if (!inWindow && wdtActive) { esp_task_wdt_delete(NULL); wdtActive = false; }

  // 08:00 AM Open
  if (h == 8 && (m >= 0 && m <= 5) && lastOpenHour != h) {
    lastOpenHour = h; fetchGlobalData();
    if (envRain || envMoisture >= 80 || envFlow > 0.05) {
      Serial.println("🚫 Schedule: Skipped");
    } else {
      openValveA(); timer.setTimeout(7000L, openValveB);
    }
  }

  // 08:30 AM Close
  if (h == 8 && m == 30 && lastCloseHour != h) {
    closeValveA(); timer.setTimeout(7000L, closeValveB); lastCloseHour = h;
  }
}

void setup() {
  Serial.begin(115200);
  pinMode(RELAY_A_PIN, OUTPUT); pinMode(RELAY_B_PIN, OUTPUT); pinMode(WIFI_LED_PIN, OUTPUT);
  digitalWrite(RELAY_A_PIN, LOW); digitalWrite(RELAY_B_PIN, LOW);

  WiFi.mode(WIFI_STA); WiFi.begin(ssid, pass);
  Blynk.config(BLYNK_AUTH_TOKEN); Blynk.connect();

  esp_task_wdt_config_t twdt_config = { .timeout_ms = 300000, .idle_core_mask = 0, .trigger_panic = true };
  esp_task_wdt_reconfigure(&twdt_config);

  timer.setInterval(10000L, checkWiFi);
  timer.setInterval(60000L, checkSchedule);
  timer.setInterval(30000L, checkFailSafe);
}

void loop() {
  if (Blynk.connected()) Blynk.run();
  timer.run();
  if (wdtActive) esp_task_wdt_reset();
}