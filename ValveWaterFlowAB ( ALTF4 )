/*
 Valve AB Controller (ALTF4) - UPDATED
 Logic: 3-Wire Motorized Valve (Valve A ONLY)
 Pins: 25 (Open), 26 (Close)
 Schedule: 08:00 AM - 08:30 AM
 Token: Shared (MbA2y5hl...)
*/

#define BLYNK_TEMPLATE_ID   "TMPL67aY-VULb"
#define BLYNK_TEMPLATE_NAME "ESP32 WIFI"
#define BLYNK_AUTH_TOKEN    "MbA2y5hlAv4SpJ7-a-y9CDhSH9d2zfyd"
#define BLYNK_PRINT Serial

#include <WiFi.h>
#include <BlynkSimpleEsp32.h>
#include <time.h>
#include <esp_task_wdt.h>

// WiFi Configuration
const char* ssid = "Fmz";
const char* pass = "iiiiiiii";
const char* POSIX_TZ = "MYT-8"; 

// --- PIN DEFINITIONS ---
const int RELAY_OPEN_PIN = 25;   // Relay for Open (Inlet)
const int RELAY_CLOSE_PIN = 26;  // Relay for Close (Inlet)
const int FLOW_SENSOR_PIN = 4;   // Flow Sensor Input
const int WIFI_LED_PIN = 2;      // Status LED

// --- VIRTUAL PINS ---
#define VPIN_VALVE_A V5           // Main Valve Switch (Active on dashboard)
#define VPIN_FLOW_RATE V1         // Display pulses
#define VPIN_FLOW_STATUS V2       // Flow LED
#define VPIN_SYSTEM_STATUS V7     // Status Text

// --- VARIABLES ---
BlynkTimer timer;
volatile unsigned long pulseCount = 0;
unsigned long lastPulseCount = 0;
bool flowDetected = false;
bool valveA_Open = false;
int lastOpenDay = -1;
int lastCloseDay = -1;

void IRAM_ATTR pulseCounter() {
  pulseCount++;
}

// ================== VALVE ACTIONS ==================

void stopValve() {
  digitalWrite(RELAY_OPEN_PIN, HIGH); // Relays OFF (Active Low)
  digitalWrite(RELAY_CLOSE_PIN, HIGH);
  Serial.println("Motor: STOP");
}

void openValveA() {
  digitalWrite(RELAY_CLOSE_PIN, HIGH); // Ensure Close is OFF
  delay(100);
  digitalWrite(RELAY_OPEN_PIN, LOW); // Trigger OPEN
  valveA_Open = true;
  Blynk.virtualWrite(VPIN_VALVE_A, 1);
  Serial.println("Action: OPEN Valve A (3-Wire)");
}

void closeValveA() {
  digitalWrite(RELAY_OPEN_PIN, HIGH); // Ensure Open is OFF
  delay(100);
  digitalWrite(RELAY_CLOSE_PIN, LOW); // Trigger CLOSE
  valveA_Open = false;
  Blynk.virtualWrite(VPIN_VALVE_A, 0);
  Serial.println("Action: CLOSE Valve A (3-Wire)");
}

// ================== HANDLERS ==================

BLYNK_WRITE(VPIN_VALVE_A) {
  if (param.asInt()) openValveA();
  else closeValveA();
}

BLYNK_CONNECTED() {
  Blynk.syncVirtual(VPIN_VALVE_A);
  Serial.println("✅ ALTF4 Connected to Blynk");
}

// ================== LOGIC ==================

void checkWiFi() {
  if (WiFi.status() == WL_CONNECTED) {
    digitalWrite(WIFI_LED_PIN, HIGH);
  } else {
    digitalWrite(WIFI_LED_PIN, LOW);
    WiFi.begin(ssid, pass);
  }
}

void checkFlow() {
  unsigned long pulses = pulseCount;
  unsigned long pulsesInWindow = pulses - lastPulseCount;
  lastPulseCount = pulses;
  flowDetected = (pulsesInWindow > 0);
  Blynk.virtualWrite(VPIN_FLOW_RATE, pulsesInWindow);
  Blynk.virtualWrite(VPIN_FLOW_STATUS, flowDetected ? 1 : 0);
}

void checkSchedule() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return;

  int hour = timeinfo.tm_hour;
  int minute = timeinfo.tm_min;
  int day = timeinfo.tm_mday;

  // 08:00 AM - START
  if (hour == 8 && minute == 0 && lastOpenDay != day) {
    openValveA();
    lastOpenDay = day;
  }

  // 08:30 AM - STOP
  if (hour == 8 && minute == 30 && lastCloseDay != day) {
    closeValveA();
    lastCloseDay = day;
  }
}

void setup() {
  Serial.begin(115200);
  
  pinMode(RELAY_OPEN_PIN, OUTPUT);
  pinMode(RELAY_CLOSE_PIN, OUTPUT);
  pinMode(WIFI_LED_PIN, OUTPUT);
  pinMode(FLOW_SENSOR_PIN, INPUT_PULLUP);
  
  // Default: OFF
  digitalWrite(RELAY_OPEN_PIN, HIGH);
  digitalWrite(RELAY_CLOSE_PIN, HIGH);
  digitalWrite(WIFI_LED_PIN, LOW);

  attachInterrupt(digitalPinToInterrupt(FLOW_SENSOR_PIN), pulseCounter, FALLING);

  // Connection
  WiFi.begin(ssid, pass);
  Blynk.config(BLYNK_AUTH_TOKEN);
  configTime(28800, 0, "pool.ntp.org", "time.nist.gov");

  // Watchdog
  esp_task_wdt_config_t twdt_config = {
    .timeout_ms = 30000, .idle_core_mask = 0, .trigger_panic = true
  };
  esp_task_wdt_init(&twdt_config);
  esp_task_wdt_add(NULL);

  timer.setInterval(2000L, checkFlow);
  timer.setInterval(10000L, checkWiFi);
  timer.setInterval(60000L, checkSchedule);
  
  Serial.println("🚀 ALTF4 READY (3-Wire Valve A)");
}

void loop() {
  Blynk.run();
  timer.run();
  esp_task_wdt_reset();
}