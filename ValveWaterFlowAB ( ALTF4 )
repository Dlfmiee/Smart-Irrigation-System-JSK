void logToGoogleSheets() {
  if (WiFi.status() == WL_CONNECTED) {
    WiFiClientSecure client;
    client.setInsecure();
    HTTPClient http;

    // Read relay state. 
    int valveA_on = !digitalRead(RELAY_A_PIN);
    int valveB_on = !digitalRead(RELAY_B_PIN);

    String statusStr = "VALVE_A:" + String(valveA_on) + "_B:" + String(valveB_on);

    String url = String(googleScriptUrl) + "?valveA=" + String(valveA_on) + "&valveB=" + String(valveB_on);

    Serial.print("Logging to Google Sheets: ");
    http.begin(client, url);
    http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);
    int httpCode = http.GET();
    
    if (httpCode > 0) {
      Serial.println("OK (" + String(httpCode) + ")");
    } else {
      Serial.println("FAILED (" + http.errorToString(httpCode) + ")");
    }
    http.end();
  }
}

void checkWiFi() {
  if (WiFi.status() == WL_CONNECTED) {
    digitalWrite(WIFI_LED_PIN, HIGH);   // 🔆 LED ON - WiFi OK
    Serial.println("✅ WiFi OK");
  } else {
    digitalWrite(WIFI_LED_PIN, LOW);  // ⚫ LED OFF - WiFi Lost
    Serial.println("📶 WiFi reconnect...");
    WiFi.begin(ssid, pass);
  }
}

void setup() {
  Serial.begin(115200);
  pinMode(RELAY_A_PIN, OUTPUT);
  pinMode(RELAY_B_PIN, OUTPUT);
  pinMode(WIFI_LED_PIN, OUTPUT);
  digitalWrite(RELAY_A_PIN, HIGH);
  digitalWrite(RELAY_B_PIN, HIGH);
  digitalWrite(WIFI_LED_PIN, LOW);
  
  WiFi.begin(ssid, pass);
  Blynk.config(BLYNK_AUTH_TOKEN);
  configTime(28800, 0, "pool.ntp.org", "time.nist.gov");
  
  // Hardware Watchdog: reboot if loop freezes for 30 seconds
  esp_task_wdt_config_t twdt_config = {
      .timeout_ms = 30000,
      .idle_core_mask = 0,
      .trigger_panic = true,
  };
  esp_task_wdt_init(&twdt_config);
  esp_task_wdt_add(NULL);

  timer.setInterval(100L, processMotorTiming); // Motor & 30 min check
  timer.setInterval(60000L, checkSchedule);
  timer.setInterval(10000L, checkWiFi);
  timer.setInterval(300000L, logToGoogleSheets); // Log every 5 minutes
}

void loop() {
  Blynk.run();
  timer.run();
  esp_task_wdt_reset(); // Feed watchdog to prevent reboot
}