#define RELAY_A_PIN 25    // Valve A (Inlet - Fertilizer)
#define RELAY_B_PIN 26    // Valve B (Outlet - Fertilizer)
#define FLOW_SENSOR_A_PIN 4  
#define FLOW_SENSOR_B_PIN 5  

volatile int pulseCountA = 0;
volatile int pulseCountB = 0;
float flowRateA = 0.0;
float flowRateB = 0.0;
unsigned long oldTimeA = 0;
unsigned long oldTimeB = 0;

const float calibrationFactor = 450.0; 
BlynkTimer timer;

bool rainLockout = false;
int lastOpenDay = -1;

// Motorized Valve Timing
unsigned long valveATimer = 0;
bool valveAHalfOpening = false;

void IRAM_ATTR pulseCounterA() { pulseCountA++; }
void IRAM_ATTR pulseCounterB() { pulseCountB++; }

void calculateFlow() {
  unsigned long currentTime = millis();
  if ((currentTime - oldTimeA) >= 1000) {
    flowRateA = ((1000.0 / (millis() - oldTimeA)) * pulseCountA) / (calibrationFactor / 60.0);
    oldTimeA = millis(); pulseCountA = 0;
    Blynk.virtualWrite(V9, flowRateA);
  }
  if ((currentTime - oldTimeB) >= 1000) {
    flowRateB = ((1000.0 / (millis() - oldTimeB)) * pulseCountB) / (calibrationFactor / 60.0);
    oldTimeB = millis(); pulseCountB = 0;
    Blynk.virtualWrite(V10, flowRateB);
  }
}

void forceCloseCD() {
  Blynk.virtualWrite(V3, 0);
  Blynk.virtualWrite(V4, 0);
}

// VALVE A - INLET (Half-Open Logic)
void openValveA_Half() { 
  digitalWrite(RELAY_A_PIN, LOW); 
  Blynk.virtualWrite(V7, 1); 
  valveAHalfOpening = true;
  valveATimer = millis();
  Serial.println("Valve A (Inlet) Opening for 5s..."); 
  forceCloseCD(); 
}
void closeValveA() { 
  digitalWrite(RELAY_A_PIN, HIGH); 
  valveAHalfOpening = false;
  Blynk.virtualWrite(V7, 0); 
  Serial.println("Valve A (Inlet) Command Closed"); 
}

// VALVE B - OUTLET (Full-Open Logic)
void openValveB() { 
  digitalWrite(RELAY_B_PIN, LOW); 
  Blynk.virtualWrite(V8, 1); 
  Serial.println("Valve B (Outlet) Opened Fully"); 
  forceCloseCD(); 
}
void closeValveB() { 
  digitalWrite(RELAY_B_PIN, HIGH); 
  Blynk.virtualWrite(V8, 0); 
  Serial.println("Valve B (Outlet) Command Closed"); 
}

void processMotorTiming() {
  // Pause Valve A after 5 seconds to achieve "Half-Open"
  if (valveAHalfOpening && (millis() - valveATimer >= 5000)) {
    digitalWrite(RELAY_A_PIN, HIGH); // Cut power to stop motor half-way
    valveAHalfOpening = false;
    Serial.println("Valve A (Inlet) Paused at Half-Open to reduce pressure.");
  }
}

void checkSchedule() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return;

  if (timeinfo.tm_hour == 8 && timeinfo.tm_min == 0) {
    if (lastOpenDay != timeinfo.tm_mday) {
      if (!rainLockout) {
        Serial.println("SCHEDULE: Fertilizer Sequence (08:00 AM)");
        openValveA_Half(); // Inlet Half
        openValveB();      // Outlet Full
      }
      lastOpenDay = timeinfo.tm_mday;
    }
  }
}

BLYNK_WRITE(V17) { rainLockout = param.asInt() == 1; }
BLYNK_WRITE(V7) { if (param.asInt()) openValveA_Half(); else closeValveA(); }
BLYNK_WRITE(V8) { if (param.asInt()) openValveB(); else closeValveB(); }
BLYNK_CONNECTED() { Blynk.syncVirtual(V17); }

void setup() {
  Serial.begin(115200);
  pinMode(RELAY_A_PIN, OUTPUT);
  pinMode(RELAY_B_PIN, OUTPUT);
  digitalWrite(RELAY_A_PIN, HIGH);
  digitalWrite(RELAY_B_PIN, HIGH);
  
  pinMode(FLOW_SENSOR_A_PIN, INPUT_PULLUP);
  pinMode(FLOW_SENSOR_B_PIN, INPUT_PULLUP);
  attachInterrupt(FLOW_SENSOR_A_PIN, pulseCounterA, FALLING);
  attachInterrupt(FLOW_SENSOR_B_PIN, pulseCounterB, FALLING);

  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);
  configTime(28800, 0, "pool.ntp.org", "time.nist.gov");
  
  timer.setInterval(100L, processMotorTiming); // Fast check for the 5s timer
  timer.setInterval(1000L, calculateFlow);
  timer.setInterval(15000L, checkSchedule);
}

void loop() {
  Blynk.run();
  timer.run();
}