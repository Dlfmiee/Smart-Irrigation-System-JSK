/*
 Valve AB Controller (ALTF4)
 V5 = Valve A (Pin 25) - Independent
 V6 = Valve B (Pin 26) - Independent
 Schedule: 08:00 AM Open, 08:30 AM Close
*/

#define BLYNK_TEMPLATE_ID   "TMPL67aY-VULb"
#define BLYNK_TEMPLATE_NAME "ESP32 WIFI"
#define BLYNK_AUTH_TOKEN    "JM9P4q32gJOpSwRtCuwPiQ6iY_IwCGPj"
#define BLYNK_PRINT Serial

#include <WiFi.h>
#include <BlynkSimpleEsp32.h>
#include <time.h>
#include <esp_task_wdt.h>

// WiFi
const char* ssid = "SurauAl-Irfan";
const char* pass = "datangsurau";

// --- PIN DEFINITIONS ---
#define RELAY_A_PIN 25   // Valve A
#define RELAY_B_PIN 27   // Valve B
#define WIFI_LED_PIN 2   // Built-in Status LED

// --- VIRTUAL PINS ---
#define VPIN_VALVE_A V5
#define VPIN_VALVE_B V6

// --- VARIABLES ---
BlynkTimer timer;
int lastOpenDay  = -1;
int lastCloseDay = -1;

// Staging Variables (Pre-Check)
int envMoisture = 0;      // V7
bool envRain = false;     // V12
float envFlow = 0;        // V0
bool envConditionOK = false;
bool leakDetected = false;
int lastCheckDay = -1;
int lastLeakCheckDay = -1;

// ================== VALVE A ==================

void openValveA() {
  digitalWrite(RELAY_A_PIN, HIGH);        // Active LOW = energize
  Blynk.virtualWrite(VPIN_VALVE_A, 1);
  Serial.println("[A] Valve A OPEN");
}

void closeValveA() {
  digitalWrite(RELAY_A_PIN, LOW);       // De-energize
  Blynk.virtualWrite(VPIN_VALVE_A, 0);
  Serial.println("[A] Valve A CLOSED");
}

// ================== VALVE B ==================

void openValveB() {
  digitalWrite(RELAY_B_PIN, HIGH);        // Active LOW = energize
  Blynk.virtualWrite(VPIN_VALVE_B, 1);
  Serial.println("[B] Valve B OPEN");
}

void closeValveB() {
  digitalWrite(RELAY_B_PIN, LOW);       // De-energize
  Blynk.virtualWrite(VPIN_VALVE_B, 0);
  Serial.println("[B] Valve B CLOSED");
}

// ================== BLYNK HANDLERS ==================

BLYNK_WRITE(VPIN_VALVE_A) {
  if (param.asInt() == 1) openValveA();
  else                    closeValveA();
}

BLYNK_WRITE(VPIN_VALVE_B) {
  if (param.asInt() == 1) openValveB();
  else                    closeValveB();
}

// Environment Sync Handlers
BLYNK_WRITE(V7) { envMoisture = param.asInt(); }
BLYNK_WRITE(V12){ envRain = param.asInt(); }
BLYNK_WRITE(V0) { envFlow = param.asFloat(); }

BLYNK_CONNECTED() {
  // Sync both valve states on reconnect
  Blynk.syncVirtual(VPIN_VALVE_A, VPIN_VALVE_B);
  Serial.println("✅ ALTF4 Connected");
}

// ================== SCHEDULE ==================

void checkSchedule() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return;

  int hour = timeinfo.tm_hour;
  int minute = timeinfo.tm_min;
  int second = timeinfo.tm_sec; // For fine-grained pre-check
  int day = timeinfo.tm_mday;

  // 1. T-30 Mins (07:30): Sync Moisture and Rain
  if (hour == 7 && minute == 30 && lastCheckDay != day) {
    Serial.println("📢 T-30 [ALTF4]: Syncing Moisture/Rain Data...");
    Blynk.syncVirtual(V7, V12);
    lastCheckDay = day;
    // Allow a few seconds for sync to return, then analyze
    timer.setTimeout(5000L, [](){
      if (envRain) {
        envConditionOK = false;
        Serial.println("⚠️ Pre-check FAIL: Rain Lockout active.");
      } else if (envMoisture >= 80) {
        envConditionOK = false;
        Serial.println("⚠️ Pre-check FAIL: Soil is too wet.");
      } else {
        envConditionOK = true;
        Serial.println("✅ Pre-check PASS: Conditions OK.");
      }
    });
  }

  // 2. T-30 Secs (07:59): Sync Flow for Leak Check
  // Note: checkSchedule runs every 60s, so we check for minute 59
  if (hour == 7 && minute == 59 && lastLeakCheckDay != day) {
    Serial.println("📢 T-30s [ALTF4]: Syncing Flow for Leak Check...");
    Blynk.syncVirtual(V0);
    lastLeakCheckDay = day;
    timer.setTimeout(2000L, [](){
      if (envFlow > 0.05) { // Small threshold for noise
        leakDetected = true;
        Serial.println("🚨 Leak Check FAIL: Flow detected before opening!");
      } else {
        leakDetected = false;
        Serial.println("✅ Leak Check PASS: No flow detected.");
      }
    });
  }

  // 3. 08:00 AM - Process Execution
  if (hour == 8 && minute == 0 && lastOpenDay != day) {
    lastOpenDay = day;
    if (envConditionOK && !leakDetected) {
      Serial.println("⏰ Schedule: 08:00 - STARTING (Staggered)");
      openValveA();
      timer.setTimeout(7000L, openValveB);
    } else {
      String reason = leakDetected ? "LEAK" : (envRain ? "RAIN" : "WET SOIL");
      Serial.print("🚫 Schedule: 08:00 - SKIPPED. Reason: ");
      Serial.println(reason);
    }
  }

  // 4. 08:30 AM - Close staggered (Always runs if opened)
  if (hour == 8 && minute == 30 && lastCloseDay != day) {
    Serial.println("⏰ Schedule: 08:30 - Closing Valve A (B follows in 7s)");
    closeValveA();
    timer.setTimeout(7000L, closeValveB);
    lastCloseDay = day;
  }
}

// ================== WIFI CHECK ==================

void checkWiFi() {
  if (WiFi.status() == WL_CONNECTED) {
    digitalWrite(WIFI_LED_PIN, HIGH);
  } else {
    digitalWrite(WIFI_LED_PIN, LOW);
    WiFi.begin(ssid, pass);
    Serial.println("[WiFi] Reconnecting...");
  }
}

// ================== SETUP ==================

void setup() {
  Serial.begin(115200);

  pinMode(RELAY_A_PIN, OUTPUT);
  pinMode(RELAY_B_PIN, OUTPUT);
  pinMode(WIFI_LED_PIN, OUTPUT);

  // Safe default: both valves CLOSED
  digitalWrite(RELAY_A_PIN, HIGH);
  digitalWrite(RELAY_B_PIN, HIGH);
  digitalWrite(WIFI_LED_PIN, LOW);

  WiFi.begin(ssid, pass);
  Blynk.config(BLYNK_AUTH_TOKEN);
  configTime(28800, 0, "pool.ntp.org", "time.nist.gov");

  // Watchdog 30s
  esp_task_wdt_config_t twdt_config = {
    .timeout_ms = 30000, .idle_core_mask = 0, .trigger_panic = true
  };
  esp_task_wdt_init(&twdt_config);
  esp_task_wdt_add(NULL);

  timer.setInterval(10000L, checkWiFi);
  timer.setInterval(60000L, checkSchedule);

  Serial.println("🚀 ALTF4 Ready - Valve A (V5/Pin25) | Valve B (V6/Pin27)");
}

void loop() {
  Blynk.run();
  timer.run();
  esp_task_wdt_reset();
}