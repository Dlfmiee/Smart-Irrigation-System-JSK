/*
  Valve AB Controller (ALTF4) - INDEPENDENT DEVICE
  V5 = Valve A (Pin 14)
  V6 = Valve B (Pin 27)
  Schedule: 08:00 AM Open, 08:30 AM Close
  Logic: Active-HIGH (HIGH=OPEN, LOW=CLOSED)
  Bridge: Syncs V5/V6 to Master Pump
*/

#define BLYNK_TEMPLATE_ID   "TMPL67aY-VULb"
#define BLYNK_TEMPLATE_NAME "ESP32 WIFI"
#define BLYNK_AUTH_TOKEN    "JM9P4q32gJOpSwRtCuwPiQ6iY_IwCGPj"
#define BLYNK_PRINT Serial

#include <WiFi.h>
#include <BlynkSimpleEsp32.h>
#include <HTTPClient.h>
#include <WiFiClientSecure.h>
#include <time.h>
#include <esp_task_wdt.h>

// WiFi
const char* ssid = "WiFi JSK";
const char* pass = "vhwau35565";

// Bridge to Master Pump
const char* MASTER_PUMP_TOKEN = "MbA2y5hlAv4SpJ7-a-y9CDhSH9d2zfyd";

// --- PIN DEFINITIONS ---
#define RELAY_A_PIN 14
#define RELAY_B_PIN 27
#define WIFI_LED_PIN 2

// --- VIRTUAL PINS ---
#define VPIN_VALVE_A V5
#define VPIN_VALVE_B V6

// --- VARIABLES ---
BlynkTimer timer;
int lastOpenHour  = -1;
int lastCloseHour = -1;

// Staging Variables (Pre-Check via HTTP Fetch)
int envMoisture = 0;      
bool envRain = false;     
float envFlow = 0;        
bool envConditionOK = false;
bool leakDetected = false;
int lastCheckHour = -1;
int lastLeakCheckHour = -1;

// ================== BRIDGE ==================

void shoutToMasterPump(int vPin, int value) {
  if (WiFi.status() != WL_CONNECTED) return;
  
  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;
  
  String url = "https://blynk.cloud/external/api/update?token=" + 
               String(MASTER_PUMP_TOKEN) + "&v" + String(vPin) + "=" + String(value);
  
  Serial.print("[BRIDGE] Syncing V" + String(vPin) + " to Pump -> ");
  Serial.println(value);
  
  http.begin(client, url);
  int httpCode = http.GET();
  if (httpCode > 0) Serial.println("[BRIDGE] Success");
  else Serial.println("[BRIDGE] Failed: " + http.errorToString(httpCode));
  http.end();
}

// Fetch Environmental Data from Master Token
void fetchGlobalData() {
  if (WiFi.status() != WL_CONNECTED) return;
  
  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;
  
  String urlV7 = "https://blynk.cloud/external/api/get?token=" + String(MASTER_PUMP_TOKEN) + "&V7";
  http.begin(client, urlV7);
  if (http.GET() > 0) envMoisture = http.getString().toInt();
  http.end();
  
  String urlV12 = "https://blynk.cloud/external/api/get?token=" + String(MASTER_PUMP_TOKEN) + "&V12";
  http.begin(client, urlV12);
  if (http.GET() > 0) envRain = (http.getString().toInt() == 1);
  http.end();
  
  String urlV0 = "https://blynk.cloud/external/api/get?token=" + String(MASTER_PUMP_TOKEN) + "&V0";
  http.begin(client, urlV0);
  if (http.GET() > 0) envFlow = http.getString().toFloat();
  http.end();
  
  Serial.print("[FETCH] M: "); Serial.print(envMoisture);
  Serial.print(" | R: "); Serial.print(envRain);
  Serial.print(" | F: "); Serial.println(envFlow);
}

// ================== VALVE CONTROL ==================

void openValveA() {
  digitalWrite(RELAY_A_PIN, HIGH);
  Blynk.virtualWrite(VPIN_VALVE_A, 1);
  shoutToMasterPump(5, 1);
  Serial.println("[A] Valve A OPEN");
}

void closeValveA() {
  digitalWrite(RELAY_A_PIN, LOW);
  Blynk.virtualWrite(VPIN_VALVE_A, 0);
  shoutToMasterPump(5, 0);
  Serial.println("[A] Valve A CLOSED");
}

void openValveB() {
  digitalWrite(RELAY_B_PIN, HIGH);
  Blynk.virtualWrite(VPIN_VALVE_B, 1);
  shoutToMasterPump(6, 1);
  Serial.println("[B] Valve B OPEN");
}

void closeValveB() {
  digitalWrite(RELAY_B_PIN, LOW);
  Blynk.virtualWrite(VPIN_VALVE_B, 0);
  shoutToMasterPump(6, 0);
  Serial.println("[B] Valve B CLOSED");
}

// ================== BLYNK HANDLERS ==================

BLYNK_WRITE(VPIN_VALVE_A) {
  int val = param.asInt();
  Serial.print("[BLYNK] V5 received: "); Serial.println(val);
  if (val == 1) openValveA();
  else          closeValveA();
}

BLYNK_WRITE(VPIN_VALVE_B) {
  int val = param.asInt();
  Serial.print("[BLYNK] V6 received: "); Serial.println(val);
  if (val == 1) openValveB();
  else          closeValveB();
}

BLYNK_CONNECTED() {
  Serial.println("[BLYNK] Connected! Syncing virtual pins...");
  Blynk.syncVirtual(VPIN_VALVE_A, VPIN_VALVE_B);
  Serial.println("✅ ALTF4 Connected & Synced (Optimized)");
}

// ================== SCHEDULE ==================

void checkSchedule() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return;

  int hour = timeinfo.tm_hour;
  int minute = timeinfo.tm_min;

  // 1. T-27 Mins (07:33): Fetch Environment Data
  if (hour == 7 && minute == 33 && lastCheckHour != hour) {
    Serial.println("📢 T-30 [ALTF4]: Fetching Sensor Data...");
    fetchGlobalData();
    lastCheckHour = hour;
    if (envRain) {
      envConditionOK = false;
      Serial.println("⚠️ Pre-check FAIL: Rain Lockout active.");
    } else if (envMoisture >= 80) {
      envConditionOK = false;
      Serial.println("⚠️ Pre-check FAIL: Soil is too wet.");
    } else {
      envConditionOK = true;
      Serial.println("✅ Pre-check PASS: Conditions OK.");
    }
  }

  // 2. T-30 Secs (07:59): Fetch Flow for Leak Check
  if (hour == 7 && minute == 59 && lastLeakCheckHour != hour) {
    Serial.println("📢 T-30s [ALTF4]: Fetching Flow for Leak Check...");
    fetchGlobalData(); // refresh
    lastLeakCheckHour = hour;
    if (envFlow > 0.05) {
      leakDetected = true;
      Serial.println("🚨 Leak Check FAIL: Flow detected before opening!");
    } else {
      leakDetected = false;
      Serial.println("✅ Leak Check PASS: No flow detected.");
    }
  }

  // 3. 08:00 AM - Process Execution
  if (hour == 8 && minute == 0 && lastOpenHour != hour) {
    lastOpenHour = hour;
    if (envConditionOK && !leakDetected) {
      Serial.println("⏰ Schedule: 08:00 - STARTING (Staggered)");
      openValveA();
      timer.setTimeout(7000L, openValveB);
    } else {
      String reason = leakDetected ? "LEAK" : (envRain ? "RAIN" : "WET SOIL");
      Serial.print("🚫 Schedule: 08:00 - SKIPPED. Reason: ");
      Serial.println(reason);
    }
  }

  // 4. 08:30 AM - Close staggered
  if (hour == 8 && minute == 30 && lastCloseHour != hour) {
    Serial.println("⏰ Schedule: 08:30 - Closing Valve A (B follows in 7s)");
    closeValveA();
    timer.setTimeout(7000L, closeValveB);
    lastCloseHour = hour;
  }
}

// ================== WIFI CHECK ==================

void checkWiFi() {
  if (WiFi.status() == WL_CONNECTED) {
    digitalWrite(WIFI_LED_PIN, HIGH);
  } else {
    digitalWrite(WIFI_LED_PIN, LOW);
    Serial.println("[WIFI] Attempting to reconnect...");
    WiFi.begin(ssid, pass);
  }
}

// ================== SETUP ==================

void setup() {
  Serial.begin(115200);
  delay(500);
  Serial.println("\n\n[STARTUP] Initializing ALTF4 (Valve AB)...");

  pinMode(RELAY_A_PIN, OUTPUT);
  pinMode(RELAY_B_PIN, OUTPUT);
  pinMode(WIFI_LED_PIN, OUTPUT);

  // Safe default
  digitalWrite(RELAY_A_PIN, LOW);
  digitalWrite(RELAY_B_PIN, LOW);
  digitalWrite(WIFI_LED_PIN, LOW);

  Serial.println("[SETUP] Connecting to WiFi: " + String(ssid));
  WiFi.begin(ssid, pass);
  
  // Robust WiFi Wait
  int wifiAttempts = 0;
  while (WiFi.status() != WL_CONNECTED && wifiAttempts < 20) {
    delay(500);
    Serial.print(".");
    wifiAttempts++;
  }
  
  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\n✅ WiFi Connected! IP: " + WiFi.localIP().toString());
  } else {
    Serial.println("\n❌ WiFi Connection FAILED!");
  }

  Serial.println("[SETUP] Configuring Blynk...");
  Blynk.config(BLYNK_AUTH_TOKEN);
  
  if (!Blynk.connected()) {
    Serial.println("[SETUP] Connecting to Blynk server...");
    Blynk.connect();
  }

  configTime(28800, 0, "pool.ntp.org", "time.nist.gov");

  // Watchdog 30s
  esp_task_wdt_config_t twdt_config = {
    .timeout_ms = 30000, .idle_core_mask = 0, .trigger_panic = true
  };
  esp_task_wdt_init(&twdt_config);
  esp_task_wdt_add(NULL);

  timer.setInterval(10000L, checkWiFi);
  timer.setInterval(60000L, checkSchedule);

  Serial.println("[SYSTEM] ALTF4 Ready (Independent Sync Mode)");
}

void loop() {
  if (Blynk.connected()) {
    Blynk.run();
  } else {
    Blynk.connect();
  }
  timer.run();
  esp_task_wdt_reset();
}