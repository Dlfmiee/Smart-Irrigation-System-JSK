BlynkTimer timer;

bool rainLockout = false;
int lastOpenDay = -1;

// Motorized Valve Timing

// 30 MINIT BAJA
unsigned long fertilizingStartTime = 0;
bool fertilizingActive = false;
const unsigned long FERTILIZING_DURATION = 1800000; // 30 MINIT




// VALVE A - INLET (Full-Open Logic)
void openValveA() { 
  digitalWrite(RELAY_A_PIN, LOW); 
  Blynk.virtualWrite(V5, 1); 
  Serial.println("Valve A (Inlet) Opened Fully"); 
}
void closeValveA() { 
  digitalWrite(RELAY_A_PIN, HIGH); 
  Blynk.virtualWrite(V5, 0); 
  Serial.println("Valve A (Inlet) Command Closed"); 
}

// VALVE B - OUTLET (Full-Open Logic)
void openValveB() { 
  digitalWrite(RELAY_B_PIN, LOW); 
  Blynk.virtualWrite(V6, 1); 
  Serial.println("Valve B (Outlet) Opened Fully"); 
}
void closeValveB() { 
  digitalWrite(RELAY_B_PIN, HIGH); 
  Blynk.virtualWrite(V6, 0); 
  Serial.println("Valve B (Outlet) Command Closed"); 
}

// 🚿 START 30 MINIT BAJA
void startFertilizing() {
  if (!rainLockout && !fertilizingActive) {
    Serial.println("🌿 BAJA 30 MINIT DIMULAKAN!");
    openValveA();
    openValveB();
    fertilizingActive = true;
    fertilizingStartTime = millis();
  } else {
    Serial.println("❌ Tidak boleh start: Rain lockout atau sudah aktif");
  }
}

// ⏹️ STOP BAJA
void stopFertilizing() {
  closeValveA();
  closeValveB();
  fertilizingActive = false;
  Serial.println("⏹️ BAJA DIBERHENTIKAN");
}

void processMotorTiming() {
  // 30 MINIT AUTO-STOP
  if (fertilizingActive && (millis() - fertilizingStartTime >= FERTILIZING_DURATION)) {
    Serial.println("⏰ 30 MINIT SELESAI - AUTO STOP!");
    stopFertilizing();
  }
}

void checkSchedule() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return;

  if (timeinfo.tm_hour == 8 && timeinfo.tm_min == 0) {
    if (lastOpenDay != timeinfo.tm_mday) {
      if (!rainLockout) {
        Serial.println("SCHEDULE: Fertilizer Sequence (08:00 AM)");
        startFertilizing();
      }
      lastOpenDay = timeinfo.tm_mday;
    }
  }
}

