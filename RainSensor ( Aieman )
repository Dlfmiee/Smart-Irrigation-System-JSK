int lastRainValue = -1;

// ================== FUNCTIONS ==================

// ---- Bridge to Pump ----
void shoutToMasterPump(int lockoutValue) {
  if (WiFi.status() != WL_CONNECTED) return;
  
  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;
  
  String url = "https://blynk.cloud/external/api/update?token=" + String(MASTER_PUMP_TOKEN) + "&v12=" + String(lockoutValue);
  
  Serial.print("[BRIDGE] Syncing Pump V12 -> ");
  Serial.println(lockoutValue);
  
  http.begin(client, url);
  int httpCode = http.GET();
  if (httpCode > 0) {
    Serial.println("[BRIDGE] Success: " + String(httpCode));
  } else {
    Serial.println("[BRIDGE] Failed: " + http.errorToString(httpCode));
  }
  http.end();
}

// ---- Rain Sensor ----
void readRainSensor() {
  int rainValue = analogRead(RAIN_SENSOR_PIN);

  // Send only if changed significantly
  if (abs(rainValue - lastRainValue) > 100) {
    Blynk.virtualWrite(V9, rainValue);
    lastRainValue = rainValue;
    Serial.println("[BLYNK] Rain value updated");
  }

  // Detect rain
  if (rainValue < RAIN_THRESHOLD) {
    digitalWrite(LED_PIN, HIGH);
    Blynk.virtualWrite(V10, "RAINING");

    if (!rainLockout) {
      rainLockout = true;
      Blynk.virtualWrite(V12, 1);
      Serial.println("[STATUS] Rain detected -> LOCKOUT ON");
      shoutToMasterPump(1);
    }
  } else {
    digitalWrite(LED_PIN, LOW);
    Blynk.virtualWrite(V10, "NO RAIN");
  }
}

// ---- Midnight Reset ----
void checkMidnightReset() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return;

  if (timeinfo.tm_hour == 0 && timeinfo.tm_min == 0) {
    if (lastResetDay != timeinfo.tm_mday) {
      rainLockout = false;
      Blynk.virtualWrite(V12, 0);

      lastResetDay = timeinfo.tm_mday;
      Serial.println("[RESET] Midnight -> Lockout cleared");
      shoutToMasterPump(0);
    }
  }
}

// ---- Google Sheets Logging ----
void logToGoogleSheets() {
  if (WiFi.status() != WL_CONNECTED) return;

  int rainFlag = rainLockout ? 1 : 0;

  WiFiClientSecure client;
  client.setInsecure();

  HTTPClient http;
  String url = String(googleScriptUrl) + "?rain=" + String(rainFlag);

  Serial.print("[LOG] Sending: ");
  Serial.println(url);

  http.begin(client, url);
  http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);

  int httpCode = http.GET();

  if (httpCode > 0) {
    Serial.println("[LOG] Success: " + String(httpCode));
  } else {
    Serial.println("[LOG] Failed: " + http.errorToString(httpCode));
  }
  http.end();
}

void checkWiFi() {
  if (WiFi.status() == WL_CONNECTED) {
    digitalWrite(WIFI_LED_PIN, LOW);   // 🔆 LED ON - WiFi OK
  } else {
    digitalWrite(WIFI_LED_PIN, HIGH);  // ⚫ LED OFF - WiFi Lost
  }
}

// ---- Blynk Sync ----
BLYNK_WRITE(V12) {
  rainLockout = param.asInt();
}

BLYNK_CONNECTED() {
  Blynk.syncVirtual(V12);
}

// ================== SETUP ==================
void setup() {
  Serial.begin(115200);

  pinMode(LED_PIN, OUTPUT);
  digitalWrite(LED_PIN, LOW);
  pinMode(WIFI_LED_PIN, OUTPUT);
  digitalWrite(WIFI_LED_PIN, HIGH);

  // Connect WiFi + Blynk
  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);

  // Malaysia Time (GMT+8)
  configTime(28800, 0, "pool.ntp.org", "time.nist.gov");

  // ---- Watchdog (FIXED API) ----
  esp_task_wdt_config_t wdt_config = {
    .timeout_ms = 30000,
    .idle_core_mask = 0,
    .trigger_panic = true
  };
  esp_task_wdt_init(&wdt_config);
  esp_task_wdt_add(NULL);

  // ---- Timers ----
  timer.setInterval(5000L, readRainSensor);           // 5 sec for faster rain detect
  timer.setInterval(10000L, checkWiFi);               // WiFi check
  timer.setInterval(30000L, checkMidnightReset);      // 30 sec
  timer.setInterval(300000L, logToGoogleSheets);     // 5 min

  Serial.println("[SYSTEM] Started");
}

// ================== LOOP ==================
void loop() {
  if (WiFi.status() == WL_CONNECTED) {
    Blynk.run();
  }
  timer.run();
  esp_task_wdt_reset();
}