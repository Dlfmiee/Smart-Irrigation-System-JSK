// Pin setup
#define RAIN_SENSOR_PIN 34   // Analog pin
#define LED_PIN 27           // LED indicator

BlynkTimer timer;
bool rainLockout = false;
int lastResetDay = -1;

void readRainSensor()
{
  int rainValue = analogRead(RAIN_SENSOR_PIN);
  Blynk.virtualWrite(V9, rainValue);

  // Rain threshold (adjust according to calibration)
  if (rainValue < 2000)   // Raining
  {
    digitalWrite(LED_PIN, HIGH);
    Blynk.virtualWrite(V10, "RAINING");
    
    // Activate global rain lockout if not already active
    if (!rainLockout) {
      rainLockout = true;
      Blynk.virtualWrite(V12, 1);
      Serial.println("Rain detected! Setting Global Rain Lockout (V12) to ON.");
    }
  }
  else
  {
    digitalWrite(LED_PIN, LOW);
    Blynk.virtualWrite(V10, "NO RAIN");
  }
}

void checkMidnightReset() {
  struct tm timeinfo;
  if (getLocalTime(&timeinfo)) {
    // Reset rain lockout exactly at midnight (00:00) so irrigation can resume next day
    if (timeinfo.tm_hour == 0 && timeinfo.tm_min == 0) {
      if (lastResetDay != timeinfo.tm_mday) {
        rainLockout = false;
        Blynk.virtualWrite(V12, 0); // Clear lockout in the cloud
        lastResetDay = timeinfo.tm_mday;
        Serial.println("Midnight Reached! Rain Lockout (V12) has been RESET.");
      }
    }
  }
}

// Read lockout from cloud just in case of ESP restart
BLYNK_WRITE(V12) {
  rainLockout = param.asInt() == 1;
}

BLYNK_CONNECTED() {
  Blynk.syncVirtual(V12); // Sync Rain Lockout state
}

void logToGoogleSheets() {
  int rainValue = analogRead(RAIN_SENSOR_PIN);
  String status = rainLockout ? "RAIN_LOCKOUT" : "CLEAR";

  if (WiFi.status() == WL_CONNECTED) {
    WiFiClientSecure client;
    client.setInsecure();
    HTTPClient http;

    int rainFlag = rainLockout ? 1 : 0;
    String url = String(googleScriptUrl) + "?rain=" + String(rainFlag);

    Serial.print("Logging to Google Sheets: ");
    http.begin(client, url);
    http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);
    int httpCode = http.GET();
    
    if (httpCode > 0) {
      Serial.println("OK (" + String(httpCode) + ")");
    } else {
      Serial.println("FAILED (" + http.errorToString(httpCode) + ")");
    }
    http.end();
  }
}

void setup()
{
  Serial.begin(115200);
  pinMode(LED_PIN, OUTPUT);
  digitalWrite(LED_PIN, LOW);

  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);
  
  // Set Timezone Malaysia (GMT+8)
  configTime(28800, 0, "pool.ntp.org", "time.nist.gov");

  timer.setInterval(2000L, readRainSensor);
  timer.setInterval(30000L, checkMidnightReset); // Check schedule safely
  timer.setInterval(300000L, logToGoogleSheets); // Log every 5 minutes
}

void loop()
{
  Blynk.run();
  timer.run();
}