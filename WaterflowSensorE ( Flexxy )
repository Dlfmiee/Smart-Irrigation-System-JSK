volatile int pulseCount = 0;
float flowRate = 0;
float lastFlowRate = -1; 
volatile unsigned long lastPulseTime = 0; 

BlynkTimer timer;
int lastReportDay = -1;
int lastReportSlot = -1;
int lastSentMinute = -1; // Minute-latch for One-Shot reporting

void IRAM_ATTR pulseCounter() {
  pulseCount++;
  lastPulseTime = millis();
}

void sendFlowRate() {
  noInterrupts();
  int count = pulseCount;
  pulseCount = 0;
  interrupts();

  // Calculation for 2-second interval:
  float flow_L_per_min = (count / 7.5) * 30.0; 
  flowRate = flow_L_per_min / 60.0;  // Convert to L/sec

  time_t now = time(nullptr);
  struct tm* timeinfo = localtime(&now);
  int hour = timeinfo->tm_hour;
  int minute = timeinfo->tm_min;

  Serial.print("[FLOW] Pulses: ");
  Serial.print(count);
  Serial.print(" | Rate: ");
  Serial.print(flowRate, 3);
  Serial.println(" L/sec");

  // Exact Target Slots: First (Leak Check T-2), Mid Check, Final Reset
  bool isTargetSlot = ((hour == 7 && minute == 58) ||
                       (hour == 8 && minute == 15) ||
                       (hour == 15 && minute == 58) ||
                       (hour == 16 && minute == 15));
                       
  bool isResetSlot = ((hour == 8 && minute == 31) ||
                      (hour == 16 && minute == 31));

  if (isTargetSlot || (isResetSlot && lastFlowRate > 0)) {
    if (minute != lastSentMinute) {
      Serial.println("📤 [SNAPSHOT] Connecting for flow sync...");
      Blynk.connect();
      unsigned long start = millis();
      while (!Blynk.connected() && millis() - start < 10000) {
        Blynk.run();
        delay(100);
      }

      if (Blynk.connected()) {
        float valToSend = isTargetSlot ? flowRate : 0;
        Blynk.virtualWrite(V0, valToSend);
        Blynk.run();
        delay(1000);
        
        lastSentMinute = minute;
        lastFlowRate = valToSend;
        Serial.println(isTargetSlot ? "✅ Snapshot Sent." : "✅ Final 0-Reset Sent.");
      } else {
        Serial.println("⚠️ Snapshot FAILED — Token might be busy.");
      }

      Blynk.disconnect(); // Failsafe
      Serial.println("💤 Disconnected from Blynk.");
    }
  }
}

void logToGoogleSheets() {
  if (WiFi.status() == WL_CONNECTED) {
    WiFiClientSecure client;
    client.setInsecure();
    HTTPClient http;
    String url = String(googleScriptUrl) + "?flowE=" + String(flowRate, 3);
    
    Serial.print("[SHEETS] Logging... ");
    http.begin(client, url);
    http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);
    int httpCode = http.GET();
    Serial.println(httpCode > 0 ? "DONE" : "FAIL");
    http.end();
  }
}

bool ntpSynced = false;

void checkWiFi() {
  wl_status_t wifiStatus = WiFi.status();

  if (wifiStatus == WL_CONNECTED) {
    digitalWrite(WIFI_LED_PIN, HIGH);
    if (!ntpSynced) {
      configTime(28800, 0, "pool.ntp.org", "time.google.com", "time.cloudflare.com");
      struct tm t;
      if (getLocalTime(&t, 5000)) {
        Serial.printf("✅ [NTP] Masa sync: %02d:%02d:%02d\n", t.tm_hour, t.tm_min, t.tm_sec);
        ntpSynced = true;
      } else {
        Serial.println("⚠️ [NTP] Masih gagal — akan cuba lagi.");
      }
    }
  } else if (wifiStatus == WL_IDLE_STATUS) {
    Serial.println("📶 WiFi sedang connecting... tunggu.");
  } else {
    ntpSynced = false;
    digitalWrite(WIFI_LED_PIN, LOW);
    Serial.printf("📶 WiFi lost (status=%d) — reconnecting...\n", wifiStatus);
    // Remove aggressive disconnect(true)
    WiFi.begin(ssid, pass);
  }
}

bool wdtActive = false;

void checkSchedule() {
  time_t now = time(nullptr);
  struct tm* timeinfo = localtime(&now);
  
  int hour = timeinfo->tm_hour;
  int minute = timeinfo->tm_min;
  int day = timeinfo->tm_yday;

  // --- WINDOWED WATCHDOG LOGIC ---
  // Window: 07:02 to 08:35 AND 15:02 to 16:35
  bool inMorningWindow = (hour == 7 && minute >= 2) || (hour == 8 && minute <= 35);
  bool inAfternoonWindow = (hour == 15 && minute >= 2) || (hour == 16 && minute <= 35);
  bool inWindow = inMorningWindow || inAfternoonWindow;

  if (inWindow && !wdtActive) {
    esp_task_wdt_add(NULL);
    wdtActive = true;
    Serial.println("🛡️ [WATCHDOG] Armed for Irrigation Window.");
  } else if (!inWindow && wdtActive) {
    esp_task_wdt_delete(NULL);
    wdtActive = false;
    Serial.println("🔓 [WATCHDOG] Disarmed (Idle Mode).");
  }

  // --- TWO-STAGE CONNECTION LOGIC ---
  int prepSlot = -1;
  if (hour == 7 && minute == 53) prepSlot = 0;
  else if (hour == 15 && minute == 53) prepSlot = 1;

  int workSlot = -1;
  if (hour == 7 && minute == 58) workSlot = 0;
  else if (hour == 15 && minute == 58) workSlot = 1;

  // Stage 1: Connect 5m early
  if (prepSlot != -1 && minute != lastSentMinute) {
    Serial.println("🌐 [STAGE 1] Connecting to Blynk 5m early...");
    Blynk.connect();
    lastSentMinute = minute; // latch
  }

  // Stage 2: Report and Disconnect
  if (workSlot != -1 && (day != lastReportDay || workSlot != lastReportSlot)) {
    Serial.printf("📢 [STAGE 2] Reporting Waterflow E at %02d:%02d\n", hour, minute);
    
    // Ensure we are connected
    if (!Blynk.connected()) Blynk.connect();
    unsigned long start = millis();
    while (!Blynk.connected() && millis() - start < 10000) {
      Blynk.run();
      delay(100);
    }

    if (Blynk.connected()) {
      Blynk.virtualWrite(V0, flowRate);
      Blynk.run();
      delay(1000);
      Serial.println("✅ Scheduled report sent.");
    } else {
      Serial.println("⚠️ Report FAILED — Token might be busy.");
    }
    
    Blynk.disconnect(); // Always Release
    Serial.println("💤 Disconnected from Blynk.");
    
    logToGoogleSheets();
    lastReportDay = day;
    lastReportSlot = workSlot;
  }
}

void setup() {
  Serial.begin(115200);
  delay(1000); 
  Serial.println("\n=== WATERFLOW SENSOR E (2s INTERVAL) ===");

  pinMode(WIFI_LED_PIN, OUTPUT);
  pinMode(LED_PIN, OUTPUT);
  // Startup blink on external LED (power-on indicator)
  for(int i=0; i<3; i++) {
    digitalWrite(LED_PIN, HIGH); delay(100);
    digitalWrite(LED_PIN, LOW);  delay(100);
  }

  pinMode(FLOW_SENSOR_PIN, INPUT_PULLUP);
  attachInterrupt(digitalPinToInterrupt(FLOW_SENSOR_PIN), pulseCounter, FALLING);
  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, pass);
  Blynk.config(BLYNK_AUTH_TOKEN);

  // NTP Sync (+8 for Malaysia)
  configTime(28800, 0, "pool.ntp.org", "time.nist.gov");
  Serial.print("Waiting for NTP sync...");
  time_t now = time(nullptr);
  int retries = 0;
  while (now < 24 * 3600 && retries < 20) {
    delay(500);
    Serial.print(".");
    now = time(nullptr);
    retries++;
  }
  Serial.println("\nTime synced.");

  // Watchdog setup
  esp_task_wdt_config_t twdt_config = {
      .timeout_ms = 300000,
      .idle_core_mask = 0,
      .trigger_panic = true,
  };
  esp_task_wdt_reconfigure(&twdt_config);
  // esp_task_wdt_add(NULL); -> Moved to dynamic window in checkSchedule()

  timer.setInterval(5000L, sendFlowRate);      // Balanced update (5 seconds)
  timer.setInterval(10000L, checkWiFi);        // WiFi status updates
  timer.setInterval(60000L, checkSchedule);    // Check schedule every minute
  Serial.println("=== SETUP COMPLETE ===");
}

void loop() {
  if (Blynk.connected()) Blynk.run();
  timer.run();
  if (wdtActive) esp_task_wdt_reset();

  // Real-time LED feedback: LED ON if water pulse detected in last 1.5s
  static bool currentLedState = false;
  bool shouldBeOn = (millis() - lastPulseTime < 1500 && lastPulseTime > 0);
  if (shouldBeOn != currentLedState) {
    currentLedState = shouldBeOn;
    digitalWrite(LED_PIN, currentLedState ? HIGH : LOW);
  }
}