#define BLYNK_TEMPLATE_NAME "ESP32 WIFI"
#define BLYNK_AUTH_TOKEN "MbA2y5hlAv4SpJ7-a-y9CDhSH9d2zfyd"

#include <WiFi.h>
#include <BlynkSimpleEsp32.h>
#include <HTTPClient.h>
#include <WiFiClientSecure.h>
#include <esp_task_wdt.h>

const char* googleScriptUrl = "https://script.google.com/macros/s/AKfycbw6NvqTFViBKepVJR1U8h83tk3qDTgYXf08oPubvSgFoqx4YWgLtQ71HhUk0xqkdrty/exec";

char ssid[] = "Fmz";
char pass[] = "iiiiiiii";

#define FLOW_SENSOR_PIN 27
#define LED_PIN 26
#define WIFI_LED_PIN 2

volatile int pulseCount = 0;
float flowRate = 0;
float lastFlowRate = -1; 
volatile unsigned long lastPulseTime = 0; 

BlynkTimer timer;

void IRAM_ATTR pulseCounter() {
  pulseCount++;
  lastPulseTime = millis();
}

void sendFlowRate() {
  noInterrupts();
  int count = pulseCount;
  pulseCount = 0;
  interrupts();

  // Calculation for 2-second interval:
  // pulses / 7.5 = Liters per minute if measured for 1 minute
  // Since we measure for 2 seconds (1/30th of a minute), we adjust:
  float flow_L_per_min = (count / 7.5) * 30.0; 
  flowRate = flow_L_per_min / 60.0;  // Convert to L/sec

  Serial.print("[FLOW] Pulses: ");
  Serial.print(count);
  Serial.print(" | Rate: ");
  Serial.print(flowRate, 3);
  Serial.println(" L/sec");

  // Only update Blynk if changed significantly to avoid flooding
  if (abs(flowRate - lastFlowRate) > 0.01) {
    Blynk.virtualWrite(V0, flowRate);
    lastFlowRate = flowRate;
  }
}

void logToGoogleSheets() {
  if (WiFi.status() == WL_CONNECTED) {
    WiFiClientSecure client;
    client.setInsecure();
    HTTPClient http;
    String url = String(googleScriptUrl) + "?flowE=" + String(flowRate, 3);
    
    Serial.print("[SHEETS] Logging... ");
    http.begin(client, url);
    http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);
    int httpCode = http.GET();
    Serial.println(httpCode > 0 ? "DONE" : "FAIL");
    http.end();
  }
}

void checkWiFi() {
  if (WiFi.status() == WL_CONNECTED) {
    digitalWrite(WIFI_LED_PIN, HIGH);   // 🔆 LED ON - WiFi OK
    Serial.println("✅ WiFi OK");
  } else {
    digitalWrite(WIFI_LED_PIN, LOW);  // ⚫ LED OFF - WiFi Lost
    Serial.println("📶 WiFi reconnect...");
    WiFi.begin(ssid, pass);
  }
}

void setup() {
  Serial.begin(115200);
  delay(1000); 
  Serial.println("\n=== WATERFLOW SENSOR E (2s INTERVAL) ===");

  pinMode(LED_PIN, OUTPUT);
  pinMode(WIFI_LED_PIN, OUTPUT);
  digitalWrite(WIFI_LED_PIN, LOW); // Default OFF
  // Initial LED Test
  for(int i=0; i<3; i++) {
    digitalWrite(LED_PIN, HIGH); delay(100);
    digitalWrite(LED_PIN, LOW);  delay(100);
  }

  pinMode(FLOW_SENSOR_PIN, INPUT_PULLUP);
  attachInterrupt(digitalPinToInterrupt(FLOW_SENSOR_PIN), pulseCounter, FALLING);

  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);

  // Watchdog setup
  esp_task_wdt_config_t twdt_config = {
      .timeout_ms = 30000,
      .idle_core_mask = 0,
      .trigger_panic = true,
  };
  esp_task_wdt_init(&twdt_config);
  esp_task_wdt_add(NULL);

  timer.setInterval(2000L, sendFlowRate);      // Faster update (2 seconds)
  timer.setInterval(10000L, checkWiFi);        // WiFi status updates
  timer.setInterval(300000L, logToGoogleSheets); // 5 minutes
  Serial.println("=== SETUP COMPLETE ===");
}

void loop() {
  Blynk.run();
  timer.run();
  esp_task_wdt_reset(); 

  // Real-time LED feedback: Turn ON if pulse was detected in the last 1.5 seconds
  if (millis() - lastPulseTime < 1500 && lastPulseTime > 0) {
    digitalWrite(LED_PIN, HIGH);
  } else {
    digitalWrite(LED_PIN, LOW);
  }
}