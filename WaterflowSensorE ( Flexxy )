void setup() {
  Serial.begin(115200);
  delay(1000); 
  Serial.println("\n=== WATERFLOW SENSOR E (2s INTERVAL) ===");

  pinMode(WIFI_LED_PIN, OUTPUT);
  pinMode(LED_PIN, OUTPUT);
  // Startup blink on external LED (power-on indicator)
  for(int i=0; i<3; i++) {
    digitalWrite(LED_PIN, HIGH); delay(100);
    digitalWrite(LED_PIN, LOW);  delay(100);
  }

  pinMode(FLOW_SENSOR_PIN, INPUT_PULLUP);
  attachInterrupt(digitalPinToInterrupt(FLOW_SENSOR_PIN), pulseCounter, FALLING);
  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, pass);
  Blynk.config(BLYNK_AUTH_TOKEN);

  // NTP Sync (+8 for Malaysia)
  configTime(28800, 0, "pool.ntp.org", "time.nist.gov");
  Serial.print("Waiting for NTP sync...");
  time_t now = time(nullptr);
  int retries = 0;
  while (now < 24 * 3600 && retries < 20) {
    delay(500);
    Serial.print(".");
    now = time(nullptr);
    retries++;
  }
  Serial.println("\nTime synced.");

  // Watchdog setup
  esp_task_wdt_config_t twdt_config = {
      .timeout_ms = 300000,
      .idle_core_mask = 0,
      .trigger_panic = true,
  };
  esp_task_wdt_reconfigure(&twdt_config);
  // esp_task_wdt_add(NULL); -> Moved to dynamic window in checkSchedule()

  timer.setInterval(5000L, sendFlowRate);      // Balanced update (5 seconds)
  timer.setInterval(10000L, checkWiFi);        // WiFi status updates
  timer.setInterval(60000L, checkSchedule);    // Check schedule every minute
  Serial.println("=== SETUP COMPLETE ===");
}

void loop() {
  if (Blynk.connected()) Blynk.run();
  timer.run();
  if (wdtActive) esp_task_wdt_reset();

  // Real-time LED feedback: LED ON if water pulse detected in last 1.5s
  static bool currentLedState = false;
  bool shouldBeOn = (millis() - lastPulseTime < 1500 && lastPulseTime > 0);
  if (shouldBeOn != currentLedState) {
    currentLedState = shouldBeOn;
    digitalWrite(LED_PIN, currentLedState ? HIGH : LOW);
  }
}