void IRAM_ATTR pulseCounter() {
  pulseCount++;
  lastPulseTime = millis();
}

void sendFlowRate() {
  noInterrupts();
  int count = pulseCount;
  pulseCount = 0;
  interrupts();

  // Calculation for 5-second interval:
  float flow_L_per_min = (count / 7.5) * 12.0; 
  flowRate = flow_L_per_min / 60.0;  // Convert to L/sec

  time_t now = time(nullptr);
  struct tm* timeinfo = localtime(&now);
  int hour = timeinfo->tm_hour;
  int minute = timeinfo->tm_min;

  Serial.print("[FLOW] Rate: ");
  Serial.print(flowRate, 3);
  Serial.println(" L/sec");

  // Define Windows (Starts 5m before process, ends 1m after)
  bool inMorningWindow = (hour == 7 && minute >= 55) || (hour == 8 && minute <= 31);
  bool inAfternoonWindow = (hour == 15 && minute >= 55) || (hour == 16 && minute <= 31);
  bool inActiveWindow = inMorningWindow || inAfternoonWindow;

  // --- WINDOWED WATCHDOG LOGIC ---
  if (inActiveWindow && !wdtActive) {
    esp_task_wdt_add(NULL);
    wdtActive = true;
    Serial.println("🛡️ [WATCHDOG] Armed for Irrigation Window.");
  } else if (!inActiveWindow && wdtActive) {
    esp_task_wdt_delete(NULL);
    wdtActive = false;
    Serial.println("🔓 [WATCHDOG] Disarmed (Idle Mode).");
  }

  if (inActiveWindow) {
    static unsigned long lastBlynkPublish = 0;
    
    // Connect if not connected during window
    if (!Blynk.connected()) {
      Serial.println("🌐 [WINDOW] Opening Blynk connection for active monitoring...");
      Blynk.connect();
    }

    // Publish every 30 seconds
    if (millis() - lastBlynkPublish >= 30000) {
      if (Blynk.connected()) {
        Blynk.virtualWrite(V0, flowRate);
        Serial.println("📤 [LIVE] Flow data sent (30s interval)");
        lastBlynkPublish = millis();
      }
    }
  } else {
    // Outside window - Ensure we are disconnected
    if (Blynk.connected()) {
      Serial.println("💤 [WINDOW END] Sending final reset and disconnecting...");
      Blynk.virtualWrite(V0, 0); // Failsafe reset
      Blynk.run();
      delay(500);
      Blynk.disconnect();
    }
  }
}

