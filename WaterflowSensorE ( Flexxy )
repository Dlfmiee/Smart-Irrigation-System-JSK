void IRAM_ATTR pulseCounter() {
  pulseCount++;
  lastPulseTime = millis();
}

void updatePumpNode(float rate) {
  if (WiFi.status() == WL_CONNECTED) {
    HTTPClient http;
    // Push directly to Pump Node (DTBuddy) for Dry-Run Protection
    String url = "http://blynk.cloud/external/api/update?token=" + String(pumpAuthToken) + "&V0=" + String(rate, 3);
    http.begin(url);
    http.GET();
    http.end();
  }
}

void sendFlowRate() {
  noInterrupts();
  uint32_t count = pulseCount;
  pulseCount = 0;
  interrupts();

  // Calculation for 5-second sampling:
  // pulses / 7.5 = L/min if measured for 60s. 
  // For 5s (1/12th of a minute), multiply by 12.0
  float flow_L_per_min = (count / 7.5) * 12.0; 
  flowRate = flow_L_per_min / 60.0;  // Convert to L/sec

  Serial.printf("[FLOW] Rate: %.3f L/sec\n", flowRate);

  // 1. SAFETY: Always push to Pump Node for Dry-Run protection
  // Massive Optimization: Stop spamming the server with "0" all night long!
  // It will now only push if water is running, or if it JUST stopped.
  static float lastPushedFlow = -10.0;
  if (flowRate > 0.01 || abs(flowRate - lastPushedFlow) > 0.01) {
    updatePumpNode(flowRate); 
    lastPushedFlow = flowRate;
  }

  // 2. LOGGING: Periodic Sheets update
  // (Handled by separate timer, but we update the flowRate variable here)

  // 3. APPS: Check Schedule & Report to Blynk App
  time_t now_t = time(nullptr);
  struct tm* timeinfo = localtime(&now_t);
  int hour = timeinfo->tm_hour;
  int minute = timeinfo->tm_min;

  // Window check: 5m before to 1m after cycles
  bool inMorningWindow = (hour == 7 && minute >= 55) || (hour == 8 && minute <= 31);
  bool inAfternoonWindow = (hour == 15 && minute >= 55) || (hour == 16 && minute <= 31);
  bool inActiveWindow = inMorningWindow || inAfternoonWindow;

  // Watchdog Management
  if (inActiveWindow && !wdtActive) {
    esp_task_wdt_add(NULL);
    wdtActive = true;
    Serial.println("🛡️ [WATCHDOG] Armed for cycle.");
  } else if (!inActiveWindow && wdtActive) {
    esp_task_wdt_delete(NULL);
    wdtActive = false;
    Serial.println("🔓 [WATCHDOG] Disarmed.");
  }

  if (inActiveWindow) {
    if (!Blynk.connected()) Blynk.connect();
    
    // Publish every 30 seconds OR if flow just stopped
    bool isTime = (millis() - lastBlynkPublish >= 30000);
    bool suddenStop = (flowRate < 0.001 && lastFlowRate > 0.001);

    if (isTime || suddenStop) {
      if (Blynk.connected()) {
        Blynk.virtualWrite(V0, flowRate);
        lastBlynkPublish = millis();
        lastFlowRate = flowRate;
        Serial.println("📤 [LIVE] Flow data sent (30s interval)");
      }
    }
  } else {
    // Outside window: Disconnect to save data/prevent flooding
    if (Blynk.connected()) {
      Blynk.virtualWrite(V0, 0); 
      Blynk.run();
      delay(500);
      Blynk.disconnect();
      Serial.println("💤 Cycle finished. Blynk disconnected.");
    }
  }
}

