#define BLYNK_TEMPLATE_NAME "ESP32 WIFI"
#define BLYNK_AUTH_TOKEN "MbA2y5hlAv4SpJ7-a-y9CDhSH9d2zfyd"

#include <WiFi.h>
#include <BlynkSimpleEsp32.h>
#include <HTTPClient.h>
#include <WiFiClientSecure.h>

const char* googleScriptUrl = "https://script.google.com/macros/s/AKfycbzp3ugFaaSGtBrX-RHZeHQjGB6KnfrzTSdFGqJvEvvV28-6j_nPyu6VP0Jhb2eOVl6B/exec";

char ssid[] = "SurauAl-Irfan";
char pass[] = "datangsurau";

#define FLOW_SENSOR_PIN 27
#define LED_PIN 26

volatile int pulseCount = 0;
float flowRate = 0;

BlynkTimer timer;

void IRAM_ATTR pulseCounter() {
  pulseCount++;
}

void sendFlowRate() {
  noInterrupts();
  int count = pulseCount;
  pulseCount = 0;
  interrupts();

  float flow_L_per_min = count / 7.5;
  flowRate = flow_L_per_min / 60.0;  // L/sec

  Serial.print("Flow rate: ");
  Serial.print(flowRate, 3);
  Serial.println(" L/sec");

  Blynk.virtualWrite(V0, flowRate);
}

void logToGoogleSheets() {
  if (WiFi.status() == WL_CONNECTED) {
    WiFiClientSecure client;
    client.setInsecure();
    HTTPClient http;

    String url = String(googleScriptUrl) + "?flowE=" + String(flowRate, 3);

    Serial.print("Logging to Google Sheets: ");
    http.begin(client, url);
    http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);
    int httpCode = http.GET();
    
    if (httpCode > 0) {
      Serial.println("OK (" + String(httpCode) + ")");
    } else {
      Serial.println("FAILED (" + http.errorToString(httpCode).c_str() + ")");
    }
    http.end();
  }
}

void setup() {
  Serial.begin(115200);

  pinMode(FLOW_SENSOR_PIN, INPUT_PULLUP);
  attachInterrupt(digitalPinToInterrupt(FLOW_SENSOR_PIN), pulseCounter, FALLING);

  pinMode(LED_PIN, OUTPUT);

  digitalWrite(LED_PIN, LOW);   // 🔥 LED ALWAYS ON (active LOW wiring)

  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);

  timer.setInterval(1000L, sendFlowRate);
  timer.setInterval(300000L, logToGoogleSheets); // Log every 5 minutes
}

void loop() {
  Blynk.run();
  timer.run();
}