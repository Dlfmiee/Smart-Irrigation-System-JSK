void IRAM_ATTR pulseCounter() {
  pulseCount++;
  lastPulseTime = millis();
}

void updateBlynkSilent(const char* token, String vPin, String value) {
  if (WiFi.status() != WL_CONNECTED) return;
  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;
  String url = "https://blynk.cloud/external/api/update?token=" + String(token) + "&" + vPin + "=" + value;
  http.begin(client, url);
  http.GET();
  http.end();
}

void syncNTP() {
  configTime(28800, 0, "pool.ntp.org", "time.google.com", "time.cloudflare.com");
  struct tm t;
  if (getLocalTime(&t, 2000)) {
    Serial.printf("✅ [NTP] Masa sync: %02d:%02d:%02d\n", t.tm_hour, t.tm_min, t.tm_sec);
    ntpSynced = true;
  }
}

void sendFlowRate() {
  noInterrupts();
  uint32_t count = pulseCount;
  pulseCount = 0;
  interrupts();

  float flow_L_per_min = (count / 7.5) * 2.0; 
  flowRate = flow_L_per_min / 60.0;  

  Serial.printf("[FLOW] Rate: %.3f L/sec\n", flowRate);

  static float lastPushedFlowToPump = -1.0;
  static float lastPushedFlowToDash = -1.0;
  
  // Update Pump (Safety) - only if changed significantly or sudden stop
  bool suddenStop = (flowRate < 0.005 && lastPushedFlowToPump > 0.02);
  if (abs(flowRate - lastPushedFlowToPump) > 0.02 || suddenStop) {
    updateBlynkSilent(pumpAuthToken, "V0", String(flowRate, 3)); 
    lastPushedFlowToPump = flowRate;
    if (suddenStop) Serial.println("🚨 [SAFETY] Sudden stop reported to Pump.");
    else Serial.println("📡 [BRIDGE] Flow updated to Master Pump.");
  }

  time_t now_t = time(nullptr);
  struct tm* timeinfo = localtime(&now_t);
  int hour = timeinfo->tm_hour;
  int minute = timeinfo->tm_min;

  bool inMorningWindow = (hour == 7 && minute >= 55) || (hour == 8 && minute <= 31);
  bool inAfternoonWindow = (hour == 15 && minute >= 55) || (hour == 16 && minute <= 31);
  bool inActiveWindow = inMorningWindow || inAfternoonWindow;

  if (inActiveWindow && !wdtActive) {
    esp_task_wdt_add(NULL); wdtActive = true;
    Serial.println("🛡️ [WATCHDOG] Armed for cycle.");
  } else if (!inActiveWindow && wdtActive) {
    esp_task_wdt_delete(NULL); wdtActive = false;
    Serial.println("🔓 [WATCHDOG] Disarmed.");
  }

  // Update Dashboard - only if in window AND changed significantly
  if (inActiveWindow || suddenStop) {
    if (abs(flowRate - lastPushedFlowToDash) > 0.01 || suddenStop) {
      updateBlynkSilent(BLYNK_AUTH_TOKEN, "V0", String(flowRate, 3));
      lastPushedFlowToDash = flowRate; 
      Serial.println("📤 [LIVE] Flow data sent to Dashboard.");
    }
  } else if (lastPushedFlowToDash > 0) {
    updateBlynkSilent(BLYNK_AUTH_TOKEN, "V0", "0");
    lastPushedFlowToDash = 0;
    Serial.println("💤 Window closed. Final zero sent.");
  }
}

void logToGoogleSheets() {
  if (WiFi.status() == WL_CONNECTED) {
    WiFiClientSecure client; client.setInsecure();
    HTTPClient http;
    String url = String(googleScriptUrl) + "?flowE=" + String(flowRate, 3);
    http.begin(client, url);
    http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);
    http.GET();
    http.end();
  }
}

void checkWiFi() {
  wl_status_t s = WiFi.status();
  if (s == WL_CONNECTED) {
    digitalWrite(WIFI_LED_PIN, HIGH);
    if (!ntpSynced) syncNTP();
  } else if (s == WL_DISCONNECTED || s == WL_NO_SSID_AVAIL || s == WL_CONNECT_FAILED) {
    digitalWrite(WIFI_LED_PIN, LOW);
    ntpSynced = false;
    Serial.println("📶 WiFi lost - attempting reconnect...");
    WiFi.begin(ssid, pass);
  }
}

void setup() {
  Serial.begin(115200);
  delay(1000); 
  Serial.println("\n=== WATERFLOW SENSOR E (POLISHED) ===");

  pinMode(WIFI_LED_PIN, OUTPUT);
  pinMode(LED_PIN, OUTPUT);
  for(int i=0; i<3; i++) {
    digitalWrite(LED_PIN, HIGH); delay(100); digitalWrite(LED_PIN, LOW); delay(100);
  }

  pinMode(FLOW_SENSOR_PIN, INPUT_PULLUP);
  attachInterrupt(digitalPinToInterrupt(FLOW_SENSOR_PIN), pulseCounter, FALLING);
  
  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, pass);
  Blynk.config(BLYNK_AUTH_TOKEN);

  // ChatGPT Improvement: Non-blocking setup (NTP will sync in background)
  esp_task_wdt_config_t twdt_config = { .timeout_ms = 300000, .idle_core_mask = 0, .trigger_panic = true };
  esp_task_wdt_reconfigure(&twdt_config);

  timer.setInterval(30000L, sendFlowRate);      
  timer.setInterval(30000L, checkWiFi);         
  timer.setInterval(900000L, logToGoogleSheets); 
  Serial.println("=== SETUP COMPLETE (Background Sync Active) ===");
}

void loop() {
  timer.run();
  if (wdtActive) esp_task_wdt_reset();
  
  static bool currentLedState = false;
  bool shouldBeOn = (millis() - lastPulseTime < 1500 && lastPulseTime > 0);
  if (shouldBeOn != currentLedState) {
    currentLedState = shouldBeOn;
    digitalWrite(LED_PIN, currentLedState ? HIGH : LOW);
  }
}