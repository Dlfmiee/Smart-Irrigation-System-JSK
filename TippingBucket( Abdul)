#define BLYNK_TEMPLATE_NAME "ESP32 WIFI"
#define BLYNK_AUTH_TOKEN "MbA2y5hlAv4SpJ7-a-y9CDhSH9d2zfyd"

#include <WiFi.h>
#include <BlynkSimpleEsp32.h>
#include <HTTPClient.h>
#include <WiFiClientSecure.h>
#include <esp_task_wdt.h>

const char* googleScriptUrl = "https://script.google.com/macros/s/AKfycbw6NvqTFViBKepVJR1U8h83tk3qDTgYXf08oPubvSgFoqx4YWgLtQ71HhUk0xqkdrty/exec";

char ssid[] = "SurauAl-Irfan";
char pass[] = "datangsurau";

const int REED_PIN = 27;
const float RAIN_PER_TIP = 0.2;
const float LOCKOUT_THRESHOLD = 5.0; // Trigger lockout at 5mm

unsigned long tipCount = 0;
bool lastState = HIGH;
unsigned long lastDebounceTime = 0;
const unsigned long debounceDelay = 150;

BlynkTimer timer;
float lastRainfall = -1; // For delta logging

// Hantar hanya rainfall
void sendData() {
  float rainfall = tipCount * RAIN_PER_TIP;

  // Delta check: only send if changed by more than 0.1mm
  if (abs(rainfall - lastRainfall) > 0.1) {
    Blynk.virtualWrite(V8, rainfall);
    lastRainfall = rainfall;
    Serial.println("[BLYNK] Sent rainfall.");
  } else {
    Serial.println("[DELTA] No change, skipping Blynk.");
  }

  Serial.print("Rainfall: ");
  Serial.print(rainfall);
  Serial.println(" mm");
  
  // Composite Rain Lockout
  if (rainfall >= LOCKOUT_THRESHOLD) {
    Blynk.virtualWrite(V12, 1);
    Serial.println("High Rainfall! Triggering Rain Lockout (V12).");
  }
}

void logToGoogleSheets() {
  float rainfall = tipCount * RAIN_PER_TIP;

  if (WiFi.status() == WL_CONNECTED) {
    WiFiClientSecure client;
    client.setInsecure();
    HTTPClient http;

    String url = String(googleScriptUrl) + "?rainfall=" + String(rainfall, 2);

    Serial.print("Logging to Google Sheets: ");
    http.begin(client, url);
    http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);
    int httpCode = http.GET();
    
    if (httpCode > 0) {
      Serial.println("OK (" + String(httpCode) + ")");
    } else {
      Serial.println("FAILED (" + http.errorToString(httpCode) + ")");
    }
    http.end();
  }
}

void setup() {
  Serial.begin(115200);
  pinMode(REED_PIN, INPUT_PULLUP);

  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);

  // Hardware Watchdog: reboot if loop freezes for 30 seconds
  esp_task_wdt_init(30, true);
  esp_task_wdt_add(NULL);

  timer.setInterval(60000L, sendData);
  timer.setInterval(300000L, logToGoogleSheets); // Log every 5 minutes
}

void loop() {
  Blynk.run();
  timer.run();
  esp_task_wdt_reset(); // Feed watchdog to prevent reboot

  bool currentState = digitalRead(REED_PIN);

  if (lastState == HIGH && currentState == LOW) {
    unsigned long now = millis();

    if (now - lastDebounceTime > debounceDelay) {
      tipCount++;
      lastDebounceTime = now;

      Serial.print("Tip: ");
      Serial.println(tipCount);
    }
  }

  lastState = currentState;
}