const int REED_PIN = 27;
const int WIFI_LED_PIN = 2; // Built-in Wi-Fi Status LED
const float RAIN_PER_TIP = 0.2;
const float LOCKOUT_THRESHOLD = 5.0; // Trigger lockout at 5mm

volatile unsigned long tipCount = 0;
volatile unsigned long lastDebounceTime = 0;
const unsigned long debounceDelay = 150;

// Flag to track when a tip has occurred for serial printing
volatile bool tipOccurred = false;

// Trackers for logic
unsigned long lastBlynkTipCount = 0;
int lastResetDay = -1;

/************ BRIDGE TO PUMP ************/
void shoutToMasterPump(int lockoutValue) {
  if (WiFi.status() != WL_CONNECTED) return;
  
  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;
  
  String url = "https://blynk.cloud/external/api/update?token=" + String(MASTER_PUMP_TOKEN) + "&v12=" + String(lockoutValue);
  
  Serial.print("[BRIDGE] Syncing Pump V12 -> ");
  Serial.println(lockoutValue);
  
  http.begin(client, url);
  int httpCode = http.GET();
  if (httpCode > 0) {
    Serial.println("[BRIDGE] Success: " + String(httpCode));
  } else {
    Serial.println("[BRIDGE] Failed: " + http.errorToString(httpCode));
  }
  http.end();
}

// Interrupt Service Routine (ISR) - Runs instantly on signal
void IRAM_ATTR handleTip() {
  unsigned long now = millis();
  if (now - lastDebounceTime > debounceDelay) {
    tipCount++;
    lastDebounceTime = now;
    tipOccurred = true; 
  }
}

BlynkTimer timer;

void checkMidnightReset() {
  struct tm timeinfo;
  if (getLocalTime(&timeinfo)) {
    // Reset exactly at midnight (00:00)
    if (timeinfo.tm_hour == 0 && timeinfo.tm_min == 0) {
      if (lastResetDay != timeinfo.tm_mday) {
        tipCount = 0;
        lastBlynkTipCount = 0;
        lastResetDay = timeinfo.tm_mday;
        Serial.println("Midnight! Rain counter has been RESET.");
        Blynk.virtualWrite(V8, 0.0); // Reset dashboard immediately
        shoutToMasterPump(0);
      }
    }
  }
}

// Hantar data ke Blynk
void sendData() {
  unsigned long currentTips = tipCount;
  float totalRainfall = currentTips * RAIN_PER_TIP;

  // Send Daily Total to Blynk (V8)
  Blynk.virtualWrite(V8, totalRainfall);
  Serial.print("[BLYNK] Daily Total Rainfall: ");
  Serial.print(totalRainfall);
  Serial.println(" mm");
  
  // Composite Rain Lockout based on TOTAL
  if (totalRainfall >= LOCKOUT_THRESHOLD) {
    Blynk.virtualWrite(V12, 1);
    Serial.println("High Rainfall! Triggering Rain Lockout (V12).");
    shoutToMasterPump(1);
  }
}

void logToGoogleSheets() {
  float rainfall = tipCount * RAIN_PER_TIP;

  if (WiFi.status() == WL_CONNECTED) {
    WiFiClientSecure client;
    client.setInsecure();
    HTTPClient http;

    String url = String(googleScriptUrl) + "?rainfall=" + String(rainfall, 2);

    Serial.print("Logging to Google Sheets: ");
    http.begin(client, url);
    http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);
    int httpCode = http.GET();
    
    if (httpCode > 0) {
      Serial.println("OK (" + String(httpCode) + ")");
    } else {
      Serial.println("FAILED (" + http.errorToString(httpCode) + ")");
    }
    http.end();
  }
}

void checkWiFi() {
  if (WiFi.status() == WL_CONNECTED) {
    digitalWrite(WIFI_LED_PIN, HIGH);   // 🔆 LED ON - WiFi OK
    Serial.println("✅ WiFi OK");
  } else {
    digitalWrite(WIFI_LED_PIN, LOW);  // ⚫ LED OFF - WiFi Lost
    Serial.println("📶 WiFi reconnect...");
    WiFi.begin(ssid, pass);
  }
}

void setup() {
  Serial.begin(115200);
  pinMode(REED_PIN, INPUT_PULLUP);
  pinMode(WIFI_LED_PIN, OUTPUT);
  digitalWrite(WIFI_LED_PIN, LOW);

  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);

  // Hardware Watchdog: reboot if loop freezes for 30 seconds
  esp_task_wdt_config_t twdt_config = {
      .timeout_ms = 30000,
      .idle_core_mask = 0,
      .trigger_panic = true,
  };
  esp_task_wdt_init(&twdt_config);
  esp_task_wdt_add(NULL);

  // Set Timezone Malaysia (GMT+8)
  configTime(28800, 0, "pool.ntp.org", "time.nist.gov");

  timer.setInterval(60000L, sendData); // Send to Blynk every 1 minute
  timer.setInterval(30000L, checkMidnightReset); // Check reset every 30s
  timer.setInterval(10000L, checkWiFi);          // WiFi indicator
  timer.setInterval(300000L, logToGoogleSheets); // Log every 5 minutes

  // Attach Interrupt to GPIO 27 - Triggers on FALLING edge (HIGH to LOW)
  attachInterrupt(digitalPinToInterrupt(REED_PIN), handleTip, FALLING);
}

void loop() {
  Blynk.run();
  timer.run();
  esp_task_wdt_reset(); // Feed watchdog to prevent reboot

  // Print tip message in loop instead of ISR to keep ISR fast
  if (tipOccurred) {
    tipOccurred = false;
    Serial.print("Tip detected! Total count: ");
    Serial.println(tipCount);
  }
}