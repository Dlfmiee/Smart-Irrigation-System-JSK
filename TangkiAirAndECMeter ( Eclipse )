/************ VARIABLE ************/
int analogValue = 0;
float voltage   = 0;
float tdsValue  = 0;
float ecValue   = 0;

BlynkTimer timer;
int lastReportDay = -1;

/************ FUNCTION ************/

// ✅ BAIKI #2 & #4 — fungsi baca sensor, boleh dipanggil dari mana-mana
void readSensors() {
  int floatState  = digitalRead(FLOAT_PIN);
  int floatStatus = (floatState == LOW) ? 1 : 0;

  analogValue = analogRead(TDS_PIN);
  voltage     = analogValue * VREF / 4095.0;
  tdsValue    = (voltage / VREF) * 1000.0;
  ecValue     = tdsValue / 500.0;

  Serial.print("[MONITOR] Float: ");
  Serial.print(floatStatus ? "FULL" : "LOW");
  Serial.print(" | TDS: ");
  Serial.print(tdsValue, 0);
  Serial.print(" ppm | EC: ");
  Serial.print(ecValue, 2);
  Serial.println(" mS/cm");
}

void sendDailyReport() {
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("[REPORT] Skipped — no WiFi.");
    return;
  }

  // ✅ BAIKI #4 — baca sensor terkini sebelum hantar
  readSensors();

  int floatState  = digitalRead(FLOAT_PIN);
  int floatStatus = (floatState == LOW) ? 1 : 0;

  Serial.println("📤 [SCHEDULED] Connecting for Tank/EC sync...");
  Blynk.connect();
  
  unsigned long start = millis();
  while (!Blynk.connected() && millis() - start < 10000) {
    Blynk.run();
    delay(100);
  }

  if (Blynk.connected()) {
    // 1. Hantar ke Blynk
    Blynk.virtualWrite(V1, floatStatus);
    Blynk.virtualWrite(V2, ecValue);
    
    Blynk.run();
    delay(1000);
    Blynk.disconnect();
    Serial.println("✅ Sync Complete. Disconnected.");
  }

  // 2. Hantar ke Google Sheets
  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;

  String url = String(googleScriptUrl)
             + "?ec="   + String(ecValue, 2)
             + "&tank=" + String(floatStatus);

  http.begin(client, url);
  http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);
  int httpCode = http.GET();

  if (httpCode > 0) Serial.println("[REPORT] Sheets OK (" + String(httpCode) + ")");
  else              Serial.println("[REPORT] Sheets FAILED (" + http.errorToString(httpCode) + ")");

  http.end();
}

bool wdtActive = false;

void checkDailySchedule() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) {
    Serial.println("[NTP] Gagal dapatkan masa.");
    return;
  }

  // --- WINDOWED WATCHDOG LOGIC ---
  // Window: 06:57 to 07:05
  bool inWindow = ( (timeinfo.tm_hour == 6 && timeinfo.tm_min >= 57) || 
                    (timeinfo.tm_hour == 7 && timeinfo.tm_min <= 5) );

  if (inWindow && !wdtActive) {
    esp_task_wdt_add(NULL);
    wdtActive = true;
    Serial.println("🛡️ [WATCHDOG] Armed for Daily Report Window.");
  } else if (!inWindow && wdtActive) {
    esp_task_wdt_delete(NULL);
    wdtActive = false;
    Serial.println("🔓 [WATCHDOG] Disarmed (Idle Mode).");
  }

  // ✅ KEKAL — tanpa semak minit, trigger pada jam 7 pagi sekali sehari
  if (timeinfo.tm_hour == 7 && lastReportDay != timeinfo.tm_mday) {
    sendDailyReport();
    lastReportDay = timeinfo.tm_mday;
  }
}

// ✅ BAIKI #3 — tunjuk IP & RSSI
void checkWiFi() {
  if (WiFi.status() == WL_CONNECTED) {
    digitalWrite(WIFI_LED_PIN, HIGH);
    Serial.print("✅ WiFi OK | IP: ");
    Serial.print(WiFi.localIP());
    Serial.print(" | RSSI: ");
    Serial.print(WiFi.RSSI());
    Serial.println(" dBm");
  } else {
    digitalWrite(WIFI_LED_PIN, LOW);
    Serial.println("📶 WiFi lost — reconnecting...");
    WiFi.begin(ssid, pass);
  }
}

/************ SETUP ************/
void setup() {
  Serial.begin(115200);

  pinMode(FLOAT_PIN,    INPUT_PULLUP);
  pinMode(TDS_PIN,      INPUT);
  pinMode(LED_PIN,      OUTPUT);
  pinMode(WIFI_LED_PIN, OUTPUT);

  digitalWrite(LED_PIN,      HIGH);
  digitalWrite(WIFI_LED_PIN, LOW);

  // ✅ BAIKI #6 — WiFi dengan feedback
  Serial.print("[WIFI] Connecting to: ");
  Serial.println(ssid);
  WiFi.begin(ssid, pass);

  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED && attempts < 20) {
    digitalWrite(WIFI_LED_PIN, !digitalRead(WIFI_LED_PIN));
    delay(500);
    Serial.print(".");
    attempts++;
  }

  if (WiFi.status() == WL_CONNECTED) {
    digitalWrite(WIFI_LED_PIN, HIGH);
    Serial.println("\n✅ WiFi Connected!");
    Serial.print("   IP   : "); Serial.println(WiFi.localIP());
    Serial.print("   RSSI : "); Serial.print(WiFi.RSSI()); Serial.println(" dBm");
  } else {
    digitalWrite(WIFI_LED_PIN, LOW);
    Serial.println("\n❌ WiFi FAILED — Blynk will retry in background.");
  }

  Blynk.config(BLYNK_AUTH_TOKEN);
  configTime(28800, 0, "pool.ntp.org");   // UTC+8 Malaysia

  // ===== WATCHDOG =====
  esp_task_wdt_config_t twdt_config = {
      .timeout_ms     = 300000,
      .idle_core_mask = 0,
      .trigger_panic  = true,
  };
  esp_task_wdt_reconfigure(&twdt_config);
  // esp_task_wdt_add(NULL); -> Moved to dynamic window in checkDailySchedule()

  // ✅ BAIKI #2 — baca sensor terus masa start, jangan tunggu 60s
  readSensors();

  // ===== TIMER =====
  timer.setInterval(60000L, readSensors);          // Monitor setiap 60s
  timer.setInterval(30000L, checkWiFi);            // Semak WiFi setiap 30s
  timer.setInterval(30000L, checkDailySchedule);   // Semak jadual setiap 30s

  Serial.println("[SYSTEM] Ready — ESP32 + Blynk + TDS + Float + Schedule 07:00");
}

/************ LOOP ************/
void loop() {
  if (Blynk.connected()) Blynk.run();
  timer.run();
  if (wdtActive) esp_task_wdt_reset();
}