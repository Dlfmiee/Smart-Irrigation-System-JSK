const char* googleScriptUrl = "https://script.google.com/macros/s/AKfycbw6NvqTFViBKepVJR1U8h83tk3qDTgYXf08oPubvSgFoqx4YWgLtQ71HhUk0xqkdrty/exec";

/************ VARIABLE ************/
int analogValue = 0;
float voltage = 0;
float tdsValue = 0;
float ecValue = 0;

BlynkTimer timer;
float lastEcValue = -1;   // For delta logging
int lastFloatStatus = -1; // For delta logging

/************ FUNCTION ************/
void sendToBlynk() {

  // ===== FLOAT SWITCH =====
  int floatState = digitalRead(FLOAT_PIN);
  int floatStatus = (floatState == LOW) ? 1 : 0;

  // ===== TDS SENSOR =====
  analogValue = analogRead(TDS_PIN);
  voltage = analogValue * VREF / 4095.0;
  tdsValue = (voltage / VREF) * 1000.0;
  ecValue = tdsValue / 500.0;

  // ===== SERIAL =====
  Serial.print("FLOAT: ");
  Serial.print(floatStatus ? "ON" : "OFF");
  Serial.print(" | TDS: ");
  Serial.print(tdsValue, 0);
  Serial.print(" ppm | EC: ");
  Serial.print(ecValue, 2);
  Serial.println(" ms/cm");

  // ===== SEND TO BLYNK (Delta Check) =====
  if (lastFloatStatus != floatStatus) {
    Blynk.virtualWrite(V1, floatStatus);
    lastFloatStatus = floatStatus;
    Serial.println("[BLYNK] Sent float status.");
  }
  if (abs(ecValue - lastEcValue) > 0.05) {
    Blynk.virtualWrite(V2, ecValue);
    lastEcValue = ecValue;
    Serial.println("[BLYNK] Sent EC value.");
  }
  if (lastFloatStatus == floatStatus && abs(ecValue - lastEcValue) <= 0.05) {
    Serial.println("[DELTA] No change, skipping Blynk.");
  }

  // ===== HEARTBEAT LED =====
  digitalWrite(LED_PIN, !digitalRead(LED_PIN));
}

void logToGoogleSheets() {
  int floatState = digitalRead(FLOAT_PIN);
  int floatStatus = (floatState == LOW) ? 1 : 0;
  String statusStr = floatStatus ? "TANK_FULL" : "TANK_LOW";

  if (WiFi.status() == WL_CONNECTED) {
    WiFiClientSecure client;
    client.setInsecure();
    HTTPClient http;

    String url = String(googleScriptUrl) + "?ec=" + String(ecValue, 2) + "&tank=" + String(floatStatus);

    Serial.print("Logging to Google Sheets: ");
    http.begin(client, url);
    http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);
    int httpCode = http.GET();
    
    if (httpCode > 0) {
      Serial.println("OK (" + String(httpCode) + ")");
    } else {
      Serial.println("FAILED (" + http.errorToString(httpCode) + ")");
    }
    http.end();
  }
}

void checkWiFi() {
  if (WiFi.status() == WL_CONNECTED) {
    digitalWrite(WIFI_LED_PIN, HIGH);   // 🔆 LED ON - WiFi OK
    Serial.println("✅ WiFi OK");
  } else {
    digitalWrite(WIFI_LED_PIN, LOW);  // ⚫ LED OFF - WiFi Lost
    Serial.println("📶 WiFi reconnect...");
    WiFi.begin(ssid, pass);
  }
}

void setup() {
  Serial.begin(115200);

  pinMode(FLOAT_PIN, INPUT_PULLUP);
  pinMode(TDS_PIN, INPUT);
  pinMode(LED_PIN, OUTPUT);
  pinMode(WIFI_LED_PIN, OUTPUT);

  digitalWrite(LED_PIN, HIGH);
  digitalWrite(WIFI_LED_PIN, LOW);

  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);

  // Hardware Watchdog: reboot if loop freezes for 30 seconds
  esp_task_wdt_config_t twdt_config = {
      .timeout_ms = 30000,
      .idle_core_mask = 0,
      .trigger_panic = true,
  };
  esp_task_wdt_init(&twdt_config);
  esp_task_wdt_add(NULL);

  timer.setInterval(60000L, sendToBlynk);
  timer.setInterval(10000L, checkWiFi);
  timer.setInterval(300000L, logToGoogleSheets); // Log every 5 minutes

  Serial.println("SYSTEM START - ESP32 + BLYNK");
}

void loop() {
  Blynk.run();
  timer.run();
  esp_task_wdt_reset(); // Feed watchdog to prevent reboot
}