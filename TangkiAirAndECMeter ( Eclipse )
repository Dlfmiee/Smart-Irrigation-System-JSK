#define FLOAT_PIN    4
#define TDS_PIN      34
#define WIFI_LED_PIN  2
#define VREF         3.3

BlynkTimer timer;
int lastReportDay = -1;
bool ntpSynced = false;
bool wdtActive = false;
float ecValue = 0.0;

void updateBlynkSilent(String params) {
  if (WiFi.status() != WL_CONNECTED) return;
  WiFiClientSecure client; client.setInsecure();
  HTTPClient http;
  String url = "https://blynk.cloud/external/api/update?token=" + String(BLYNK_AUTH_TOKEN) + "&" + params;
  http.begin(client, url); http.GET(); http.end();
}

void syncNTP() {
  configTime(28800, 0, "pool.ntp.org", "time.google.com");
  struct tm t; if (getLocalTime(&t, 1000)) ntpSynced = true;
}

void checkWiFi() {
  wl_status_t s = WiFi.status();
  if (s == WL_CONNECTED) {
    digitalWrite(WIFI_LED_PIN, HIGH);
    if (!ntpSynced) syncNTP();
  } else if (s == WL_DISCONNECTED || s == WL_NO_SSID_AVAIL || s == WL_CONNECT_FAILED) {
    digitalWrite(WIFI_LED_PIN, LOW); ntpSynced = false;
    WiFi.begin(ssid, pass);
  }
}

void readSensors() {
  int floatStatus = (digitalRead(FLOAT_PIN) == LOW) ? 1 : 0;
  ecValue = (analogRead(TDS_PIN) * VREF / 4095.0) / 0.5; // Simple EC calc
  Serial.printf("[TANK] status: %d | EC: %.2f\n", floatStatus, ecValue);
}

void sendDailyReport() {
  if (WiFi.status() != WL_CONNECTED) return;
  readSensors();
  int floatStatus = (digitalRead(FLOAT_PIN) == LOW) ? 1 : 0;
  updateBlynkSilent("V1=" + String(floatStatus) + "&V2=" + String(ecValue, 2));
}

void checkDailySchedule() {
  struct tm ti; if (!getLocalTime(&ti)) return;
  int h = ti.tm_hour; int m = ti.tm_min;

  bool inWindow = (h == 6 && m >= 55) || (h == 7 && m <= 10);
  if (inWindow && !wdtActive) { esp_task_wdt_add(NULL); wdtActive = true; }
  else if (!inWindow && wdtActive) { esp_task_wdt_delete(NULL); wdtActive = false; }

  if (h == 7 && m == 5 && lastReportDay != ti.tm_mday) {
    lastReportDay = ti.tm_mday; sendDailyReport();
  }
}

void setup() {
  Serial.begin(115200);
  pinMode(FLOAT_PIN, INPUT_PULLUP); pinMode(TDS_PIN, INPUT); pinMode(WIFI_LED_PIN, OUTPUT);

  WiFi.mode(WIFI_STA); WiFi.begin(ssid, pass);
  Blynk.config(BLYNK_AUTH_TOKEN);

  esp_task_wdt_config_t twdt_config = { .timeout_ms = 300000, .idle_core_mask = 0, .trigger_panic = true };
  esp_task_wdt_reconfigure(&twdt_config);

  timer.setInterval(30000L, checkWiFi);
  timer.setInterval(60000L, checkDailySchedule);
}

void loop() {
  timer.run();
  if (wdtActive) esp_task_wdt_reset();
}