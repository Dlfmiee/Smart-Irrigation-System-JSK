/************ BLYNK SETUP ************/
#define BLYNK_PRINT Serial

#define BLYNK_TEMPLATE_ID   "TMPL67aY-VULb"
#define BLYNK_TEMPLATE_NAME "ESP32 WIFI"
#define BLYNK_AUTH_TOKEN    "MbA2y5hlAv4SpJ7-a-y9CDhSH9d2zfyd"

/************ WIFI ************/
char ssid[] = "SurauAl-Irfan";
char pass[] = "datangsurau";

/************ PIN ************/
#define FLOAT_PIN 13
#define TDS_PIN   34
#define LED_PIN   27
#define WIFI_LED_PIN 2
#define VREF      3.3

#include <WiFi.h>
#include <WiFiClient.h>
#include <BlynkSimpleEsp32.h>
#include <HTTPClient.h>
#include <WiFiClientSecure.h>
#include <time.h>
#include <esp_task_wdt.h>

const char* googleScriptUrl = "https://script.google.com/macros/s/AKfycbw6NvqTFViBKepVJR1U8h83tk3qDTgYXf08oPubvSgFoqx4YWgLtQ71HhUk0xqkdrty/exec";

/************ VARIABLE ************/
int analogValue = 0;
float voltage = 0;
float tdsValue = 0;
float ecValue = 0;

BlynkTimer timer;
float lastEcValue = -1;
int lastFloatStatus = -1;
int lastReportDay = -1;  // Tracks daily reporting

/************ FUNCTION ************/
void readSensors() {
  // ===== FLOAT SWITCH =====
  int floatState = digitalRead(FLOAT_PIN);
  int floatStatus = (floatState == LOW) ? 1 : 0;

  // ===== TDS SENSOR =====
  analogValue = analogRead(TDS_PIN);
  voltage = analogValue * VREF / 4095.0;
  tdsValue = (voltage / VREF) * 1000.0;
  ecValue = tdsValue / 500.0;

  // ===== LOCAL SERIAL MONITOR (Every min) =====
  Serial.print("[MONITOR] Float: ");
  Serial.print(floatStatus ? "FULL" : "LOW");
  Serial.print(" | EC: ");
  Serial.println(ecValue, 2);
}

void sendDailyReport() {
  if (WiFi.status() != WL_CONNECTED) return;

  int floatState = digitalRead(FLOAT_PIN);
  int floatStatus = (floatState == LOW) ? 1 : 0;

  Serial.println("📢 [REPORT] Sending Daily Data (07:00 AM)...");

  // 1. Send to Blynk
  Blynk.virtualWrite(V1, floatStatus);
  Blynk.virtualWrite(V2, ecValue);

  // 2. Send to Google Sheets
  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;

  String url = String(googleScriptUrl) + "?ec=" + String(ecValue, 2) + "&tank=" + String(floatStatus);
  
  http.begin(client, url);
  http.setFollowRedirects(HTTPC_STRICT_FOLLOW_REDIRECTS);
  int httpCode = http.GET();
  
  if (httpCode > 0) Serial.println("[REPORT] Sheets Success");
  else Serial.println("[REPORT] Sheets Failed");
  http.end();
}

void checkDailySchedule() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return;

  // Run at 07:00 AM once per day
  if (timeinfo.tm_hour == 7 && lastReportDay != timeinfo.tm_mday) {
    sendDailyReport();
    lastReportDay = timeinfo.tm_mday;
  }
}

void checkWiFi() {
  if (WiFi.status() == WL_CONNECTED) {
    digitalWrite(WIFI_LED_PIN, HIGH);   // 🔆 LED ON - WiFi OK
    Serial.println("✅ WiFi OK");
  } else {
    digitalWrite(WIFI_LED_PIN, LOW);  // ⚫ LED OFF - WiFi Lost
    Serial.println("📶 WiFi reconnect...");
    WiFi.begin(ssid, pass);
  }
}

void setup() {
  Serial.begin(115200);

  pinMode(FLOAT_PIN, INPUT_PULLUP);
  pinMode(TDS_PIN, INPUT);
  pinMode(LED_PIN, OUTPUT);
  pinMode(WIFI_LED_PIN, OUTPUT);

  digitalWrite(LED_PIN, HIGH);
  digitalWrite(WIFI_LED_PIN, LOW);

  WiFi.begin(ssid, pass);
  Blynk.config(BLYNK_AUTH_TOKEN);
  configTime(28800, 0, "pool.ntp.org");

  // Hardware Watchdog: reboot if loop freezes for 30 seconds
  esp_task_wdt_config_t twdt_config = {
      .timeout_ms = 30000,
      .idle_core_mask = 0,
      .trigger_panic = true,
  };
  esp_task_wdt_init(&twdt_config);
  esp_task_wdt_add(NULL);

  timer.setInterval(60000L, readSensors);         // Local view every min
  timer.setInterval(30000L, checkWiFi);           // Wifi check 30s
  timer.setInterval(30000L, checkDailySchedule); // Schedule check 30s

  Serial.println("SYSTEM START - ESP32 + BLYNK");
}

void loop() {
  Blynk.run();
  timer.run();
  esp_task_wdt_reset(); // Feed watchdog to prevent reboot
}